    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo#EMMO_2bb50428_568d_46e8_b8bf_59a4c5656461> a owl:ObjectProperty ;
    rdfs:label "isOutputOf"^^xsd:string ;
    dcterms:description "A process that this dataset is the output to."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "emmo:EMMO_43e9a05d_98af_41b4_92f6_00f79a09bfce"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo#EMMO_31252f35_c767_4b97_a877_1235076c3e13> a owl:AnnotationProperty ;
    rdfs:label "conceptualisation"^^xsd:string ;
    dcterms:description "A comment that helps the reader to understand how the world has been conceptualised by the ontology authors."^^xsd:string ;
    rdfs:domain "rdfs:Class"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo#EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9> a owl:AnnotationProperty ;
    rdfs:label "elucidation"^^xsd:string ;
    dcterms:description "Short enlightening explanation aimed to facilitate the user in drawing the connection (interpretation) between a OWL entity and the real world object(s) for which it stands.  It should address the real world entities using the concepts introduced by the conceptualisation."^^xsd:string ;
    rdfs:domain "rdfs:Class"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo#EMMO_b19aacfc_5f73_4c33_9456_469c1e89a53e> a owl:ObjectProperty ;
    rdfs:label "hasDatum"^^xsd:string ;
    dcterms:description "Relates a dataset to its datum parts."^^xsd:string ;
    vann:usageNote "`hasDatum` relations are normally NOT specified manually, since they are generated from the DLite data model."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "emmo:EMMO_50d6236a_7667_4883_8ae1_9bb5d190423a"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo#EMMO_f702bad4_fc77_41f0_a26d_79f6444fd4f3> a owl:ObjectProperty ;
    rdfs:label "isDescriptionFor"^^xsd:string ;
    dcterms:description "An object (e.g. a material) that this dataset describes."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

ns1:conformance a owl:ObjectProperty ;
    rdfs:label "conformance"@en ;
    dcterms:description "Whether the annotation is mandatory, recommended or optional."@en ;
    vann:usageNote "It MUST take one of the values 'ddoc:mandatory', 'ddoc:recommended' or 'ddoc:optional'."@en ;
    rdfs:domain dcat:Resource ;
    rdfs:isDefinedBy <https://w3id.org/emmo/application/datadoc>,
        ns1: ;
    rdfs:range ns1:ConformanceLevel .

ns1:curationDate a owl:ObjectProperty ;
    rdfs:label "curationDate"^^xsd:string ;
    dcterms:description "Date of curation."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:date"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

ns1:curator a owl:ObjectProperty ;
    rdfs:label "curator"^^xsd:string ;
    dcterms:description "The agent that curated the resource."^^xsd:string ;
    vann:usageNote "Use `ddoc:curationDate` to refer to the date of curation."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "foaf:Agent"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

ns1:datadoc a skos:Concept ;
    rdfs:label "datadoc"@en ;
    dcterms:description "Basic data documentation."@en ;
    vann:usageNote "Intended to be used as a theme individual for basic data documentation."@en .

ns1:datatype a owl:ObjectProperty ;
    rdfs:label "datatype"@en ;
    dcterms:description "A datatype for annotations and data properties."@en ;
    rdfs:domain rdfs:Resource ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range rdfs:Datatype .

ns1:process a skos:Concept ;
    rdfs:label "process"@en ;
    dcterms:description "Basic documentation of processes."@en ;
    vann:usageNote "Intended to be used as a theme individual for basic documentation of processes."@en .

ns1:unitSymbol a owl:AnnotationProperty ;
    rdfs:label "unitSymbol"@en ;
    dcterms:description "A SI unit associated to a property."@en ;
    vann:usageNote "The unit should be written with standard SI unit symbols.  Examples: As, μm, J, m/s²"@en ;
    rdfs:domain dcat:Resource ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range xsd:string .

<https://w3id.org/emmo/domain/oteio#Generator> a owl:Class ;
    dcterms:description "A generator that can serialise an instance of a datamodel into a distribution."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "oteio:Parser"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#Parser> a owl:Class ;
    dcterms:description "A parser that can parse a distribution into an instance of a datamodel."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

<https://w3id.org/emmo/domain/oteio#generator> a owl:ObjectProperty ;
    rdfs:label "generator"^^xsd:string ;
    dcterms:description "A generator that can create the distribution."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "oteio:Generator"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#generatorType> a owl:AnnotationProperty ;
    rdfs:label "generatorType"^^xsd:string ;
    dcterms:description "Generator type. Ex: `application/vnd.dlite-generate`."^^xsd:string ;
    rdfs:domain "oteio:Generator"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#hasConfiguration> a owl:DatatypeProperty ;
    rdfs:label "configuration"^^xsd:string ;
    dcterms:description "A JSON string with configurations specific to the parser or generator."^^xsd:string ;
    rdfs:domain "oteio:Parser"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:JSON"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#hasDatamodel> a owl:ObjectProperty ;
    rdfs:label "datamodel"^^xsd:string ;
    dcterms:description "URI of DLite datamodel for the dataset."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "oteio:Datamodel"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#hasDatamodelStorage> a owl:DatatypeProperty ;
    rdfs:label "datamodelStorage"^^xsd:string ;
    dcterms:description "URL to DLite storage plugin where the datamodel is stored."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:anyURI"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#mapping> a owl:DatatypeProperty ;
    rdfs:label "mappings"^^xsd:string ;
    dcterms:description "A list of subject-predicate-object triples mapping the datamodel to ontological concepts."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:JSON"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#mappingFormat> a owl:AnnotationProperty ;
    rdfs:label "mappingFormat"^^xsd:string ;
    dcterms:description "File format for `mappingURL`. Defaults to \"turtle\"."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#mappingURL> a owl:DatatypeProperty ;
    rdfs:label "mappingURL"^^xsd:string ;
    dcterms:description "URL to a document defining the mappings of the datamodel. The file format is given by `mappingFormat`. Defaults to turtle."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:anyURI"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#parser> a owl:ObjectProperty ;
    rdfs:label "parser"^^xsd:string ;
    dcterms:description "A parser that can parse the distribution."^^xsd:string ;
    rdfs:domain "dcat:DataService"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "oteio:Parser"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#parserType> a owl:AnnotationProperty ;
    rdfs:label "parserType"^^xsd:string ;
    dcterms:description "Parser type. Ex: `application/vnd.dlite-parse`."^^xsd:string ;
    rdfs:domain "oteio:Parser"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/emmo/domain/oteio#statement> a owl:DatatypeProperty ;
    rdfs:label "statements"^^xsd:string ;
    dcterms:description "A list of subject-predicate-object triples with additional RDF statements documenting the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:JSON"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<https://w3id.org/pink/pink_annotation_schema> a owl:Ontology ;
    ns2:status "Under Development"^^xsd:string ;
    dcterms:abstract "The PINK Annotation Schema provides the semantic basis for SSbD."@en ;
    dcterms:bibliographicCitation "xxx"^^xsd:string ;
    dcterms:contributor <https://orcid.org/0000-0003-4250-4584> ;
    dcterms:created "2025-09-08"^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0001-8869-3718>,
        <https://orcid.org/0000-0002-1560-809X>,
        <https://orcid.org/0000-0002-1849-5246>,
        <https://orcid.org/0000-0002-8053-8198> ;
    dcterms:hasFormat <https://www.w3.org/TR/turtle> ;
    dcterms:issued "xxxx-xx-xx"^^xsd:string ;
    dcterms:license "https://creativecommons.org/licenses/by/4.0/legalcode"^^xsd:string ;
    dcterms:modified "xxxx-xx-xx"^^xsd:string ;
    dcterms:publisher <https://pink-project.eu> ;
    dcterms:title "PINK Annotation Schema"@en ;
    bibo:doi "tbd"^^xsd:string ;
    vann:preferredNamespacePrefix "pink"^^xsd:string ;
    vann:preferredNamespaceUri "https://w3id.org/pink"^^xsd:string ;
    rdfs:comment "This expands on the annotation schema provided by tripper, which again expands on the DCAT-AP."@en ;
    owl:priorVersion "0.0.0"^^xsd:string ;
    owl:versionIRI <https://w3id.org/pink/0.0.1> ;
    owl:versionInfo "0.0.1"^^xsd:string ;
    foaf:homepage <https://github.com/PINK-project/PINK-annotation-schema> ;
    foaf:logo <https://tess.elixir-europe.org/system/content_providers/images/000/000/777/original/pink-logo-orange-colorB-500.png> .

:Computation a owl:Class ;
    dcterms:description "A procedure that deals with quantitative symbols (i.e. symbols associated with a quantitative oriented language)."@en ;
    rdfs:comment "Since Computation is a subclass of Process, we say that there must exist a method that describes the computation."^^xsd:string ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf :Process ;
    skos:prefLabel "Computation"@en .

:ComputationalTool a owl:Class ;
    dcterms:description "A tool that describes how to run a computational model."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf :Method ;
    skos:altLabel "ComputationalMethod"@en ;
    skos:example "Gromacs is a computational tool that solves Newton's equations of motion."@en ;
    skos:prefLabel "ComputationalTool"@en .

:Material a owl:Class ;
    dcterms:description "The class of individuals standing for an amount of matter (ordinary, anti or hybrid) substance (or mixture of substances) in different states of matter or phases."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf prov:Entity ;
    skos:prefLabel "Material"@en .

:MaterialProcess a owl:Class ;
    dcterms:description "A process that has material as input and output."@en ;
    rdfs:comment "Since MaterialProcess is a subclass of Process, we say that there must exist a method that describes the material process."^^xsd:string ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf :Process ;
    skos:prefLabel "MaterialProcess"@en .

:Measurement a owl:Class ;
    dcterms:description "An observation that results in a quantitative comparison of a 'property' of an 'object' with a standard reference based on a well defined mesurement procedure."@en ;
    rdfs:comment "Since Measurement is a subclass of Process, we say that there must exist a method that describes the measurement."^^xsd:string ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf :Process ;
    skos:prefLabel "Measurement"@en .

:Participant a owl:Class ;
    dcterms:description "An object which is a spatial part of a process."@en ;
    vann:usageNote "Example: A student during an examination. The student exists both before and after the examination."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf prov:Agent,
        :Object ;
    skos:prefLabel "Participant"@en .

:ReliabilityDocument a owl:Class ;
    dcterms:description "xxx"@en ;
    vann:usageNote "xxx"@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf foaf:Document ;
    skos:prefLabel "ReliabilityDocument"@en .

:conformance a owl:ObjectProperty ;
    dcterms:description "Whether the annotation is mandatory, recommended or optional as part of the PINK Annotation Schema"@en ;
    vann:usageNote "It MUST take one of the values 'ddoc:mandatory', 'ddoc:recommended' or 'ddoc:optional'."@en ;
    rdfs:isDefinedBy : ;
    rdfs:range ns1:ConformanceLevel ;
    skos:prefLabel "conformance"^^xsd:string .

:documentation a owl:ObjectProperty ;
    dcterms:description "A page or document documenting this resource."^^xsd:string ;
    rdfs:domain dcat:Resource ;
    rdfs:isDefinedBy : ;
    rdfs:range foaf:Document ;
    rdfs:subPropertyOf foaf:page ;
    skos:prefLabel "documentation"@en .

:economic a :SsbdDimension ;
    dcterms:bibliographicCitation "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022"^^xsd:string ;
    dcterms:description "Aspects related to techno-economic feasibility, to operational costs, etc."@en ;
    rdfs:comment """There are important considerations to be made in the context of SSbD
such as the 'availability' of raw materials, as chemicals/materials
cannot be declared SSbD if the raw materials to produce them are not
renewable or are (very) scarce and extracted and processed in an
unsustainable manner. Economic aspects play a role when there is a
need to rank chemicals and materials based on SSbD criteria (even if
they are not SSbD). However, mainly externalities consideration is at
stake in a sustainability framework like the SSbD one."""@en ;
    skos:prefLabel "economic"^^xsd:string .

:environmental_systainability a :SsbdDimension ;
    dcterms:bibliographicCitation "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022"^^xsd:string ;
    dcterms:description "The ability to conserve natural resources and protect global ecosystems to support human health and wellbeing, within the limits of our Planet"@en ;
    rdfs:comment """Assessing environmental sustainability implies to assess the environmental impacts generated by
chemicals/materials along the entire life cycle to move towards:

  · A toxic-free environment as stated in the CSS (i.e. minimising the total toxicity footprint in terms
    of ecotoxicity and human toxicity13 - at each stage of the production and consumption life cycle,
    originated not only by the assessed chemical or material, but also by all the chemicals that are emitted
    along the life cycle14) (EC, 2020a);
  · A climate-neutral economy (i.e. minimising the emission of greenhouse gases along the life cycle)
    (EC, 2019b);
  · A resource efficient economy and a regenerative economy (i.e. using natural resources in a
    sustainable manner, minimising inputs and waste generation, and providing more benefits than
    burdens) (EC, 2020b);
  · The reduction of biodiversity loss and the conservation of ecosystem functioning, addressing the
    main drivers of structural and functional biodiversity loss (e.g. land use, climate change) (EC, 2020c);
"""@en ;
    skos:prefLabel "environmental_systainability"^^xsd:string .

:functionality a :SsbdDimension ;
    dcterms:description "XXX"@en ;
    skos:prefLabel "functionality"^^xsd:string .

:hasAPI a owl:DatatypeProperty ;
    dcterms:description "Whether the method has an API."^^xsd:string ;
    rdfs:domain dcat:Resource ;
    rdfs:isDefinedBy : ;
    rdfs:range xsd:boolean ;
    skos:prefLabel "hasAPI"@en .

:hasDatum a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates a dataset to its datum."@en ;
    rdfs:domain :Dataset ;
    rdfs:isDefinedBy : ;
    rdfs:range :Datum ;
    rdfs:subPropertyOf :hasPart ;
    skos:prefLabel "hasDatum"@en .

:hasJunctionPart a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "The part is connected with the rest item or members with both hasNext (or its inverse) and hasContact relations."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :hasPart ;
    skos:altLabel "hasSpatioTemporalPart"@en ;
    skos:prefLabel "hasJunctionPart"@en .

:hasMethod a owl:ObjectProperty ;
    dcterms:description "Relates an activity to the method that it is described by."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy : ;
    rdfs:range :Method ;
    rdfs:subPropertyOf :participatesTo ;
    skos:prefLabel "hasMethod"@en .

:hasModel a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates a method to the model it implements."@en ;
    rdfs:domain :Method ;
    rdfs:isDefinedBy : ;
    rdfs:range :Model ;
    skos:prefLabel "hasModel"@en .

:hasParticipant a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "The relation between a process and an object participating to it, i.e. that is relevant to the process itself."@en ;
    rdfs:comment "Participation is a parthood relation: you must be part of the process to contribute to it. A participant whose 4D extension is totally contained within the process."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :hasPart ;
    skos:prefLabel "hasParticipant"@en .

:hasProperty a owl:ObjectProperty ;
    dcterms:description "A semiotic relation that connects a semiotic object to a property in a declaration process."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy : ;
    rdfs:range :Property ;
    skos:prefLabel "hasProperty"@en .

:hasSpatialPart a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "A proper part of a whole, whose parts always cover the full temporal extension of the whole within a spatial interval."@en ;
    rdfs:comment "The part is connected with the rest item or members with hasContact relations only (no hasNext)."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :hasPart ;
    skos:prefLabel "hasSpatialPart"@en .

:hasTemporalPart a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "A relation that identify a proper item part of the whole, whose parts always cover the full spatial extension of the whole within a time interval."^^xsd:string ;
    rdfs:comment "A temporal part of an item cannot both cause and be caused by any other proper part of the item."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :hasPart ;
    skos:prefLabel "hasTemporalPart"@en .

:method a owl:ObjectProperty ;
    dcterms:description "Relates a dataset to the method that describes the activity it was created with."^^xsd:string ;
    rdfs:domain dcat:Dataset ;
    rdfs:isDefinedBy : ;
    rdfs:range :Method ;
    rdfs:subPropertyOf :wasDerivedBy ;
    skos:prefLabel "method"@en .

:safety a :SsbdDimension ;
    dcterms:bibliographicCitation "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022"^^xsd:string ;
    dcterms:description "Human helth and environmental safety aspects of chemicals and materials."@en ;
    rdfs:comment """In the context of chemicals assessment, safety could be referring to a
certain condition where a stressor (e.g. a chemical) is unlikely to
cause any adverse effect to a receptor (e.g. humans and other
organisms) (more related to intrinsic hazard properties of the
stressor) or where a receptor is protected from risk (more related to
control measures or mechanisms to minimise exposure to the
stressor). In any case, the term safe involves receptors, and with
that generally also requires the consideration of the contact
(i.e. exposure) between stressors and receptors as addressed in a risk
assessment context."""@en ;
    skos:prefLabel "safety"^^xsd:string .

:social_systainability a :SsbdDimension ;
    dcterms:bibliographicCitation "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022"^^xsd:string ;
    dcterms:description "A globally agreed list of objectives and targets to be pursued for achieving sustainable development."@en ;
    rdfs:comment """In the SDGs framework several Goals focus on social aspects,
e.g. poverty eradication (SDG 1), food security (SDG 2), health (SDG 3),
education (SDG 4), gender equality (SDG 5), decent work (SDG 8),
reduce inequalities (SDG 10), peace and justice (SDG 16)."""@en ;
    skos:prefLabel "social_sustainability"^^xsd:string .

:ssbdDimension a owl:ObjectProperty ;
    dcterms:description "XXX"@en ;
    vann:usageNote "One of `pink:functionality`, `pink:safety`, `pink:environmental_sustainability`, `pink:social_sustainability`"@en ;
    rdfs:isDefinedBy : ;
    rdfs:range :SsbdDimension ;
    skos:prefLabel "ssbdDimension"@en .

:ssbdSubDimension a owl:DatatypeProperty ;
    dcterms:description "XXX"@en ;
    rdfs:isDefinedBy : ;
    rdfs:range xsd:string ;
    skos:prefLabel "ssbdSubDimension"@en .

dcterms:hasPart a owl:ObjectProperty ;
    rdfs:label "hasPart"^^xsd:string ;
    dcterms:description "A related resource that is included either physically or logically in the described resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

rdfs:Resource a owl:Class ;
    dcterms:description "A generic resource defined by RDFS."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

prov:Attribution a owl:Class ;
    dcterms:description "An agent that has some form of responsibility for a resource, but which is not a publisher nor a creator of the resource."^^xsd:string ;
    vann:usageNote "See [explanations and examples in W3C/DCAT](https://www.w3.org/TR/vocab-dcat-3/#qualified-attribution)."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "foaf:Agent"^^xsd:string .

prov:used a owl:ObjectProperty ;
    rdfs:label "used"^^xsd:string ;
    rdfs:comment "A prov:Entity that was used by this prov:Activity. For example, :baking prov:used :spoon, :egg, :oven ."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    owl:propertyChainAxiom ( prov:qualifiedUsage prov:entity ) ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "entities-activities"^^xsd:string ;
    prov:inverse "wasUsedBy"^^xsd:string ;
    prov:qualifiedForm prov:Usage,
        prov:qualifiedUsage .

prov:wasAssociatedWith a owl:ObjectProperty ;
    rdfs:label "wasAssociatedWith"^^xsd:string ;
    rdfs:comment "An prov:Agent that had some (unspecified) responsibility for the occurrence of this prov:Activity."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:range prov:Agent ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    owl:propertyChainAxiom ( prov:qualifiedAssociation prov:agent ) ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "agents-responsibility"^^xsd:string ;
    prov:inverse "wasAssociateFor"^^xsd:string ;
    prov:qualifiedForm prov:Association,
        prov:qualifiedAssociation .

prov:wasAttributedTo a owl:ObjectProperty ;
    rdfs:label "wasAttributedTo"^^xsd:string ;
    rdfs:comment "Attribution is the ascribing of an entity to an agent."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:range prov:Agent ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    owl:propertyChainAxiom ( prov:qualifiedAttribution prov:agent ) ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "agents-responsibility"^^xsd:string ;
    prov:definition "Attribution is the ascribing of an entity to an agent."@en ;
    prov:inverse "contributed"^^xsd:string ;
    prov:qualifiedForm prov:Attribution,
        prov:qualifiedAttribution .

prov:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:label "wasGeneratedBy"^^xsd:string ;
    dcterms:description "An activity that generated, or provides the business context for, the creation of the dataset."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "prov:Activity"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

prov:wasInformedBy a owl:ObjectProperty ;
    rdfs:label "wasInformedBy"^^xsd:string ;
    rdfs:comment "An activity a2 is dependent on or informed by another activity a1, by way of some unspecified entity that is generated by a1 and used by a2."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:range prov:Activity ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    owl:propertyChainAxiom ( prov:qualifiedCommunication prov:activity ) ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "entities-activities"^^xsd:string ;
    prov:inverse "informed"^^xsd:string ;
    prov:qualifiedForm prov:Communication,
        prov:qualifiedCommunication .

foaf:Agent a owl:Class ;
    dcterms:description "An agent (eg. person, group, software or physical artifact)."^^xsd:string ;
    vann:usageNote "A resource that acts or has the power to act."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "dcterms:Agent"^^xsd:string,
        "emmo:EMMO_2480b72b_db8d_460f_9a5f_c2912f979046"^^xsd:string .

foaf:page a owl:ObjectProperty ;
    rdfs:label "documentation"^^xsd:string ;
    dcterms:description "A page or document about this resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "foaf:Document"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

<https://orcid.org/0000-0001-8869-3718> a foaf:Person ;
    skos:prefLabel "FrancescaLonstadBleken"^^xsd:string ;
    foaf:name "Francesca Lønstad Bleken"^^xsd:string ;
    foaf:workplaceHomepage <https://www.sintef.no/en> .

<https://orcid.org/0000-0002-1560-809X> a foaf:Person ;
    skos:prefLabel "JesperFriis"^^xsd:string ;
    foaf:name "Jesper Friis"^^xsd:string ;
    foaf:workplaceHomepage <https://www.sintef.no/en> .

<https://orcid.org/0000-0002-1849-5246> a foaf:Person ;
