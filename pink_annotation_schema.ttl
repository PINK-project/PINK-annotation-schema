    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Distribution"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

<http://www.w3.org/ns/adms#versionNotes> a owl:AnnotationProperty ;
    rdfs:label "versionNotes"^^xsd:string ;
    dcterms:description "A description of the differences between this version and a previous version of the resource."^^xsd:string ;
    vann:usageNote "This property can be repeated for parallel language versions of the version notes."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:DataService a owl:Class ;
    dcterms:description "A collection of operations that provides access to one or more datasets or data processing functions."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "rdfs:Resource"^^xsd:string .

dcat:DatasetSeries a owl:Class ;
    dcterms:description "A collection of datasets that are published separately, but share some characteristics that group them."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "dcat:Dataset"^^xsd:string .

dcat:Distribution a owl:Class ;
    dcterms:description "A physical embodiment of the Dataset in a particular format."^^xsd:string ;
    vann:usageNote "This represents a general availability of a dataset. It implies no information about the actual access method of the data, i.e., whether by direct download, API, or through a Web page. The use of dcat:downloadURL property indicates directly downloadable distributions."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "dcat:Resource"^^xsd:string .

dcat:Relationship a owl:Class ;
    dcterms:description "An association class for attaching additional information to a relationship between DCAT Resources."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

dcat:accessService a owl:ObjectProperty ;
    rdfs:label "accessService"^^xsd:string ;
    dcterms:description "A data service that gives access to the distribution of the dataset."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:DataService"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:accessURL a owl:ObjectProperty ;
    rdfs:label "accessURL"^^xsd:string ;
    dcterms:description "A URL that gives access to a Distribution of the Dataset. E.g. landing page, feed, SPARQL endpoint. Use for all cases except a simple download link, in which case downloadURL is preferred."^^xsd:string ;
    vann:usageNote "The resource at the access URL may contain information about how to get the Dataset."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:mandatory"^^xsd:string .

dcat:bbox a owl:AnnotationProperty ;
    rdfs:label "bbox"^^xsd:string ;
    dcterms:description "The geographic bounding box of a resource."^^xsd:string ;
    rdfs:domain "dcterms:Location"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:byteSize a owl:DatatypeProperty ;
    rdfs:label "byteSize"^^xsd:string ;
    dcterms:description "The size of a Distribution in bytes."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:nonNegativeInteger"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:centroid a owl:AnnotationProperty ;
    rdfs:label "centroid"^^xsd:string ;
    dcterms:description "The geographic center (centroid) of a resource."^^xsd:string ;
    rdfs:domain "dcterms:Location"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:compressFormat a owl:ObjectProperty ;
    rdfs:label "compressFormat"^^xsd:string ;
    dcterms:description "The format of the file in which the data is contained in a compressed form, e.g. to reduce the size of the downloadable file."^^xsd:string ;
    vann:usageNote "It SHOULD be expressed using a media type as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types)."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:MediaType"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:contactPoint a owl:ObjectProperty ;
    rdfs:label "contactPoint"^^xsd:string ;
    dcterms:description "Contact information that can be used for sending comments about the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "vcard:Kind"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:distribution a owl:ObjectProperty ;
    rdfs:label "distribution"^^xsd:string ;
    dcterms:description "An available distribution for the dataset."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Distribution"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:downloadURL a owl:DatatypeProperty ;
    rdfs:label "downloadURL"^^xsd:string ;
    dcterms:description "A URL that is a direct link to a downloadable file in a given format. The format is indicated by the distribution's 'dterms:format' and/or 'dcat:mediaType'."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:anyURI"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:endpointDescription a owl:ObjectProperty ;
    rdfs:label "endpointDescription"^^xsd:string ;
    dcterms:description "A description of the services available via the end-points, including their operations, parameters etc."^^xsd:string ;
    rdfs:domain "dcat:DataService"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:endpointURL a owl:DatatypeProperty ;
    rdfs:label "endpointURL"^^xsd:string ;
    dcterms:description "The root location or primary endpoint of the service (an IRI)."^^xsd:string ;
    rdfs:domain "dcat:DataService"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:anyURI"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:mandatory"^^xsd:string .

dcat:hasRole a owl:ObjectProperty ;
    rdfs:label "hasRole"^^xsd:string ;
    dcterms:description "A function of an entity or agent with respect to another entity or resource."^^xsd:string ;
    rdfs:domain "dcat:Relationship"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Role"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

dcat:hasVersion a owl:ObjectProperty ;
    rdfs:label "hasVersion"^^xsd:string ;
    dcterms:description "A related resource that is a version, edition, or adaptation of the described resource."^^xsd:string ;
    vann:usageNote "This property is intended for relating a non-versioned or abstract resource to several versioned resources, e.g., snapshots."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:inSeries a owl:ObjectProperty ;
    rdfs:label "inSeries"^^xsd:string ;
    dcterms:description "A dataset series of which the dataset is part."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:DatasetSeries"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:keyword a owl:AnnotationProperty ;
    rdfs:label "keyword"^^xsd:string ;
    dcterms:description "A keyword or tag describing the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:landingPage a owl:ObjectProperty ;
    rdfs:label "landingPage"^^xsd:string ;
    dcterms:description "A web page that provides access to the resource and/or additional information (e.g. the distribution for a dataset)."^^xsd:string ;
    vann:usageNote """It is intended to point to a landing page at the original
data provider, not to a page on a site of a third party,
such as an aggregator.

For distributions, if they are accessible only through a
landing page (i.e. direct download URLs are not known), then
the landing page link should be duplicated as accessURL on a
distribution.
"""^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "foaf:Document"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:mediaType a owl:ObjectProperty ;
    rdfs:label "mediaType"^^xsd:string ;
    dcterms:description "The media type of the Distribution as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types)."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:MediaType"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:packageFormat a owl:ObjectProperty ;
    rdfs:label "packageFormat"^^xsd:string ;
    dcterms:description "The format of the file in which one or more data files are grouped together, e.g. to enable a set of related files to be downloaded together."^^xsd:string ;
    vann:usageNote "It SHOULD be expressed using a media type as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) and prefixed with `https://www.iana.org/assignments/media-types/`."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:MediaType"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:qualifiedRelation a owl:ObjectProperty ;
    rdfs:label "qualifiedRelation"^^xsd:string ;
    dcterms:description "A description of a relationship with another resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Relationship"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:servesDataset a owl:ObjectProperty ;
    rdfs:label "servesDataset"^^xsd:string ;
    dcterms:description "This property refers to a collection of data that this data service can distribute."^^xsd:string ;
    rdfs:domain "dcat:DataService"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Dataset"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:spatialResolutionInMeters a owl:DatatypeProperty ;
    rdfs:label "spatialResolution"^^xsd:string ;
    dcterms:description "The minimum spatial separation resolvable in a dataset, measured in meters."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:decimal"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:temporalResolution a owl:DatatypeProperty ;
    rdfs:label "temporalResolution"^^xsd:string ;
    dcterms:description "The minimum time period resolvable in the dataset."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:duration"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcat:theme a owl:ObjectProperty ;
    rdfs:label "theme"^^xsd:string ;
    dcterms:description "A category of the resource.  A resource may be associated with multiple themes."^^xsd:string ;
    vann:usageNote "The set of themes used to categorize the resources are organized in a skos:ConceptScheme, skos:Collection, owl:Ontology or similar, describing all the categories and their relations in the catalog."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "skos:Concept"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcat:version a owl:AnnotationProperty ;
    rdfs:label "version"^^xsd:string ;
    dcterms:description "Version indicator (name or identifier) of a resource."^^xsd:string ;
    vann:usageNote "DCAT does not prescribe how a version name / identifier should be specified, and refers for guidance to [DWBP]'s Best Practice 7: Provide a version indicator."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

locn:Geometry a owl:Class ;
    dcterms:description "The locn:Geometry class provides the means to identify a location as a point, line, polygon, etc. expressed using coordinates in some coordinate reference system."^^xsd:string ;
    vann:usageNote "This specification does not impose any additional requirements to properties for this entity."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

locn:geometry a owl:ObjectProperty ;
    rdfs:label "geometry"^^xsd:string ;
    dcterms:description "The geographic center (centroid) of a resource."^^xsd:string ;
    rdfs:domain "dcterms:Location"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "locn:Geometry"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

prov:category a owl:AnnotationProperty ;
    rdfs:comment "Classify prov-o terms into three categories, including 'starting-point', 'qualifed', and 'extended'. This classification is used by the prov-o html document to gently introduce prov-o terms to its users. "@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> .

prov:component a owl:AnnotationProperty ;
    rdfs:comment "Classify prov-o terms into six components according to prov-dm, including 'agents-responsibility', 'alternate', 'annotations', 'collections', 'derivations', and 'entities-activities'. This classification is used so that readers of prov-o specification can find its correspondence with the prov-dm specification."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> .

prov:constraints a owl:AnnotationProperty ;
    rdfs:comment "A reference to the principal section of the PROV-CONSTRAINTS document that describes this concept."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:subPropertyOf rdfs:seeAlso .

prov:definition a owl:AnnotationProperty ;
    rdfs:comment "A definition quoted from PROV-DM or PROV-CONSTRAINTS that describes the concept expressed with this OWL term."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> .

prov:dm a owl:AnnotationProperty ;
    rdfs:comment "A reference to the principal section of the PROV-DM document that describes this concept."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:subPropertyOf rdfs:seeAlso .

prov:n a owl:AnnotationProperty ;
    rdfs:comment "A reference to the principal section of the PROV-DM document that describes this concept."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:subPropertyOf rdfs:seeAlso .

prov:wasDerivedFrom a owl:ObjectProperty ;
    rdfs:label "wasDerivedFrom"^^xsd:string ;
    dcterms:description "A derivation is a transformation of an entity into another, an update of an entity resulting in a new one, or the construction of a new entity based on a pre-existing entity."^^xsd:string ;
    vann:usageNote "Relates a resource to another resource it was derived from."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

foaf:homepage a owl:AnnotationProperty ;
    rdfs:isDefinedBy : .

foaf:logo a owl:AnnotationProperty ;
    rdfs:isDefinedBy : .

foaf:name a owl:DatatypeProperty ;
