    dcterms:description "A name of the agent."^^xsd:string ;
    rdfs:domain "foaf:Agent"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:string"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:mandatory"^^xsd:string .

<https://w3id.org/emmo#EMMO_1494c1a9_00e1_40c2_a9cc_9bbf302a1cac> a owl:ObjectProperty ;
    rdfs:label "isInputOf"^^xsd:string ;
    dcterms:description "A process that this dataset is the input to."^^xsd:string ;
