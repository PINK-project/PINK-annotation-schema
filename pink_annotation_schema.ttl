@prefix : <https://w3id.org/pink/pink_annotation_schema#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix ns1: <https://w3id.org/emmo/application/datadoc#> .
@prefix ns2: <http://data.europa.eu/r5r/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://data.europa.eu/eli/ontology#LegalResource> a owl:Class ;
    dcterms:description "This class represents the legislation, policy or policies that lie behind the Rules that govern the service."^^xsd:string ;
    vann:usageNote "The definition and properties of the Legal Resource class are aligned with the ontology included in \"Council conclusions inviting the introduction of the European Legislation Identifier (ELI)\". For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the (ELI) ontology. In this data specification the use is restricted to instances of this class that follow the (ELI) URI guidelines."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

ns2:applicableLegislation a owl:ObjectProperty ;
    rdfs:label "applicableLegislation"^^xsd:string ;
    dcterms:description "The legislation that mandates the creation or management of the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "eli:LegalResource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

ns2:availability a owl:DatatypeProperty ;
    rdfs:label "availability"^^xsd:string ;
    dcterms:description "An indication how long it is planned to keep the Distribution of the Dataset available."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:date"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

ns2:status a owl:ObjectProperty ;
    rdfs:label "status"^^xsd:string ;
    dcterms:description "The status of the distribution in the context of maturity lifecycle."^^xsd:string ;
    vann:usageNote "It MUST take one of the values: 'stat:Completed', 'stat:Deprecated', 'stat:UnderDevelopment', 'stat:Withdrawn'."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "skos:Concept"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

<http://publications.europa.eu/resource/authority/access-right/CONFIDENTIAL> a dcterms:RightsStatement ;
    vann:usageNote "Disclosure of this data could cause damage to interested parties such as public administrations and businesses. It may refer to personal and professional information as well as to information in the context of business, commerce or trade."@en ;
    rdfs:isDefinedBy <https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://publications.europa.eu/resource/authority/access-right> ;
    skos:definition "Information that is not disclosed."@en ;
    skos:prefLabel "confidential"@en .

<http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC> a dcterms:RightsStatement ;
    vann:usageNote "This category may include resources that contain sensitive or personal information."@en ;
    rdfs:isDefinedBy <https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://publications.europa.eu/resource/authority/access-right> ;
    skos:definition "Not publicly accessible for privacy, security or other reasons."@en ;
    skos:prefLabel "non-public"@en .

<http://publications.europa.eu/resource/authority/access-right/PUBLIC> a dcterms:RightsStatement ;
    vann:usageNote "Permissible obstacles include registration and request for API keys, as long as anyone can request such registration and/or API keys."@en ;
    rdfs:isDefinedBy <https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://publications.europa.eu/resource/authority/access-right> ;
    skos:definition "Publicly accessible by everyone."@en ;
    skos:prefLabel "public"@en .

<http://publications.europa.eu/resource/authority/access-right/RESTRICTED> a dcterms:RightsStatement ;
    vann:usageNote "This category may include resources that require payment, resources shared under non-disclosure agreements, resources for which the publisher or owner has not yet decided if they can be publicly released."@en ;
    rdfs:isDefinedBy <https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://publications.europa.eu/resource/authority/access-right> ;
    skos:definition "Only available under certain conditions."@en ;
    skos:prefLabel "restricted"@en .

<http://publications.europa.eu/resource/authority/access-right/SENSITIVE> a dcterms:RightsStatement ;
    rdfs:isDefinedBy <https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://publications.europa.eu/resource/authority/access-right> ;
    skos:definition "Sensitive non-classified (SNC) information, information whose unauthorised disclosure could cause damage to the Commission or other interested parties such as businesses, companies, intellectual property or personal data but which is not EU classified information."@en ;
    skos:prefLabel "sensitive"@en .

<http://purl.org/adms/status/Completed> a skos:Concept ;
    skos:inScheme <http://purl.org/adms/status/1.0> ;
    skos:notation "Completed"^^xsd:string ;
    skos:prefLabel "Completed"@en .

<http://purl.org/adms/status/Deprecated> a skos:Concept ;
    skos:inScheme <http://purl.org/adms/status/1.0> ;
    skos:notation "Deprecated"^^xsd:string ;
    skos:prefLabel "Deprecated"@en .

<http://purl.org/adms/status/UnderDevelopment> a skos:Concept ;
    skos:inScheme <http://purl.org/adms/status/1.0> ;
    skos:notation "UnderDevelopment"^^xsd:string ;
    skos:prefLabel "UnderDevelopment"@en .

<http://purl.org/adms/status/Withdrawn> a skos:Concept ;
    skos:inScheme <http://purl.org/adms/status/1.0> ;
    skos:notation "Withdrawn"^^xsd:string ;
    skos:prefLabel "Withdrawn"@en .

dcterms:LicenseDocument a owl:Class ;
    dcterms:description "A legal document giving official permission to do something with a resource."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

dcterms:Location a owl:Class ;
    dcterms:description "A spatial region or named place."^^xsd:string ;
    vann:usageNote "It can be represented using a controlled vocabulary or with geographic coordinates. In the latter case, the use of the Core Location Vocabulary is recommended, following the approach described in the GeoDCAT-AP specification."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

dcterms:MediaType a owl:Class ;
    dcterms:description "A media type, e.g. the format of a computer file."^^xsd:string ;
    vann:usageNote "Media type instances follow the [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) vocabulary using the <http://www.iana.org/assignments/media-types/> namespace. For example, the IRI of the media type `text/turtle` is <http://www.iana.org/assignments/media-types/text/turtle>."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

dcterms:Standard a owl:Class ;
    dcterms:description "A standard or other specification to which a resource conforms."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

dcterms:abstract a owl:AnnotationProperty ;
    rdfs:label "abstract"^^xsd:string ;
    dcterms:description "A summary of the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

dcterms:accessRights a owl:ObjectProperty ;
    rdfs:label "accessRights"^^xsd:string ;
    dcterms:description "Information about who can access the resource or an indication of its security status."^^xsd:string ;
    vann:usageNote "Access Rights may include information regarding access or restrictions based on privacy, security, or other policies. The following preferred Rights Statement individuals are defined: `accr:PUBLIC`, `accr:NON_PUBLIC`, `accr:CONFIDENTIAL`, `accr:RESTRICTED`, `accr:SENSITIVE`"^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:RightsStatement"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:accrualPeriodicity a owl:ObjectProperty ;
    rdfs:label "frequency"^^xsd:string ;
    dcterms:description "The frequency at which the Dataset is updated."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:Frequency"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:bibliographicCitation a owl:AnnotationProperty ;
    rdfs:label "bibliographicCitation"^^xsd:string ;
    dcterms:description "A bibliographic reference for the resource."^^xsd:string ;
    vann:usageNote "Recommended practice is to include sufficient bibliographic detail to identify the resource as unambiguously as possible."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

dcterms:conformsTo a owl:ObjectProperty ;
    rdfs:label "conformsTo"^^xsd:string ;
    dcterms:description "An implementing rule or other specification."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:Standard"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:contributor a owl:ObjectProperty ;
    rdfs:label "contributor"^^xsd:string ;
    dcterms:description "An entity responsible for making contributions to the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "foaf:Agent"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:creator a owl:ObjectProperty ;
    rdfs:label "creator"^^xsd:string ;
    dcterms:description "An entity responsible for producing the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "foaf:Agent"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:description a owl:AnnotationProperty ;
    rdfs:label "description"^^xsd:string ;
    dcterms:description "A free-text account of the resource."^^xsd:string ;
    vann:usageNote "This property can be repeated for parallel language versions of the description."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:mandatory"^^xsd:string .

dcterms:format a owl:ObjectProperty ;
    rdfs:label "format"^^xsd:string ;
    dcterms:description "The file format of the Distribution."^^xsd:string ;
    vann:usageNote "dcat:mediaType SHOULD be used if the type of the distribution is defined by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types)."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:MediaTypeOrExtent"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:identifier a owl:AnnotationProperty ;
    rdfs:label "identifier"^^xsd:string ;
    dcterms:description "URI or other unique identifier of the resource being described."^^xsd:string ;
    vann:usageNote "Recommended practice is to identify the resource by means of a string conforming to an identification system. Examples include International Standard Book Number (ISBN), Digital Object Identifier (DOI), and Uniform Resource Name (URN).  Persistent identifiers should be provided as HTTP URIs."^^xsd:string ;
    rdfs:domain "foaf:Agent"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:isReferencedBy a owl:ObjectProperty ;
    rdfs:label "isReferencedBy"^^xsd:string ;
    dcterms:description "A related resource, such as a publication, that references, cites, or otherwise points to the documented resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:issued a owl:DatatypeProperty ;
    rdfs:label "releaseDate"^^xsd:string ;
    dcterms:description "The date of formal issuance (e.g., publication) of the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:date"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:language a owl:DatatypeProperty ;
    rdfs:label "language"^^xsd:string ;
    dcterms:description "A language of the resource."^^xsd:string ;
    vann:usageNote """Recommended practice is to use either a non-literal value
representing a language from a controlled vocabulary such as
ISO 639-2 or ISO 639-3, or a literal value consisting of an
IETF Best Current Practice 47
[[IETF-BCP47](https://tools.ietf.org/html/bcp47)] language
tag.

Example values: "en", "it", "no", "da"

This property can be repeated if the resource is expressed
with multiple languages.
"""^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:string"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:license a owl:ObjectProperty ;
    rdfs:label "license"^^xsd:string ;
    dcterms:description "A licence under which the resource is made available."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:LicenseDocument"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:modified a owl:DatatypeProperty ;
    rdfs:label "modificationDate"^^xsd:string ;
    dcterms:description "The most recent date on which the resource was changed or modified."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:date"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:publisher a owl:ObjectProperty ;
    rdfs:label "publisher"^^xsd:string ;
    dcterms:description "Agent responsible for making the resource available."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "foaf:Agent"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcterms:relation a owl:ObjectProperty ;
    rdfs:label "relatedResource"^^xsd:string ;
    dcterms:description "A resource with an unspecified relationship to the cataloged resource."^^xsd:string ;
    rdfs:domain "dcat:Relationship"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:source a owl:ObjectProperty ;
    rdfs:label "source"^^xsd:string ;
    dcterms:description "A related Dataset from which the described Dataset is derived."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcat:Dataset"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

dcterms:spatial a owl:ObjectProperty ;
    rdfs:label "geographicalCoverage"^^xsd:string ;
    dcterms:description "A geographic region that is covered by the dataset."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:Location"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcterms:temporal a owl:ObjectProperty ;
    rdfs:label "temporalCoverage"^^xsd:string ;
    dcterms:description "A temporal period that the Dataset covers."^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "dcterms:PeriodOfTime"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:recommended"^^xsd:string .

dcterms:title a owl:AnnotationProperty ;
    rdfs:label "title"^^xsd:string ;
    dcterms:description "A name given to the resource."^^xsd:string ;
    vann:usageNote "This property can be repeated for parallel language versions of the name."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:mandatory"^^xsd:string .

dcterms:type a owl:ObjectProperty ;
    rdfs:label "type"^^xsd:string ;
    dcterms:description "A type of the resource."^^xsd:string ;
    vann:usageNote "A recommended controlled vocabulary data-type is foreseen. For agents, the value should be chosen from [ADMS publisher type](https://raw.githubusercontent.com/SEMICeu/ADMS-AP/master/purl.org/ADMS_SKOS_v1.00.rdf)."^^xsd:string ;
    rdfs:domain "dcterms:LicenseDocument"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "skos:Concept"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

bibo:doi a owl:AnnotationProperty ;
    rdfs:isDefinedBy : .

vann:preferredNamespacePrefix a owl:AnnotationProperty ;
    rdfs:isDefinedBy : .

vann:preferredNamespaceUri a owl:AnnotationProperty ;
    rdfs:isDefinedBy : .

vann:usageNote a owl:AnnotationProperty ;
    rdfs:label "usageNote"^^xsd:string ;
    dcterms:description "A reference that provides information on how this resource is to be used."^^xsd:string ;
    rdfs:domain "rdfs:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdf:langString"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<http://spdx.org/rdf/terms#Checksum> a owl:Class ;
    dcterms:description "A preferred label of the concept."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

<http://spdx.org/rdf/terms#ChecksumAlgorithm> a owl:Class ;
    dcterms:description "Algorithm for Checksums."^^xsd:string ;
    vann:usageNote "This specification does not impose any additional requirements to properties for this entity."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

<http://spdx.org/rdf/terms#algorithm> a owl:ObjectProperty ;
    rdfs:label "algorithm"^^xsd:string ;
    dcterms:description "The algorithm used to produce the subject Checksum."^^xsd:string ;
    rdfs:domain "spdx:Checksum"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "spdx:ChecksumAlgorithm"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

<http://spdx.org/rdf/terms#checksum> a owl:ObjectProperty ;
    rdfs:label "checksum"^^xsd:string ;
    dcterms:description "A mechanism that can be used to verify that the contents of a distribution have not changed."^^xsd:string ;
    vann:usageNote "The checksum is related to the downloadURL."^^xsd:string ;
    rdfs:domain "dcat:Distribution"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "spdx:Checksum"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

<http://spdx.org/rdf/terms#checksumValue> a owl:DatatypeProperty ;
    rdfs:label "checksumValue"^^xsd:string ;
    dcterms:description "A lower case hexadecimal encoded digest value produced using a specific algorithm."^^xsd:string ;
    rdfs:domain "spdx:Checksum"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "xsd:hexBinary"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

rdfs:comment a owl:AnnotationProperty ;
    rdfs:label "comment"^^xsd:string ;
    dcterms:description "A description of the subject resource. Use `description` instead."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy rdfs: ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

rdfs:domain a owl:ObjectProperty ;
    rdfs:label "domain"^^xsd:string ;
    dcterms:description "A domain of the subject property."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

rdfs:isDefinedBy a owl:ObjectProperty ;
    rdfs:label "isDefinedBy"^^xsd:string ;
    dcterms:description "Indicate a resource defining the subject resource. This property may be used to indicate an RDF vocabulary in which a resource is described."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy rdfs: ;
    rdfs:range "skos:Concept"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

rdfs:label a owl:AnnotationProperty ;
    rdfs:label "label"^^xsd:string ;
    dcterms:description "Provides a human-readable version of a resource's name."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy rdfs: ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

rdfs:range a owl:ObjectProperty ;
    rdfs:label "range"^^xsd:string ;
    dcterms:description "A range of the subject property."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Resource"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

rdfs:subClassOf a owl:ObjectProperty ;
    rdfs:label "subClassOf"^^xsd:string ;
    dcterms:description "The subject is a subclass of a class."^^xsd:string ;
    rdfs:domain "rdfs:Class"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "rdfs:Class"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

owl:deprecated a owl:DatatypeProperty ;
    rdfs:label "deprecated"^^xsd:string ;
    dcterms:description "The annotation property that indicates that a given entity has been deprecated. It should equal to `\"true\"^^xsd:boolean`."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy owl: ;
    rdfs:range "xsd:boolean"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

owl:maxQualifiedCardinality a owl:DatatypeProperty ;
    rdfs:label "maxQualifiedCardinality"^^xsd:string ;
    dcterms:description "The property that determines the cardinality of a maximum qualified cardinality restriction."^^xsd:string ;
