    dcterms:description "A secondary identifier of the Dataset"^^xsd:string ;
    rdfs:domain "dcat:Dataset"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "adms:Identifier"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

<http://www.w3.org/ns/adms#sample> a owl:ObjectProperty ;
    rdfs:label "sample"^^xsd:string ;
    dcterms:description "A sample distribution of the dataset."^^xsd:string ;
