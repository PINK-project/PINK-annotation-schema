[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#y> ;
