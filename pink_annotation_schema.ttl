    foaf:workplaceHomepage <https://www.birmingham.ac.uk> .

ns1:mandatory a owl:NamedIndividual,
        ns1:ConformanceLevel ;
    rdfs:label "mandatory"@en ;
    rdfs:isDefinedBy : ;
    skos:prefLabel "mandatory"@en .

ns1:optional a owl:NamedIndividual,
        ns1:ConformanceLevel ;
    rdfs:label "optional"@en ;
    rdfs:isDefinedBy : ;
    skos:prefLabel "optional"@en .

ns1:recommended a owl:NamedIndividual,
        ns1:ConformanceLevel ;
    rdfs:label "recommended"@en ;
    rdfs:isDefinedBy : ;
    skos:prefLabel "recommended"@en .

:Dataset a owl:Class ;
    dcterms:description "Encoded data made of more than one datum."@en ;
    vann:usageNote "A collection of (more than one) datum, published or curated by a single agent, and available for access or download in one or more representations."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasPart ;
            owl:someValuesFrom :Datum ],
        dcat:Dataset,
        :Data ;
    skos:prefLabel "Dataset"@en .

:Model a owl:Class ;
    dcterms:description "A useful simplified description of a selected part of the world."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf prov:Entity ;
    skos:example """Newton's law of motion is a model for how a body will move when subjected to forces.
A mouse can be seen as a model for a human (e.g. in medicine).
An architectural floor plan is a model of a house.
"""@en ;
    skos:prefLabel "Model"@en .

:Object a owl:Class ;
    dcterms:description "The class of all individuals who's temporal parts are of the same type as the whole."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf prov:Entity ;
    skos:prefLabel "Object"@en .

:Property a owl:Class ;
    dcterms:description "A coventional semiotic sigh that stands for an physical interaction with an object using an atomic symbol."@en ;
    vann:usageNote "A property is atomic in the sense that is aimed to deliver one and one only aspect of the object."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf prov:Entity ;
    skos:prefLabel "Property"@en .

:Role a owl:Class ;
    dcterms:description "The class of all individuals that are defined through a parthood relation to an entity."@en ;
    vann:usageNote "An individual can be said to have a role in relation to the entity."@en ;
    rdfs:isDefinedBy <https://w3id.org/pink/reused-terms#> ;
    skos:prefLabel "Role"@en .

:input a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates a method to an entity via a process that used the entity and that the method participates to."@en ;
    rdfs:comment "The process P is through overlapped by the agent A and overcrossed by the entity E, where the non-overlapping part of E causes P."@en ;
    rdfs:domain :Method ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf :attributed ;
    skos:prefLabel "input"@en .

:nonOverlaps a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    dcterms:description "The relation between two individuals that does not share any parts."@en ;
    rdfs:isDefinedBy : ;
    owl:propertyDisjointWith :overlaps ;
    skos:prefLabel "nonOverlaps"@en .

:output a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates a method to an entity via a process that was generated by the entity and that the method participates to."@en ;
    rdfs:comment "The process P is through overlapped by the agent A and overcrossed by the entity E, where the non-overlapping part of E is caused by P."@en ;
    rdfs:domain :Method ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf :attributed ;
    skos:prefLabel "output"@en .

:wasInformedBy a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "A one-directional relation between an activity that affects the subject activity."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Activity ;
    rdfs:subPropertyOf prov:wasInformedBy,
        :isAfter ;
    skos:prefLabel "wasInformedBy"@en .

owl:Restriction a owl:Class ;
    dcterms:description "The class of property restrictions."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

dcat:Dataset a owl:Class ;
    dcterms:description "A collection of data, published or curated by an agent, and available for access or download in one or more representations."^^xsd:string ;
    vann:usageNote "This class represents the actual dataset as published by the dataset provider. In cases where a distinction between the actual dataset and its entry in the catalog is necessary (because metadata such as modification date and maintainer might differ), the catalog record class can be used for the latter."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "dcat:Resource"^^xsd:string,
        "emmo:EMMO_194e367c_9783_4bf5_96d0_9ad597d48d9a"^^xsd:string .

prov:qualifiedAttribution a owl:ObjectProperty ;
    rdfs:label "qualifiedAttribution"^^xsd:string ;
    dcterms:description "An Agent having some form of responsibility for the resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:range "prov:Attribution"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string ;
    ns1:conformance "ddoc:optional"^^xsd:string .

foaf:Document a owl:Class ;
    dcterms:description "A document."^^xsd:string ;
    vann:usageNote "The Document class represents those things which are, broadly conceived, 'documents'. E.g. images."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        :Data .

:Datum a owl:Class ;
    dcterms:description "A self-consistent encoded data entity."@en ;
    vann:usageNote "Datum is the building block of datasets."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf :Data ;
    skos:prefLabel "Datum"@en .

:isAfter a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "A one-directional relation between an entity that affects the subject."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :causedBy ;
    skos:prefLabel "isAfter"@en .

:participatesTo a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relation an entity to an activity that it interacts with."@en ;
    rdfs:comment "The entity through overlaps the activity."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Activity ;
    rdfs:subPropertyOf :isOvercrossedBy ;
    skos:prefLabel "participatesTo"@en .

:processedFrom a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Indirect relation that relates the output of an activity to its input."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :isAfter ;
    skos:prefLabel "processedFrom"@en .

:wasAssociatedWith a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates an activity to an agent that had some (unspecified) responsibility for the occurence of this activity."@en ;
    rdfs:comment "The activity is through overlapped by the agent."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Agent ;
    rdfs:subPropertyOf prov:wasAssociatedWith,
        :isOvercrossedBy ;
    skos:prefLabel "wasAssociatedWith"@en .

:wasAttributedTo a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates an entity to an agent via an activity that both the entity and agent participates to."@en ;
    rdfs:comment "The activity is through overlapped by the agent and overcrossed by the entity."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Agent ;
    rdfs:subPropertyOf prov:wasAttributedTo,
        :causedBy ;
    owl:inverseOf :attributed ;
    skos:prefLabel "wasAttributedTo"@en .

:wasDerivedBy a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Indirect relation that relates the output entity of an activity to its input entity."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf prov:wasDerivedBy,
        :processedFrom ;
    skos:prefLabel "wasDerivedBy"@en .

rdfs:seeAlso a owl:ObjectProperty ;
    rdfs:label "seeAlso"^^xsd:string ;
    dcterms:description "Indicates a resource that might provide additional information about the subject resource."^^xsd:string ;
    rdfs:domain "dcat:Resource"^^xsd:string ;
    rdfs:isDefinedBy rdfs: ;
    rdfs:range "skos:Concept"^^xsd:string ;
    dcat:theme "ddoc:datadoc"^^xsd:string .

:causedBy a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "A relation between an entity that causally affects the subject."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    skos:example "John yesterday is the cause of John today, is an example of temporal-like causality. The desk supporting my laptop is a space-like causality."@en ;
    skos:prefLabel "causedBy"@en .

:hasProcess a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates a method to the process that it describes."@en ;
    rdfs:comment "The starting point for this relation is that it relates a method to an activity it describes. However, when an activity is described by a method is a process. Therefor is the range of this relation a process and not only an activity."@en,
        "This is a subproperty of participatesTo, meaning that the process is overcrossed by the method."@en ;
    rdfs:domain :Method ;
    rdfs:isDefinedBy : ;
    rdfs:range :Process ;
    rdfs:subPropertyOf :participatesTo ;
    skos:prefLabel "hasProcess"@en .

:overlaps a owl:ObjectProperty,
        owl:ReflexiveProperty,
        owl:SymmetricProperty ;
    dcterms:description "The relation between two individuals representing entities that share at least one of their parts."@en ;
    rdfs:isDefinedBy : ;
    owl:propertyDisjointWith :nonOverlaps ;
    skos:prefLabel "overlaps"@en .

dcat:Resource a owl:Class ;
    dcterms:description "Resource published or curated by an agent."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "rdfs:Resource"^^xsd:string .

:Data a owl:Class ;
    dcterms:description "Contrast from variation of properties that is encoded by an agent and that can be decoded by another agent according to a specific rule."@en ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf prov:Entity ;
    skos:prefLabel "Data"@en .

:Process a owl:Class ;
    dcterms:description "An activity that is described by a method."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf :hasProcess ] ;
            owl:someValuesFrom :Method ],
        prov:Activity ;
    skos:prefLabel "Process"@en .

:attributed a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates an agent to an entity via an activity that both the agent and entity participates to."@en ;
    rdfs:comment "The activity is through overlapped by the agent and overcrossed by the entity."@en,
        "There may or may not be a causal interaction between the agent and entity."@en ;
    rdfs:domain prov:Agent ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf :causedBy ;
    owl:inverseOf :wasAttributedTo ;
    skos:prefLabel "attributed"@en .

:isOvercrossedBy a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "The relation between an entity that overlaps another without having it as part."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf :overlaps ;
    owl:propertyDisjointWith :hasPart ;
    skos:prefLabel "isOvercrossedBy"@en .

dcterms:RightsStatement a owl:Class ;
    dcterms:description "A statement about the intellectual property rights (IPR) held in or over a resource, a legal document giving official permission to do something with a resource, or a statement about access rights."^^xsd:string ;
    vann:usageNote "EU pre-defines the following individuals: accr:PUBLIC, accr:NON_PUBLIC, accr:CONFIDENTIAL, accr:RESTRICTED, accr:SENSITIVE."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

ns1:ConformanceLevel a owl:Class ;
    rdfs:label "ConformanceLevel"@en ;
    dcterms:description "The class of conformance levels. Includes the following individuals: `ddoc:mandatory`, `ddoc:recommended` and `ddoc:optional`."@en ;
    rdfs:isDefinedBy ns1: ;
    owl:oneOf ( ns1:mandatory ns1:optional ns1:recommended ) .

:used a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates an activity to an entity that it used."@en ;
    rdfs:comment "The activity A proper overlaps the entity E, where the non-overlapping part of E causes A."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf prov:used,
        :isOvercrossedBy ;
    skos:example "For example, :baking :used :spoon, :egg, :oven ."^^xsd:string ;
    skos:prefLabel "used"@en .

:wasGeneratedBy a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    dcterms:description "Relates an entity to the activity it was generated from."@en ;
    rdfs:comment "The activity A proper overlaps the entity E, where the non-overlapping part of E is caused by A."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy : ;
    rdfs:range prov:Activity ;
    rdfs:subPropertyOf prov:wasGeneratedBy,
        :isOvercrossedBy ;
    skos:prefLabel "wasGeneratedBy"@en .

skos:Concept a owl:Class ;
    dcterms:description "An idea or notion; a unit of thought."^^xsd:string ;
    vann:usageNote "In DCAT-AP, a Concept is used to denote codes within a codelist. See [DCAT-AP](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#controlled-vocs) for expectations and more detail."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

prov:Agent a owl:Class ;
    rdfs:label "Agent"^^xsd:string ;
    dcterms:description "An agent is something that bears some form of responsibility for an activity taking place, for the existence of an entity, or for another agent's aprovctivity. "@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:subClassOf foaf:Agent,
        :Role ;
    owl:disjointWith prov:InstantaneousEvent ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "agents-responsibility"^^xsd:string ;
    prov:definition "An agent is something that bears some form of responsibility for a activity taking place, for the existence of an entity, or for another agent's aprovctivity. "@en ;
    prov:dm "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-agent"^^xsd:anyURI ;
    prov:n "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-Agent"^^xsd:anyURI .

:SsbdDimension a owl:Class ;
    dcterms:description "XXX"@en ;
    rdfs:comment "The pink:SsbdDimension is an extension of the 'sustainability dimensions' defined by JRC."^^xsd:string ;
    rdfs:isDefinedBy : ;
    skos:prefLabel "SsbdDimension"@en .

:Method a owl:Class ;
    dcterms:description "Data that describes how to perform an activity."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf :Data ;
    skos:altLabel "MethodImplementation"@en ;
    skos:prefLabel "Method"@en .

:hasPart a owl:ObjectProperty,
        owl:ReflexiveProperty ;
    dcterms:description "The primitive relation that express the concept of an entity being part of another one."@en ;
    rdfs:comment "OWL2 does not allow non-simple (e.g. transitive) properties to appear in disjoint property axioms. We therefore implement the transitivity of hasPart using SWRL rules instead of asserting it with owl:TransitiveProperty."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subPropertyOf dcterms:hasPart,
        :overlaps ;
    skos:prefLabel "hasPart"@en .

prov:Activity a owl:Class ;
    rdfs:label "Activity"^^xsd:string ;
    dcterms:description "An activity is something that occurs over a period of time and acts upon or with entities; it may include consuming, processing, transforming, modifying, relocating, using, or generating entities."^^xsd:string ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        <https://w3id.org/pink/reused-terms#> ;
    owl:disjointWith prov:Entity ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "entities-activities"^^xsd:string ;
    prov:constraints "http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#prov-dm-constraints-fig"^^xsd:anyURI ;
    prov:definition "An activity is something that occurs over a period of time and acts upon or with entities; it may include consuming, processing, transforming, modifying, relocating, using, or generating entities."^^xsd:string ;
    prov:dm "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-Activity"^^xsd:anyURI ;
    prov:n "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-Activity"^^xsd:anyURI .

<urn:swrl:var#x> a swrl:Variable .

<urn:swrl:var#y> a swrl:Variable .

<urn:swrl:var#z> a swrl:Variable .

prov:Entity a owl:Class ;
    rdfs:label "Entity"^^xsd:string ;
    dcterms:description "An entity is a physical, digital, conceptual, or other kind of thing with some fixed aspects; entities may be real or imaginary. "@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#>,
        ns1: ;
    owl:disjointWith prov:InstantaneousEvent ;
    prov:category "starting-point"^^xsd:string ;
    prov:component "entities-activities"^^xsd:string ;
    prov:constraints "http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#prov-dm-constraints-fig"^^xsd:anyURI ;
    prov:definition "An entity is a physical, digital, conceptual, or other kind of thing with some fixed aspects; entities may be real or imaginary. "@en ;
    prov:dm "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-entity"^^xsd:anyURI ;
    prov:n "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-Entity"^^xsd:anyURI .

rdfs:Class a owl:Class ;
    dcterms:description "The class of classes."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class .

owl:Class a owl:Class ;
    dcterms:description "The class of OWL classes."^^xsd:string ;
    rdfs:isDefinedBy ns1: ;
    rdfs:subClassOf rdfs:Class,
        "rdfs:Class"^^xsd:string .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#y> ;
                    swrl:propertyPredicate :hasPart ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#y> ;
                            swrl:argument2 <urn:swrl:var#z> ;
                            swrl:propertyPredicate :hasPart ] ;
                    rdf:rest () ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#z> ;
                    swrl:propertyPredicate :hasPart ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#y> ;
                    swrl:propertyPredicate :wasGeneratedBy ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#y> ;
                            swrl:argument2 <urn:swrl:var#z> ;
                            swrl:propertyPredicate :used ] ;
                    rdf:rest () ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#z> ;
                    swrl:propertyPredicate :wasDerivedBy ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#y> ;
                    swrl:argument2 <urn:swrl:var#x> ;
                    swrl:propertyPredicate :wasAssociatedWith ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#y> ;
                            swrl:argument2 <urn:swrl:var#z> ;
                            swrl:propertyPredicate :used ] ;
                    rdf:rest () ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#z> ;
                    swrl:propertyPredicate :attributed ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#y> ;
                    swrl:propertyPredicate :used ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#y> ;
                            swrl:argument2 <urn:swrl:var#z> ;
                            swrl:propertyPredicate :wasGeneratedBy ] ;
                    rdf:rest () ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#z> ;
                    swrl:propertyPredicate :wasInformedBy ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#y> ;
                    swrl:propertyPredicate :wasGeneratedBy ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#y> ;
                            swrl:argument2 <urn:swrl:var#z> ;
                            swrl:propertyPredicate :used ] ;
                    rdf:rest () ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#z> ;
                    swrl:propertyPredicate :processedFrom ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#x> ;
                    swrl:argument2 <urn:swrl:var#y> ;
                    swrl:propertyPredicate :hasProcess ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#z> ;
