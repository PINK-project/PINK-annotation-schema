<http://xmlns.com/foaf/0.1/workplaceHomepage> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/dc/terms/hasPart
<http://purl.org/dc/terms/hasPart> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#used
<http://www.w3.org/ns/prov#used> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasAssociatedWith
<http://www.w3.org/ns/prov#wasAssociatedWith> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasAttributedTo
<http://www.w3.org/ns/prov#wasAttributedTo> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasDerivedBy
<http://www.w3.org/ns/prov#wasDerivedBy> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasInfluencedBy
<http://www.w3.org/ns/prov#wasInfluencedBy> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasInformedBy
<http://www.w3.org/ns/prov#wasInformedBy> rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/page
<http://xmlns.com/foaf/0.1/page> rdf:type owl:ObjectProperty .


###  https://w3id.org/pink#attributed
:attributed rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :causedBy ;
            owl:inverseOf :wasAttributedTo ;
            rdf:type owl:AsymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:domain <http://www.w3.org/ns/prov#Agent> ;
            rdfs:range <http://www.w3.org/ns/prov#Entity> ;
            <http://www.w3.org/2004/02/skos/core#definition> "Relates an agent to an entity via an activity that both the agent and entity participates to."@en ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "attributed"@en ;
            <http://www.w3.org/2004/02/skos/core#skopeNote> "The activity is through overlapped by the agent and overcrossed by the entity."@en ,
                                                            "There may or may not be a causal interaction between the agent and entity."@en .


###  https://w3id.org/pink#causedBy
:causedBy rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasInfluencedBy> ;
          rdf:type owl:IrreflexiveProperty ;
          <http://www.w3.org/2004/02/skos/core#definition> "A relation between an entity that causally affects the subject."@en ;
          <http://www.w3.org/2004/02/skos/core#example> "John yesterday is the cause of John today, is an example of temporal-like causality. The desk supporting my laptop is a space-like causality."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "causedBy"@en .


###  https://w3id.org/pink#conformance
:conformance rdf:type owl:ObjectProperty ;
             rdfs:range <https://w3id.org/emmo/application/datadoc#ConformanceLevel> ;
             <http://purl.org/vocab/vann/usageNote> "It MUST take one of the values 'ddoc:mandatory', 'ddoc:recommended' or 'ddoc:optional'."@en ;
             rdfs:isDefinedBy <https://w3id.org/pink> ;
             <http://www.w3.org/2004/02/skos/core#definition> "Whether the annotation is mandatory, recommended or optional as part of the PINK Annotation Schema"@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "conformance" .


###  https://w3id.org/pink#documentation
:documentation rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/page> ;
               rdfs:domain <http://www.w3.org/ns/dcat#Resource> ;
               rdfs:range <http://xmlns.com/foaf/0.1/Document> ;
               <http://www.w3.org/2004/02/skos/core#definition> "A page or document documenting this resource." ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "documentation"@en .


###  https://w3id.org/pink#hasDatum
:hasDatum rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasPart ;
          rdf:type owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Dataset ;
          rdfs:range :Datum ;
          <http://www.w3.org/2004/02/skos/core#definition> "Relates a dataset to its datum."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "hasDatum"@en .


###  https://w3id.org/pink#hasJunctionPart
:hasJunctionPart rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasPart ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 <http://www.w3.org/2004/02/skos/core#altLabel> "hasSpatioTemporalPart"@en ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The part is connected with the rest item or members with both hasNext (or its inverse) and hasContact relations."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "hasJunctionPart"@en .


###  https://w3id.org/pink#hasMethod
:hasMethod rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :participatesTo ;
           rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
           rdfs:range :Method ;
           <http://www.w3.org/2004/02/skos/core#definition> "Relates an activity to the method that it is described by." ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "hasMethod"@en .


###  https://w3id.org/pink#hasModel
:hasModel rdf:type owl:ObjectProperty ,
                   owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Method ;
          rdfs:range :Model ;
          <http://www.w3.org/2004/02/skos/core#definition> "Relates a method to the model it implements."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "hasModel"@en .


###  https://w3id.org/pink#hasPart
:hasPart rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf <http://purl.org/dc/terms/hasPart> ,
                            :overlaps ;
         rdf:type owl:ReflexiveProperty ;
         owl:propertyDisjointWith :isOvercrossedBy ;
         <http://www.w3.org/2004/02/skos/core#definition> "The primitive relation that express the concept of an entity being part of another one."@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "hasPart"@en ;
         <http://www.w3.org/2004/02/skos/core#skopeNote> "OWL2 does not allow non-simple (e.g. transitive) properties to appear in disjoint property axioms. We therefore implement the transitivity of hasPart using SWRL rules instead of asserting it with owl:TransitiveProperty."@en .


###  https://w3id.org/pink#hasParticipant
:hasParticipant rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasPart ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                <http://www.w3.org/2004/02/skos/core#definition> "The relation between a process and an object participating to it, i.e. that is relevant to the process itself."@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "hasParticipant"@en ;
                <http://www.w3.org/2004/02/skos/core#skopeNote> "Participation is a parthood relation: you must be part of the process to contribute to it. A participant whose 4D extension is totally contained within the process."@en .


###  https://w3id.org/pink#hasProcess
:hasProcess rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :participatesTo ;
            rdf:type owl:AsymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:domain :Method ;
            rdfs:range :Process ;
            <http://www.w3.org/2004/02/skos/core#definition> "Relates a method to the process that it describes."@en ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "hasProcess"@en ;
            <http://www.w3.org/2004/02/skos/core#skopeNote> "The starting point for this relation is that it relates a method to an activity it describes. However, when an activity is described by a method is a process. Therefor is the range of this relation a process and not only an activity."@en ,
                                                            "This is a subproperty of participatesTo, meaning that the process is overcrossed by the method."@en .


###  https://w3id.org/pink#hasProperty
:hasProperty rdf:type owl:ObjectProperty ;
             rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
             rdfs:range :Property ;
             <http://www.w3.org/2004/02/skos/core#definition> "A semiotic relation that connects a semiotic object to a property in a declaration process."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "hasProperty"@en .


###  https://w3id.org/pink#hasSpatialPart
:hasSpatialPart rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasPart ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                <http://www.w3.org/2004/02/skos/core#definition> "A proper part of a whole, whose parts always cover the full temporal extension of the whole within a spatial interval."@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "hasSpatialPart"@en ;
                <http://www.w3.org/2004/02/skos/core#skopeNote> "The part is connected with the rest item or members with hasContact relations only (no hasNext)."@en .


###  https://w3id.org/pink#hasTemporalPart
:hasTemporalPart rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasPart ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A relation that identify a proper item part of the whole, whose parts always cover the full spatial extension of the whole within a time interval." ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "hasTemporalPart"@en ;
                 <http://www.w3.org/2004/02/skos/core#skopeNote> "A temporal part of an item cannot both cause and be caused by any other proper part of the item."@en .


###  https://w3id.org/pink#input
:input rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :attributed ;
       rdf:type owl:AsymmetricProperty ,
                owl:IrreflexiveProperty ;
       rdfs:domain :Method ;
       rdfs:range <http://www.w3.org/ns/prov#Entity> ;
       <http://www.w3.org/2004/02/skos/core#definition> "Relates a method to an entity via a process that used the entity and that the method participates to."@en ;
       <http://www.w3.org/2004/02/skos/core#prefLabel> "input"@en ;
       <http://www.w3.org/2004/02/skos/core#skopeNote> "The process P is through overlapped by the agent A and overcrossed by the entity E, where the non-overlapping part of E causes P."@en .


###  https://w3id.org/pink#isAfter
:isAfter rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :causedBy ;
         rdf:type owl:AsymmetricProperty ,
                  owl:IrreflexiveProperty ;
         <http://www.w3.org/2004/02/skos/core#definition> "A one-directional relation between an entity that affects the subject."@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "isAfter"@en .


###  https://w3id.org/pink#isOvercrossedBy
:isOvercrossedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :overlaps ;
                 rdf:type owl:IrreflexiveProperty ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The relation between an entity that overlaps another without having it as part."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "isOvercrossedBy"@en .


###  https://w3id.org/pink#method
:method rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :wasDerivedBy ;
        rdfs:domain <http://www.w3.org/ns/dcat#Dataset> ;
        rdfs:range :Method ;
        <http://www.w3.org/2004/02/skos/core#definition> "Relates a dataset to the method that describes the activity it was created with." ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "method"@en .


###  https://w3id.org/pink#nonOverlaps
:nonOverlaps rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ,
                      owl:IrreflexiveProperty ;
             owl:propertyDisjointWith :overlaps ;
             <http://www.w3.org/2004/02/skos/core#definition> "The relation between two individuals that does not share any parts."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "nonOverlaps"@en .


###  https://w3id.org/pink#output
:output rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :attributed ;
        rdf:type owl:AsymmetricProperty ,
                 owl:IrreflexiveProperty ;
        rdfs:domain :Method ;
        rdfs:range <http://www.w3.org/ns/prov#Entity> ;
        <http://www.w3.org/2004/02/skos/core#definition> "Relates a method to an entity via a process that was generated by the entity and that the method participates to."@en ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "output"@en ;
        <http://www.w3.org/2004/02/skos/core#skopeNote> "The process P is through overlapped by the agent A and overcrossed by the entity E, where the non-overlapping part of E is caused by P."@en .


###  https://w3id.org/pink#overlaps
:overlaps rdf:type owl:ObjectProperty ,
                   owl:SymmetricProperty ,
                   owl:ReflexiveProperty ;
          <http://www.w3.org/2004/02/skos/core#definition> "The relation between two individuals representing entities that share at least one of their parts."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "overlaps"@en .


###  https://w3id.org/pink#participatesTo
:participatesTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :isOvercrossedBy ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                rdfs:range <http://www.w3.org/ns/prov#Activity> ;
                <http://www.w3.org/2004/02/skos/core#definition> "Relation an entity to an activity that it interacts with."@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "participatesTo"@en ;
                <http://www.w3.org/2004/02/skos/core#skopeNote> "The entity through overlaps the activity."@en .


###  https://w3id.org/pink#processedFrom
:processedFrom rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAfter ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               <http://www.w3.org/2004/02/skos/core#definition> "Indirect relation that relates the output of an activity to its input."@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "processedFrom"@en .


###  https://w3id.org/pink#ssbdDimension
:ssbdDimension rdf:type owl:ObjectProperty ;
               rdfs:range :SsbdDimension ;
               <http://purl.org/vocab/vann/usageNote> "One of `pink:functionality`, `pink:safety`, `pink:environmental_sustainability`, `pink:social_sustainability`"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "ssbdDimension"@en .


###  https://w3id.org/pink#used
:used rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf <http://www.w3.org/ns/prov#used> ,
                         :isOvercrossedBy ;
      rdf:type owl:AsymmetricProperty ,
               owl:IrreflexiveProperty ;
      rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
      rdfs:range <http://www.w3.org/ns/prov#Entity> ;
      <http://www.w3.org/2004/02/skos/core#definition> "Relates an activity to an entity that it used."@en ;
      <http://www.w3.org/2004/02/skos/core#example> "For example, :baking :used :spoon, :egg, :oven ." ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "used"@en ;
      <http://www.w3.org/2004/02/skos/core#skopeNote> "The activity A proper overlaps the entity E, where the non-overlapping part of E causes A."@en .


###  https://w3id.org/pink#wasAssociatedWith
:wasAssociatedWith rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAssociatedWith> ,
                                      :isOvercrossedBy ;
                   rdf:type owl:AsymmetricProperty ,
                            owl:IrreflexiveProperty ;
                   rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
                   rdfs:range <http://www.w3.org/ns/prov#Agent> ;
                   <http://www.w3.org/2004/02/skos/core#definition> "Relates an activity to an agent that had some (unspecified) responsibility for the occurence of this activity."@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "wasAssociatedWith"@en ;
                   <http://www.w3.org/2004/02/skos/core#skopeNote> "The activity is through overlapped by the agent."@en .


###  https://w3id.org/pink#wasAttributedTo
:wasAttributedTo rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAttributedTo> ,
                                    :causedBy ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:range <http://www.w3.org/ns/prov#Agent> ;
                 <http://www.w3.org/2004/02/skos/core#definition> "Relates an entity to an agent via an activity that both the entity and agent participates to."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "wasAttributedTo"@en ;
                 <http://www.w3.org/2004/02/skos/core#skopeNote> "The activity is through overlapped by the agent and overcrossed by the entity."@en .


###  https://w3id.org/pink#wasDerivedBy
:wasDerivedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasDerivedBy> ,
                                 :processedFrom ;
              rdf:type owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
              rdfs:range <http://www.w3.org/ns/prov#Entity> ;
              <http://www.w3.org/2004/02/skos/core#definition> "Indirect relation that relates the output entity of an activity to its input entity."@en ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "wasDerivedBy"@en .


###  https://w3id.org/pink#wasGeneratedBy
:wasGeneratedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasGeneratedBy> ,
                                   :isOvercrossedBy ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                rdfs:range <http://www.w3.org/ns/prov#Activity> ;
                <http://www.w3.org/2004/02/skos/core#definition> "Relates an entity to the activity it was generated from."@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "wasGeneratedBy"@en ;
                <http://www.w3.org/2004/02/skos/core#skopeNote> "The activity A proper overlaps the entity E, where the non-overlapping part of E is caused by A."@en .


###  https://w3id.org/pink#wasInformedBy
:wasInformedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasInformedBy> ,
                                  :isAfter ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
               rdfs:range <http://www.w3.org/ns/prov#Activity> ;
               <http://www.w3.org/2004/02/skos/core#definition> "A one-directional relation between an activity that affects the subject activity."@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "wasInformedBy"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/pink#hasAPI
:hasAPI rdf:type owl:DatatypeProperty ;
        rdfs:domain <http://www.w3.org/ns/dcat#Resource> ;
        rdfs:range xsd:boolean ;
        <http://www.w3.org/2004/02/skos/core#definition> "Whether the method has an API." ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "hasAPI"@en .


###  https://w3id.org/pink#ssbdSubDimension
:ssbdSubDimension rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "ssbdSubDimension"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/dcat#Dataset
<http://www.w3.org/ns/dcat#Dataset> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#Resource
<http://www.w3.org/ns/dcat#Resource> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
<http://www.w3.org/ns/prov#Agent> rdf:type owl:Class ;
                                  rdfs:subClassOf :Role .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Document
<http://xmlns.com/foaf/0.1/Document> rdf:type owl:Class ;
                                     rdfs:subClassOf :Data .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .


###  https://w3id.org/emmo/application/datadoc#ConformanceLevel
<https://w3id.org/emmo/application/datadoc#ConformanceLevel> rdf:type owl:Class .


###  https://w3id.org/pink#Computation
:Computation rdf:type owl:Class ;
             rdfs:subClassOf :Process ;
             <http://www.w3.org/2004/02/skos/core#definition> "A procedure that deals with quantitative symbols (i.e. symbols associated with a quantitative oriented language)."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Computation"@en ;
             <http://www.w3.org/2004/02/skos/core#skopeNote> "Since Computation is a subclass of Process, we say that there must exist a method that describes the computation." .


###  https://w3id.org/pink#ComputationalTool
:ComputationalTool rdf:type owl:Class ;
                   rdfs:subClassOf :Method ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "ComputationalMethod"@en ;
                   <http://www.w3.org/2004/02/skos/core#definition> "A tool that describes how to run a computational model."@en ;
                   <http://www.w3.org/2004/02/skos/core#example> "Gromacs is a computational tool that solves Newton's equations of motion."@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "ComputationalTool"@en .


###  https://w3id.org/pink#Data
:Data rdf:type owl:Class ;
      rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
      <http://www.w3.org/2004/02/skos/core#definition> "Contrast from variation of properties that is encoded by an agent and that can be decoded by another agent according to a specific rule."@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Data"@en .


###  https://w3id.org/pink#Dataset
:Dataset rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/dcat#Dataset> ,
                         :Data ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasPart ;
                           owl:someValuesFrom :Datum
                         ] ;
         <http://purl.org/vocab/vann/usageNote> "A collection of (more than one) datum, published or curated by a single agent, and available for access or download in one or more representations."@en ;
         <http://www.w3.org/2004/02/skos/core#definition> "Encoded data made of more than one datum."@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "Dataset"@en .


###  https://w3id.org/pink#Datum
:Datum rdf:type owl:Class ;
       rdfs:subClassOf :Data ;
       <http://purl.org/vocab/vann/usageNote> "Datum is the building block of datasets."@en ;
       <http://www.w3.org/2004/02/skos/core#definition> "A self-consistent encoded data entity."@en ;
       <http://www.w3.org/2004/02/skos/core#prefLabel> "Datum"@en .


###  https://w3id.org/pink#Material
:Material rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
          <http://www.w3.org/2004/02/skos/core#definition> "The class of individuals standing for an amount of matter (ordinary, anti or hybrid) substance (or mixture of substances) in different states of matter or phases."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "Material"@en .


###  https://w3id.org/pink#MaterialProcess
:MaterialProcess rdf:type owl:Class ;
                 rdfs:subClassOf :Process ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A process that has material as input and output."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "MaterialProcess"@en ;
                 <http://www.w3.org/2004/02/skos/core#skopeNote> "Since MaterialProcess is a subclass of Process, we say that there must exist a method that describes the material process." .


###  https://w3id.org/pink#Measurement
:Measurement rdf:type owl:Class ;
             rdfs:subClassOf :Process ;
             <http://www.w3.org/2004/02/skos/core#definition> "An observation that results in a quantitative comparison of a 'property' of an 'object' with a standard reference based on a well defined mesurement procedure."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Measurement"@en ;
             <http://www.w3.org/2004/02/skos/core#skopeNote> "Since Measurement is a subclass of Process, we say that there must exist a method that describes the measurement." .


###  https://w3id.org/pink#Method
:Method rdf:type owl:Class ;
        rdfs:subClassOf :Data ;
        <http://www.w3.org/2004/02/skos/core#altLabel> "MethodImplementation"@en ;
        <http://www.w3.org/2004/02/skos/core#definition> "Data that describes how to perform an activity."@en ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "Method"@en .


###  https://w3id.org/pink#Model
:Model rdf:type owl:Class ;
       rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
       <http://www.w3.org/2004/02/skos/core#definition> "A useful simplified description of a selected part of the world."@en ;
       <http://www.w3.org/2004/02/skos/core#example> """Newton's law of motion is a model for how a body will move when subjected to forces.
A mouse can be seen as a model for a human (e.g. in medicine).
An architectural floor plan is a model of a house.
"""@en ;
       <http://www.w3.org/2004/02/skos/core#prefLabel> "Model"@en .


###  https://w3id.org/pink#Object
:Object rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
        <http://www.w3.org/2004/02/skos/core#definition> "The class of all individuals who's temporal parts are of the same type as the whole."@en ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "Object"@en .


###  https://w3id.org/pink#Participant
:Participant rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ,
                             :Object ;
             <http://purl.org/vocab/vann/usageNote> "Example: A student during an examination. The student exists both before and after the examination."@en ;
             <http://www.w3.org/2004/02/skos/core#definition> "An object which is a spatial part of a process."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Participant"@en .


###  https://w3id.org/pink#Process
:Process rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty [ owl:inverseOf :hasProcess
                                          ] ;
                           owl:someValuesFrom :Method
                         ] ;
         <http://www.w3.org/2004/02/skos/core#definition> "An activity that is described by a method."@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "Process"@en .


###  https://w3id.org/pink#Property
:Property rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
          <http://purl.org/vocab/vann/usageNote> "A property is atomic in the sense that is aimed to deliver one and one only aspect of the object."@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "A coventional semiotic sigh that stands for an physical interaction with an object using an atomic symbol."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "Property"@en .


###  https://w3id.org/pink#ReliabilityDocument
:ReliabilityDocument rdf:type owl:Class ;
                     rdfs:subClassOf <http://xmlns.com/foaf/0.1/Document> ;
                     <http://purl.org/vocab/vann/usageNote> "xxx"@en ;
                     <http://www.w3.org/2004/02/skos/core#definition> "xxx"@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "ReliabilityDocument"@en .


###  https://w3id.org/pink#Role
:Role rdf:type owl:Class ;
      <http://purl.org/vocab/vann/usageNote> "An individual can be said to have a role in relation to the entity."@en ;
      <http://www.w3.org/2004/02/skos/core#definition> "The class of all individuals that are defined through a parthood relation to an entity."@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Role"@en .


###  https://w3id.org/pink#SsbdDimension
:SsbdDimension rdf:type owl:Class ;
               <http://www.w3.org/2004/02/skos/core#definition> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "SsbdDimension"@en ;
               <http://www.w3.org/2004/02/skos/core#skopeNote> "The pink:SsbdDimension is an extension of the 'sustainability dimensions' defined by JRC." .


#################################################################
#    Individuals
#################################################################

###  https://orcid.org/0000-0001-8869-3718
<https://orcid.org/0000-0001-8869-3718> rdf:type owl:NamedIndividual ,
                                                 <http://xmlns.com/foaf/0.1/Person> ;
                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "FrancescaLonstadBleken" ;
                                        <http://xmlns.com/foaf/0.1/name> "Francesca Lønstad Bleken" ;
                                        <http://xmlns.com/foaf/0.1/workplaceHomepage> <https://www.sintef.no/en/> .


###  https://orcid.org/0000-0002-1560-809X
<https://orcid.org/0000-0002-1560-809X> rdf:type owl:NamedIndividual ,
                                                 <http://xmlns.com/foaf/0.1/Person> ;
                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "JesperFriis" ;
                                        <http://xmlns.com/foaf/0.1/name> "Jesper Friis" ;
                                        <http://xmlns.com/foaf/0.1/workplaceHomepage> <https://www.sintef.no/en/> .


###  https://orcid.org/0000-0002-1849-5246
<https://orcid.org/0000-0002-1849-5246> rdf:type owl:NamedIndividual ,
                                                 <http://xmlns.com/foaf/0.1/Person> ;
                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "ThomasExner" ;
                                        <http://xmlns.com/foaf/0.1/name> "Thomas Exner" ;
                                        <http://xmlns.com/foaf/0.1/workplaceHomepage> <https://sevenpastnine.com/> .


###  https://orcid.org/0000-0002-8053-8198
<https://orcid.org/0000-0002-8053-8198> rdf:type owl:NamedIndividual ,
                                                 <http://xmlns.com/foaf/0.1/Person> ;
                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "JohDokler" ;
                                        <http://xmlns.com/foaf/0.1/name> "Joh Dokler" ;
                                        <http://xmlns.com/foaf/0.1/workplaceHomepage> <https://sevenpastnine.com/> .


###  https://orcid.org/0000-0003-4250-4584
<https://orcid.org/0000-0003-4250-4584> rdf:type owl:NamedIndividual ,
                                                 <http://xmlns.com/foaf/0.1/Person> ;
                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "IseultLynch" ;
                                        <http://xmlns.com/foaf/0.1/name> "Iseult Lynch" ;
                                        <http://xmlns.com/foaf/0.1/workplaceHomepage> <https://www.birmingham.ac.uk/> .


###  https://w3id.org/emmo/application/datadoc#mandatory
<https://w3id.org/emmo/application/datadoc#mandatory> rdf:type owl:NamedIndividual ;
                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "mandatory"@en .


###  https://w3id.org/emmo/application/datadoc#optional
<https://w3id.org/emmo/application/datadoc#optional> rdf:type owl:NamedIndividual ;
                                                     <http://www.w3.org/2004/02/skos/core#prefLabel> "optional"@en .


###  https://w3id.org/emmo/application/datadoc#recommended
<https://w3id.org/emmo/application/datadoc#recommended> rdf:type owl:NamedIndividual ;
                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "recommended"@en .


###  https://w3id.org/pink#economic
:economic rdf:type owl:NamedIndividual ,
                   :SsbdDimension ;
          <http://purl.org/dc/terms/bibliographicCitation> "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022" ;
          <http://www.w3.org/2004/02/skos/core#definition> "Aspects related to techno-economic feasibility, to operational costs, etc."@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "economic" ;
          <http://www.w3.org/2004/02/skos/core#scopeNote> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
          <http://www.w3.org/2004/02/skos/core#skopeNote> """There are important considerations to be made in the context of SSbD
such as the 'availability' of raw materials, as chemicals/materials
cannot be declared SSbD if the raw materials to produce them are not
renewable or are (very) scarce and extracted and processed in an
unsustainable manner. Economic aspects play a role when there is a
need to rank chemicals and materials based on SSbD criteria (even if
they are not SSbD). However, mainly externalities consideration is at
stake in a sustainability framework like the SSbD one."""@en .


###  https://w3id.org/pink#environmental_systainability
:environmental_systainability rdf:type owl:NamedIndividual ,
                                       :SsbdDimension ;
                              <http://purl.org/dc/terms/bibliographicCitation> "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022" ;
                              <http://www.w3.org/2004/02/skos/core#definition> "The ability to conserve natural resources and protect global ecosystems to support human health and wellbeing, within the limits of our Planet"@en ;
                              <http://www.w3.org/2004/02/skos/core#prefLabel> "environmental_systainability" ;
                              <http://www.w3.org/2004/02/skos/core#scopeNote> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
                              <http://www.w3.org/2004/02/skos/core#skopeNote> """Assessing environmental sustainability implies to assess the environmental impacts generated by
chemicals/materials along the entire life cycle to move towards:

  · A toxic-free environment as stated in the CSS (i.e. minimising the total toxicity footprint in terms
    of ecotoxicity and human toxicity13 - at each stage of the production and consumption life cycle,
    originated not only by the assessed chemical or material, but also by all the chemicals that are emitted
    along the life cycle14) (EC, 2020a);
  · A climate-neutral economy (i.e. minimising the emission of greenhouse gases along the life cycle)
    (EC, 2019b);
  · A resource efficient economy and a regenerative economy (i.e. using natural resources in a
    sustainable manner, minimising inputs and waste generation, and providing more benefits than
    burdens) (EC, 2020b);
  · The reduction of biodiversity loss and the conservation of ecosystem functioning, addressing the
    main drivers of structural and functional biodiversity loss (e.g. land use, climate change) (EC, 2020c);
"""@en .


###  https://w3id.org/pink#functionality
:functionality rdf:type owl:NamedIndividual ,
                        :SsbdDimension ;
               <http://www.w3.org/2004/02/skos/core#definition> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "functionality" .


###  https://w3id.org/pink#safety
:safety rdf:type owl:NamedIndividual ,
                 :SsbdDimension ;
        <http://purl.org/dc/terms/bibliographicCitation> "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022" ;
        <http://www.w3.org/2004/02/skos/core#definition> "Human helth and environmental safety aspects of chemicals and materials."@en ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "safety" ;
        <http://www.w3.org/2004/02/skos/core#scopeNote> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
        <http://www.w3.org/2004/02/skos/core#skopeNote> """In the context of chemicals assessment, safety could be referring to a
certain condition where a stressor (e.g. a chemical) is unlikely to
cause any adverse effect to a receptor (e.g. humans and other
organisms) (more related to intrinsic hazard properties of the
stressor) or where a receptor is protected from risk (more related to
control measures or mechanisms to minimise exposure to the
stressor). In any case, the term safe involves receptors, and with
that generally also requires the consideration of the contact
(i.e. exposure) between stressors and receptors as addressed in a risk
assessment context."""@en .


###  https://w3id.org/pink#social_systainability
:social_systainability rdf:type owl:NamedIndividual ,
                                :SsbdDimension ;
                       <http://purl.org/dc/terms/bibliographicCitation> "Caldeira et al. JRC Technical Report. Sage and Sustainable by Design chemicals and materials. EU Science Hub. doi:10.2760/487955. 2022" ;
                       <http://www.w3.org/2004/02/skos/core#definition> "A globally agreed list of objectives and targets to be pursued for achieving sustainable development."@en ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "social_sustainability" ;
                       <http://www.w3.org/2004/02/skos/core#scopeNote> "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
                       <http://www.w3.org/2004/02/skos/core#skopeNote> """In the SDGs framework several Goals focus on social aspects,
e.g. poverty eradication (SDG 1), food security (SDG 2), health (SDG 3),
education (SDG 4), gender equality (SDG 5), decent work (SDG 8),
reduce inequalities (SDG 10), peace and justice (SDG 16)."""@en .


#################################################################
#    Rules
#################################################################

<urn:swrl:var#x> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#y> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#z> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasProcess ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#x> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#y>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :used ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#y> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#z>
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :input ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#x> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#z>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
