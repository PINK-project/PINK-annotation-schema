@prefix : <https://w3id.org/pink#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/pink#> .

<https://w3id.org/pink> rdf:type owl:Ontology ;
                         owl:versionIRI <https://w3id.org/pink/0.0.1> ;
                         owl:imports <https://w3id.org/pink/0.0.1/reused-terms> ;
                         <http://data.europa.eu/r5r/status> "Under Development" ;
                         <http://purl.org/dc/terms/abstract> """The PINK Annotation Schema provides the semantic basis for SSbD.

The PINK Annotation Schema expands on the annotation schema provided by tripper, which again expands on the DCAT-AP.

A reference documentation of terms reused from standard W3C vocabularies can be found https://pink-project.github.io/PINK-annotation-schema/widoco-reused-terms/index-en.html.
"""@en ;
                         <http://purl.org/dc/terms/bibliographicCitation> "xxx" ;
                         <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0003-4250-4584> ;
                         <http://purl.org/dc/terms/created> "2025-09-08" ;
                         <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0001-8869-3718> ,
                                                            <https://orcid.org/0000-0002-1560-809X> ,
                                                            <https://orcid.org/0000-0002-1849-5246> ,
                                                            <https://orcid.org/0000-0002-8053-8198> ;
                         <http://purl.org/dc/terms/hasFormat> <https://www.w3.org/TR/turtle/> ;
                         <http://purl.org/dc/terms/issued> "xxxx-xx-xx" ;
                         <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/legalcode" ;
                         <http://purl.org/dc/terms/modified> "xxxx-xx-xx" ;
                         <http://purl.org/dc/terms/publisher> <https://pink-project.eu/> ;
                         <http://purl.org/dc/terms/title> "PINK Annotation Schema"@en ;
                         <http://purl.org/ontology/bibo/doi> "tbd" ;
                         <http://purl.org/vocab/vann/preferredNamespacePrefix> "pink" ;
                         <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/pink" ;
                         owl:priorVersion "0.0.0" ;
                         owl:versionInfo "0.0.1" ;
                         <http://xmlns.com/foaf/0.1/homepage> <https://github.com/PINK-project/PINK-annotation-schema> ;
                         <http://xmlns.com/foaf/0.1/logo> <https://tess.elixir-europe.org/system/content_providers/images/000/000/777/original/pink-logo-orange-colorB-500.png> .

