    <!-- https://w3id.org/pink#hasParticipant -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pink#hasParticipant"/>
    


    <!-- https://w3id.org/pink#implementsModel -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pink#implementsModel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/emmo/hume#AIModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#AIModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#DataBasedModel"/>
        <skos:altLabel xml:lang="en">ArtificialIntelligenceModel</skos:altLabel>
        <skos:definition xml:lang="en">An AI-based model.</skos:definition>
        <skos:prefLabel xml:lang="en">AIModel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#AnalogicalIcon -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#AnalogicalIcon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pink#Model"/>
        <skos:altLabel xml:lang="en">AnalogicalIcon</skos:altLabel>
        <skos:definition xml:lang="en">A model that represents the internal logical structure of the object.</skos:definition>
        <skos:example xml:lang="en">A physics equation is replicating the mechanisms internal to the object.</skos:example>
        <skos:example xml:lang="en">Electrical diagram is diagrammatic and resemblance</skos:example>
        <skos:example xml:lang="en">MODA and CHADA are diagrammatic representation of a simulation or a characterisation workflow.</skos:example>
        <skos:prefLabel xml:lang="en">AnalogicalModel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A model that focus on HOW the object works.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The subclass of model inspired by Peirceian category (b) the diagram, whose internal relations, mainly dyadic or so taken, represent by analogy (with the same logic) the relations in something (e.g. math formula, geometric flowchart).</skos:scopeNote>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#DataBasedModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#DataBasedModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#MathematicalModel"/>
        <skos:definition xml:lang="en">A mathematical model based on observed data, measurements, or experimental results.</skos:definition>
        <skos:prefLabel xml:lang="en">DataBasedModel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#DataProcessing -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#DataProcessing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pink#Computation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pink#hasParticipant"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/emmo/hume#DataProcessingSoftware"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A computation that provides a data output following the elaboration of some input data, using a data processing application.</skos:definition>
        <skos:prefLabel xml:lang="en">DataProcessing</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#DataProcessingSoftware -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#DataProcessingSoftware">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pink#Software"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pink#implementsModel"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/emmo/hume#MathematicalModel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:altLabel xml:lang="en">DataProcessingApplication</skos:altLabel>
        <skos:definition xml:lang="en">A software program aimed for data processing.</skos:definition>
        <skos:prefLabel xml:lang="en">DataProcessingSoftware</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#FunctionalIcon -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#FunctionalIcon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pink#Model"/>
        <skos:altLabel xml:lang="en">FunctionalIcon</skos:altLabel>
        <skos:definition xml:lang="en">A model that imitates one representative character of the object. It share external similarities with the object, but not necessarily the same internal logical structure.</skos:definition>
        <skos:example xml:lang="en">A data based model is only a functional model, since it provide the same relations between the properties of the object (e.g., it can predict some properties as function of others) but is not considering the internal mechanisms (i.e., it can ignore the physics).</skos:example>
        <skos:prefLabel xml:lang="en">FunctionalModel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A model that focusing WHAT the object does.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">This subclass of model inspired by Peirceian category (c) the metaphor, which represents the representative character of a sign by representing a parallelism in something else.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#GenerativeAIModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#GenerativeAIModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#AIModel"/>
        <skos:altLabel xml:lang="en">GenerativeArtificialIntelligenceModel</skos:altLabel>
        <skos:definition xml:lang="en">An AI model that can generate new content, like text, images or code.</skos:definition>
        <skos:example xml:lang="en">Chatbots</skos:example>
        <skos:prefLabel xml:lang="en">GenerativeAIModel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#MachineLearningModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#MachineLearningModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#AIModel"/>
        <skos:definition xml:lang="en">An AI model using machine learning.</skos:definition>
        <skos:prefLabel xml:lang="en">MachineLearningModel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#MathematicalModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#MathematicalModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#AnalogicalIcon"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pink#Information"/>
        <skos:definition xml:lang="en">An analogical model expressed in mathematical language.</skos:definition>
        <skos:prefLabel xml:lang="en">MathematicalModel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A mathematical model can be defined as a description of a system using mathematical concepts and language to facilitate proper explanation of a system or to study the effects of different components and to make predictions on patterns of behaviour.

Abramowitz and Stegun, 1968</skos:scopeNote>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#NaturalLanguageProcessingModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#NaturalLanguageProcessingModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#AIModel"/>
        <skos:definition xml:lang="en">An AI model that understands and generates human language.</skos:definition>
        <skos:example xml:lang="en">Chatbots</skos:example>
        <skos:prefLabel xml:lang="en">NaturalLanguageProcessingModel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#PhysicsBasedModel -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#PhysicsBasedModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#MathematicalModel"/>
        <rdfs:isDefinedBy xml:lang="en">CEN Workshop Agreement, CWA 17284 Materials modelling - terminology, classification and metadata</rdfs:isDefinedBy>
        <skos:definition xml:lang="en">A mathematical model based on a fundamental physics theory which defines the relations between physics quantities of an entity.</skos:definition>
        <skos:prefLabel xml:lang="en">PhysicsBasedModel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#Replica -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#Replica">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#FunctionalIcon"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/emmo/hume#ResemblanceIcon"/>
        <skos:definition xml:lang="en">A model that not only resembles the object, but also can express some of the object&apos;s functions.</skos:definition>
        <skos:example xml:lang="en">A small scale replica of a plane tested in a wind gallery shares the same functionality in terms of aerodynamic behaviour of the bigger one.</skos:example>
        <skos:example xml:lang="en">Pinocchio is a functional model of a boy since it imitates the external behaviour without having the internal biological structure of a human being (it is made of magic wood...).</skos:example>
        <skos:prefLabel xml:lang="en">Replica</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/emmo/hume#ResemblanceIcon -->


    <owl:Class rdf:about="https://w3id.org/emmo/hume#ResemblanceIcon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pink#Model"/>
        <skos:altLabel xml:lang="en">ResemblanceIcon</skos:altLabel>
        <skos:definition xml:lang="en">A model that mimics the spatial or temporal shape of the object.</skos:definition>
        <skos:example xml:lang="en">A geographical map that imitates the shape of the landscape and its properties at a specific historical time.</skos:example>
        <skos:prefLabel xml:lang="en">ResemblanceModel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A model that focus on WHERE/WHEN the object is, in the sense of spatial or temporal shape.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The subclass of model inspired by Peirceian category a) the image, which depends on a simple quality (e.g. picture).</skos:scopeNote>
    </owl:Class>
    


    <!-- https://w3id.org/pink#Computation -->


    <owl:Class rdf:about="https://w3id.org/pink#Computation"/>
    


    <!-- https://w3id.org/pink#Information -->


    <owl:Class rdf:about="https://w3id.org/pink#Information"/>
    


    <!-- https://w3id.org/pink#Model -->


    <owl:Class rdf:about="https://w3id.org/pink#Model"/>
    


    <!-- https://w3id.org/pink#Software -->


    <owl:Class rdf:about="https://w3id.org/pink#Software"/>
</rdf:RDF>



