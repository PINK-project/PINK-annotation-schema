<http://spdx.org/rdf/terms#algorithm> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <http://spdx.org/rdf/terms#Checksum> ;
                                      rdfs:range <http://spdx.org/rdf/terms#ChecksumAlgorithm> .


