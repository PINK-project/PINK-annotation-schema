dcterms:title vann:usageNote "This property can be repeated for parallel language versions of the name." ;
              rdfs:isDefinedBy ns1: ;
              skos:definition "A name given to the resource." ;
              skos:prefLabel "title" .


dcterms:type vann:usageNote "A recommended controlled vocabulary data-type is foreseen. For agents, the value should be chosen from [ADMS publisher type](https://raw.githubusercontent.com/SEMICeu/ADMS-AP/master/purl.org/ADMS_SKOS_v1.00.rdf)." ;
             rdfs:domain "dcterms:LicenseDocument" ;
