                  rdfs:range <http://www.w3.org/2006/vcard/ns#Kind> .


###  http://www.w3.org/ns/dcat#distribution
dcat:distribution rdf:type owl:ObjectProperty ;
                  rdfs:domain dcat:Dataset ;
                  rdfs:range dcat:Distribution .


###  http://www.w3.org/ns/dcat#endpointDescription
dcat:endpointDescription rdf:type owl:ObjectProperty ;
                         rdfs:domain dcat:DataService ;
                         rdfs:range rdfs:Resource .


###  http://www.w3.org/ns/dcat#hasRole
dcat:hasRole rdf:type owl:ObjectProperty ;
             rdfs:domain dcat:Relationship .


###  http://www.w3.org/ns/dcat#hasVersion
dcat:hasVersion rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:Resource ;
                rdfs:range rdfs:Resource .


###  http://www.w3.org/ns/dcat#inSeries
dcat:inSeries rdf:type owl:ObjectProperty ;
              rdfs:domain dcat:Dataset ;
              rdfs:range dcat:DatasetSeries .


###  http://www.w3.org/ns/dcat#landingPage
dcat:landingPage rdf:type owl:ObjectProperty ;
                 rdfs:domain dcat:Resource ;
                 rdfs:range foaf:Document .


###  http://www.w3.org/ns/dcat#mediaType
dcat:mediaType rdf:type owl:ObjectProperty ;
               rdfs:domain dcat:Distribution ;
               rdfs:range dcterms:MediaType .


###  http://www.w3.org/ns/dcat#packageFormat
dcat:packageFormat rdf:type owl:ObjectProperty ;
                   rdfs:domain dcat:Distribution ;
                   rdfs:range dcterms:MediaType .


###  http://www.w3.org/ns/dcat#qualifiedRelation
dcat:qualifiedRelation rdf:type owl:ObjectProperty ;
                       rdfs:domain dcat:Resource ;
                       rdfs:range dcat:Relationship .


###  http://www.w3.org/ns/dcat#servesDataset
dcat:servesDataset rdf:type owl:ObjectProperty ;
                   rdfs:domain dcat:DataService ;
                   rdfs:range dcat:Dataset .


###  http://www.w3.org/ns/dcat#theme
dcat:theme rdf:type owl:ObjectProperty ;
           rdfs:domain dcat:Resource ;
           rdfs:range skos:Concept .


###  http://www.w3.org/ns/locn#geometry
locn:geometry rdf:type owl:ObjectProperty ;
              rdfs:domain dcterms:Location ;
              rdfs:range locn:Geometry .


###  http://www.w3.org/ns/prov#activity
prov:activity rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#agent
prov:agent rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#entity
prov:entity rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#qualifiedAssociation
prov:qualifiedAssociation rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#qualifiedAttribution
prov:qualifiedAttribution rdf:type owl:ObjectProperty ;
                          rdfs:domain dcat:Resource ;
                          rdfs:range prov:Attribution .


###  http://www.w3.org/ns/prov#qualifiedCommunication
prov:qualifiedCommunication rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#qualifiedUsage
prov:qualifiedUsage rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#used
prov:used rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf prov:wasInfluencedBy ;
          rdfs:domain prov:Activity ;
          rdfs:range prov:Entity ;
          owl:propertyChainAxiom ( prov:qualifiedUsage
                                   prov:entity
                                 ) ;
          rdfs:comment "A prov:Entity that was used by this prov:Activity. For example, :baking prov:used :spoon, :egg, :oven ."@en ;
          rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                           <https://w3id.org/pink/reused-terms#> ;
          rdfs:label "used" ;
          prov:category "starting-point" ;
          prov:component "entities-activities" ;
          prov:inverse "wasUsedBy" ;
          prov:qualifiedForm prov:Usage ,
                             prov:qualifiedUsage .


###  http://www.w3.org/ns/prov#wasAssociatedWith
prov:wasAssociatedWith rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf prov:wasInfluencedBy ;
                       rdfs:domain prov:Activity ;
                       rdfs:range prov:Agent ;
                       owl:propertyChainAxiom ( prov:qualifiedAssociation
                                                prov:agent
                                              ) ;
                       rdfs:comment "An prov:Agent that had some (unspecified) responsibility for the occurrence of this prov:Activity."@en ;
                       rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                                        <https://w3id.org/pink/reused-terms#> ;
                       rdfs:label "wasAssociatedWith" ;
                       prov:category "starting-point" ;
                       prov:component "agents-responsibility" ;
                       prov:inverse "wasAssociateFor" ;
                       prov:qualifiedForm prov:Association ,
                                          prov:qualifiedAssociation .


###  http://www.w3.org/ns/prov#wasAttributedTo
prov:wasAttributedTo rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf prov:wasInfluencedBy ;
                     rdfs:domain prov:Entity ;
                     rdfs:range prov:Agent ;
                     owl:propertyChainAxiom ( prov:qualifiedAttribution
                                              prov:agent
                                            ) ;
                     rdfs:comment "Attribution is the ascribing of an entity to an agent."@en ;
                     rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                                      <https://w3id.org/pink/reused-terms#> ;
                     rdfs:label "wasAttributedTo" ;
                     prov:category "starting-point" ;
                     prov:component "agents-responsibility" ;
                     prov:definition "Attribution is the ascribing of an entity to an agent."@en ;
                     prov:inverse "contributed" ;
                     prov:qualifiedForm prov:Attribution ,
                                        prov:qualifiedAttribution .


###  http://www.w3.org/ns/prov#wasDerivedBy
prov:wasDerivedBy rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:ObjectProperty ;
                    rdfs:domain dcat:Dataset ;
                    rdfs:range dcat:Resource .


###  http://www.w3.org/ns/prov#wasGeneratedBy
prov:wasGeneratedBy rdf:type owl:ObjectProperty ;
                    rdfs:domain dcat:Dataset ;
                    rdfs:range prov:Activity .


###  http://www.w3.org/ns/prov#wasInfluencedBy
prov:wasInfluencedBy rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasInformedBy
prov:wasInformedBy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf prov:wasInfluencedBy ;
                   rdfs:domain prov:Activity ;
                   rdfs:range prov:Activity ;
                   owl:propertyChainAxiom ( prov:qualifiedCommunication
                                            prov:activity
                                          ) ;
                   rdfs:comment "An activity a2 is dependent on or informed by another activity a1, by way of some unspecified entity that is generated by a1 and used by a2."@en ;
                   rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                                    <https://w3id.org/pink/reused-terms#> ;
                   rdfs:label "wasInformedBy" ;
                   prov:category "starting-point" ;
                   prov:component "entities-activities" ;
                   prov:inverse "informed" ;
                   prov:qualifiedForm prov:Communication ,
                                      prov:qualifiedCommunication .


###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:ObjectProperty ;
          rdfs:domain dcat:Resource ;
          rdfs:range foaf:Document .


###  https://w3id.org/emmo/application/datadoc#conformance
ns1:conformance rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:Resource ;
                rdfs:range ns1:ConformanceLevel ;
                vann:usageNote "It MUST take one of the values 'ddoc:mandatory', 'ddoc:recommended' or 'ddoc:optional'."@en ;
                rdfs:isDefinedBy <https://w3id.org/emmo/application/datadoc> ,
                                 ns1: ;
                skos:definition "Whether the annotation is mandatory, recommended or optional."@en ;
                skos:prefLabel "conformance"@en .


###  https://w3id.org/emmo/application/datadoc#curator
ns1:curator rdf:type owl:ObjectProperty ;
            rdfs:domain dcat:Resource ;
            rdfs:range foaf:Agent .


###  https://w3id.org/emmo/application/datadoc#datatype
ns1:datatype rdf:type owl:ObjectProperty ;
             rdfs:domain rdfs:Resource ;
             rdfs:range rdfs:Datatype ;
             rdfs:isDefinedBy ns1: ;
             skos:definition "A datatype for annotations and data properties."@en ;
             skos:prefLabel "datatype"@en .


###  https://w3id.org/emmo/domain/oteio#generator
<https://w3id.org/emmo/domain/oteio#generator> rdf:type owl:ObjectProperty ;
                                               rdfs:domain dcat:Distribution ;
                                               rdfs:range <https://w3id.org/emmo/domain/oteio#Generator> .


###  https://w3id.org/emmo/domain/oteio#hasDatamodel
<https://w3id.org/emmo/domain/oteio#hasDatamodel> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain dcat:Dataset .


###  https://w3id.org/emmo/domain/oteio#parser
<https://w3id.org/emmo/domain/oteio#parser> rdf:type owl:ObjectProperty ;
                                            rdfs:domain dcat:DataService ;
                                            rdfs:range <https://w3id.org/emmo/domain/oteio#Parser> .


###  https://w3id.org/pink#attributed
:attributed rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :causedBy ;
            owl:inverseOf :wasAttributedTo ;
            rdf:type owl:AsymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:domain prov:Agent ;
            rdfs:range prov:Entity ;
            rdfs:isDefinedBy : ;
            skos:definition "Relates an agent to an entity via an activity that both the agent and entity participates to."@en ;
            skos:prefLabel "attributed"@en ;
            skos:skopeNote "The activity is through overlapped by the agent and overcrossed by the entity."@en ,
                           "There may or may not be a causal interaction between the agent and entity."@en .


###  https://w3id.org/pink#causedBy
:causedBy rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf prov:wasInfluencedBy ;
          rdf:type owl:IrreflexiveProperty ;
          rdfs:isDefinedBy : ;
          skos:definition "A relation between an entity that causally affects the subject."@en ;
          skos:example "John yesterday is the cause of John today, is an example of temporal-like causality. The desk supporting my laptop is a space-like causality."@en ;
          skos:prefLabel "causedBy"@en .


###  https://w3id.org/pink#conformance
:conformance rdf:type owl:ObjectProperty ;
             rdfs:range ns1:ConformanceLevel ;
             vann:usageNote "It MUST take one of the values 'ddoc:mandatory', 'ddoc:recommended' or 'ddoc:optional'."@en ;
             rdfs:isDefinedBy <https://w3id.org/pink> ,
                              : ;
             skos:definition "Whether the annotation is mandatory, recommended or optional as part of the PINK Annotation Schema"@en ;
             skos:prefLabel "conformance" .


###  https://w3id.org/pink#documentation
:documentation rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf foaf:page ;
               rdfs:domain dcat:Resource ;
               rdfs:range foaf:Document ;
               rdfs:isDefinedBy : ;
               skos:definition "A page or document documenting this resource." ;
               skos:prefLabel "documentation"@en .


###  https://w3id.org/pink#hasDatum
:hasDatum rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasPart ;
          rdf:type owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Dataset ;
          rdfs:range :Datum ;
          rdfs:isDefinedBy : ;
          skos:definition "Relates a dataset to its datum."@en ;
          skos:prefLabel "hasDatum"@en .


###  https://w3id.org/pink#hasDescription
:hasDescription rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :isRepresentedBy ;
                owl:inverseOf :isDescriptionOf ;
                rdfs:domain prov:Entity ;
                rdfs:range :Description ;
                rdfs:isDefinedBy : ;
                skos:definition "Connects an entity to a description."@en ;
                skos:prefLabel "hasDescription"@en .


###  https://w3id.org/pink#hasInput
:hasInput rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :used ;
          rdf:type owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain prov:Activity ;
          rdfs:range prov:Entity ;
          rdfs:isDefinedBy : ;
          skos:definition "Relates an activity to an entity that is input to the activity."@en ;
          skos:prefLabel "hasInput"@en ;
          skos:skopeNote "The activity A proper overlaps the entity E, where the non-overlapping part of E causes A."@en .


###  https://w3id.org/pink#hasJunctionPart
:hasJunctionPart rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasPart ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:isDefinedBy : ;
                 skos:altLabel "hasSpatioTemporalPart"@en ;
                 skos:definition "The part is connected with the rest item or members with both hasNext (or its inverse) and hasContact relations."@en ;
                 skos:prefLabel "hasJunctionPart"@en .


###  https://w3id.org/pink#hasModel
:hasModel rdf:type owl:ObjectProperty ,
                   owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain prov:Activity ;
          rdfs:range :Model ;
          rdfs:isDefinedBy : ;
          skos:definition "Relates an activity to the model it implements."@en ;
          skos:prefLabel "hasModel"@en .


###  https://w3id.org/pink#hasOutput
:hasOutput rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf [ owl:inverseOf :wasGeneratedBy
                              ] ;
           rdf:type owl:AsymmetricProperty ,
                    owl:IrreflexiveProperty ;
           rdfs:domain prov:Activity ;
           rdfs:range prov:Entity ;
           rdfs:isDefinedBy : ;
           skos:definition "Relates an activity to an entity that is the output of the activity."@en ;
           skos:prefLabel "hasOutput"@en ;
           skos:skopeNote "The activity A proper overlaps the entity E, where the non-overlapping part of E is caused by A."@en .


###  https://w3id.org/pink#hasPart
:hasPart rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf dcterms:hasPart ,
                            :overlaps ;
         rdf:type owl:ReflexiveProperty ;
         owl:propertyDisjointWith :isOvercrossedBy ;
         rdfs:isDefinedBy : ;
         skos:definition "The primitive relation that express the concept of an entity being part of another one."@en ;
         skos:prefLabel "hasPart"@en ;
         skos:skopeNote "OWL2 does not allow non-simple (e.g. transitive) properties to appear in disjoint property axioms. We therefore implement the transitivity of hasPart using SWRL rules instead of asserting it with owl:TransitiveProperty."@en .


###  https://w3id.org/pink#hasParticipant
:hasParticipant rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasPart ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:isDefinedBy : ;
                skos:definition "The relation between a process and an object participating to it, i.e. that is relevant to the process itself."@en ;
                skos:prefLabel "hasParticipant"@en ;
                skos:skopeNote "Participation is a parthood relation: you must be part of the process to contribute to it. A participant whose 4D extension is totally contained within the process."@en .


###  https://w3id.org/pink#hasProcess
:hasProcess rdf:type owl:ObjectProperty .


###  https://w3id.org/pink#hasProperty
:hasProperty rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :isRepresentedBy ;
             owl:inverseOf :isPropertyOf ;
             rdfs:domain prov:Entity ;
             rdfs:range :Property ;
             rdfs:isDefinedBy : ;
             skos:definition "Connects an entity to a property."@en ;
             skos:prefLabel "hasProperty"@en .


###  https://w3id.org/pink#hasSoftware
:hasSoftware rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :wasAssociatedWith ;
             rdf:type owl:AsymmetricProperty ,
                      owl:IrreflexiveProperty ;
             rdfs:domain :Computation ;
             rdfs:range :Software ;
             rdfs:isDefinedBy : ;
             skos:definition "Relates a computation to the software used to perform the computation."@en ;
             skos:prefLabel "hasSoftware"@en .


###  https://w3id.org/pink#hasSpatialPart
:hasSpatialPart rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasPart ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:isDefinedBy : ;
                skos:definition "A proper part of a whole, whose parts always cover the full temporal extension of the whole within a spatial interval."@en ;
                skos:prefLabel "hasSpatialPart"@en ;
                skos:skopeNote "The part is connected with the rest item or members with hasContact relations only (no hasNext)."@en .


###  https://w3id.org/pink#hasTemporalPart
:hasTemporalPart rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasPart ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:isDefinedBy : ;
                 skos:definition "A relation that identify a proper item part of the whole, whose parts always cover the full spatial extension of the whole within a time interval." ;
                 skos:prefLabel "hasTemporalPart"@en ;
                 skos:skopeNote "A temporal part of an item cannot both cause and be caused by any other proper part of the item."@en .


###  https://w3id.org/pink#hasUnit
:hasUnit rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :hasDescription ;
         rdfs:domain :Property ;
         vann:usageNote """A universal restriction should be used when referring to a unit in EMMO.  For example:

    :LethalDose50
        a pink:Toxicity , [
            a owl:Restriction ;
            owl:onProperty pink:hasUnit ;
            owl:someValuesFrom emmo:MilliGramPerKiloGram
        ] .
"""@en ;
         rdfs:isDefinedBy : ;
         skos:definition "Connects a property to its unit."@en ;
         skos:prefLabel "hasUnit"@en ;
         skos:scopeNote "`pink:hasUnit` is intended to refer to a unit in an existing unit ontology, like QUDT or EMMO."@en .


###  https://w3id.org/pink#input
:input rdf:type owl:ObjectProperty .


###  https://w3id.org/pink#isAfter
:isAfter rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :causedBy ;
         rdf:type owl:AsymmetricProperty ,
                  owl:IrreflexiveProperty ;
         rdfs:isDefinedBy : ;
         skos:definition "A one-directional relation between an entity that affects the subject."@en ;
         skos:prefLabel "isAfter"@en .


###  https://w3id.org/pink#isDescriptionOf
:isDescriptionOf rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :standsFor ;
                 rdfs:domain :Description ;
                 rdfs:range prov:Entity ;
                 rdfs:isDefinedBy : ;
                 skos:definition "Connects a description to an entity."@en ;
                 skos:prefLabel "isDescriptionOf"@en .


###  https://w3id.org/pink#isInterpretedBy
:isInterpretedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :semiotical ;
                 rdfs:domain :Sign ;
                 rdfs:range :Interpreter ;
                 rdfs:isDefinedBy : ;
                 skos:definition "Connects a sign (e.g. a property) to an interpreter."@en ;
                 skos:prefLabel "isInterpretedBy"@en .


###  https://w3id.org/pink#isOvercrossedBy
:isOvercrossedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :overlaps ;
                 rdf:type owl:IrreflexiveProperty ;
                 rdfs:isDefinedBy : ;
                 skos:definition "The relation between an entity that overlaps another without having it as part."@en ;
                 skos:prefLabel "isOvercrossedBy"@en .


###  https://w3id.org/pink#isPropertyOf
:isPropertyOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :standsFor ;
              rdfs:domain :Property ;
              rdfs:range prov:Entity ;
              rdfs:isDefinedBy : ;
              skos:definition "Connects a property to an entity."@en ;
              skos:prefLabel "isPropertyOf"@en .


###  https://w3id.org/pink#isRepresentedBy
:isRepresentedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :semiotical ;
                 owl:inverseOf :standsFor ;
                 rdfs:domain prov:Entity ;
                 rdfs:range :Sign ;
                 rdfs:isDefinedBy : ;
                 skos:definition "Connects an entity to a sign that stands for the entity."@en ;
                 skos:prefLabel "isRepresentedBy"@en .


###  https://w3id.org/pink#nonOverlaps
:nonOverlaps rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ,
                      owl:IrreflexiveProperty ;
             owl:propertyDisjointWith :overlaps ;
             rdfs:isDefinedBy : ;
             skos:definition "The relation between two individuals that does not share any parts."@en ;
             skos:prefLabel "nonOverlaps"@en .


###  https://w3id.org/pink#output
:output rdf:type owl:ObjectProperty .


###  https://w3id.org/pink#overlaps
:overlaps rdf:type owl:ObjectProperty ,
                   owl:SymmetricProperty ,
                   owl:ReflexiveProperty ;
          rdfs:isDefinedBy : ;
          skos:definition "The relation between two individuals representing entities that share at least one of their parts."@en ;
          skos:prefLabel "overlaps"@en .


###  https://w3id.org/pink#participatesTo
:participatesTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :isOvercrossedBy ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:domain prov:Entity ;
                rdfs:range prov:Activity ;
                rdfs:isDefinedBy : ;
                skos:definition "Relation an entity to an activity that it interacts with."@en ;
                skos:prefLabel "participatesTo"@en ;
                skos:skopeNote "The entity through overlaps the activity."@en .


###  https://w3id.org/pink#priorRelease
:priorRelease rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :causedBy ;
              rdf:type owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:domain :Software ;
              rdfs:range :Software ;
              rdfs:isDefinedBy : ;
              skos:definition "Direct relation that relates a software to the most resent earlier release of the software."@en ;
              skos:prefLabel "priorRelease"@en ;
              skos:skopeNote "Useful for tracking the provenance of software releases."@en .


###  https://w3id.org/pink#processedFrom
:processedFrom rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAfter ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:isDefinedBy : ;
               skos:definition "Indirect relation that relates the output of an activity to its input."@en ;
               skos:prefLabel "processedFrom"@en .


###  https://w3id.org/pink#semiotical
:semiotical rdf:type owl:ObjectProperty ;
            rdfs:isDefinedBy : ;
            skos:definition "The base of all semiotic relations."@en ;
            skos:prefLabel "semiotical"@en ;
            skos:skopeNote "Semiotic relations can be seen as shortcuts that replaces a series of complex causal relations with a single relation."@en ,
                           "Semiotic relations take part in a triadic semiotic meaning-making process, where an 'interpreter' connects a 'sign' (e.g. a property) to an entity (called 'referent')."@en ,
                           "The semiotic relations in the PINK Annotation Scheme are inspirred by EMMO, which in turn is based on the semiotic theory by Charles Sanders Peirce (1839-1914)."@en .


###  https://w3id.org/pink#ssbdDimension
:ssbdDimension rdf:type owl:ObjectProperty ;
               rdfs:range :SsbdDimension ;
               vann:usageNote "One of `pink:functionality`, `pink:safety`, `pink:environmental_sustainability`, `pink:social_sustainability`"@en ;
               rdfs:isDefinedBy : ;
               skos:definition "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
               skos:prefLabel "ssbdDimension"@en .


###  https://w3id.org/pink#standsFor
:standsFor rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :semiotical ;
           rdfs:domain :Sign ;
           rdfs:range prov:Entity ;
           rdfs:isDefinedBy : ;
           skos:definition "Connects a sign (e.g. a property) to an entity (a 'referent')."@en ;
           skos:prefLabel "standsFor"@en .


###  https://w3id.org/pink#used
:used rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf prov:used ,
                         :isOvercrossedBy ;
      rdf:type owl:AsymmetricProperty ,
               owl:IrreflexiveProperty ;
      rdfs:domain prov:Activity ;
      rdfs:range prov:Entity ;
      rdfs:isDefinedBy : ;
      skos:definition "Relates an activity to an entity that it used."@en ;
      skos:example "For example, :baking :used :spoon, :egg, :oven ." ;
      skos:prefLabel "used"@en ;
      skos:skopeNote "The activity A proper overlaps the entity E, where the non-overlapping part of E causes A."@en .


###  https://w3id.org/pink#wasAssociatedWith
:wasAssociatedWith rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf prov:wasAssociatedWith ,
                                      :isOvercrossedBy ;
                   rdf:type owl:AsymmetricProperty ,
                            owl:IrreflexiveProperty ;
                   rdfs:domain prov:Activity ;
                   rdfs:range prov:Agent ;
                   rdfs:isDefinedBy : ;
                   skos:definition "Relates an activity to an agent that had some (unspecified) responsibility for the occurence of this activity."@en ;
                   skos:prefLabel "wasAssociatedWith"@en ;
                   skos:skopeNote "The activity is through overlapped by the agent."@en .


###  https://w3id.org/pink#wasAttributedTo
:wasAttributedTo rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf prov:wasAttributedTo ,
                                    :causedBy ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:domain prov:Entity ;
                 rdfs:range prov:Agent ;
                 rdfs:isDefinedBy : ;
                 skos:definition "Relates an entity to an agent via an activity that both the entity and agent participates to."@en ;
                 skos:prefLabel "wasAttributedTo"@en ;
                 skos:skopeNote "The activity is through overlapped by the agent and overcrossed by the entity."@en .


###  https://w3id.org/pink#wasDerivedBy
:wasDerivedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf prov:wasDerivedBy ,
                                 :processedFrom ;
              rdf:type owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:domain prov:Entity ;
              rdfs:range prov:Entity ;
              rdfs:isDefinedBy : ;
              skos:definition "Indirect relation that relates the output entity of an activity to its input entity."@en ;
              skos:prefLabel "wasDerivedBy"@en .


###  https://w3id.org/pink#wasGeneratedBy
:wasGeneratedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf prov:wasGeneratedBy ,
                                   :isOvercrossedBy ;
                rdf:type owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:domain prov:Entity ;
                rdfs:range prov:Activity ;
                rdfs:isDefinedBy : ;
                skos:definition "Relates an entity to the activity it was generated from."@en ;
                skos:prefLabel "wasGeneratedBy"@en ;
                skos:skopeNote "The activity A proper overlaps the entity E, where the non-overlapping part of E is caused by A."@en .


###  https://w3id.org/pink#wasInformedBy
:wasInformedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf prov:wasInformedBy ,
                                  :isAfter ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:domain prov:Activity ;
               rdfs:range prov:Activity ;
               rdfs:isDefinedBy : ;
               skos:definition "A one-directional relation between an activity that affects the subject activity."@en ;
               skos:prefLabel "wasInformedBy"@en .


#################################################################
#    Data properties
#################################################################

###  http://data.europa.eu/r5r/availability
ns2:availability rdf:type owl:DatatypeProperty ;
                 rdfs:domain dcat:Distribution ;
                 rdfs:range xsd:datetime .


###  http://purl.org/dc/terms/accrualPeriodicity
dcterms:accrualPeriodicity rdf:type owl:DatatypeProperty ;
                           rdfs:range dcterms:Frequency .


###  http://purl.org/dc/terms/format
dcterms:format rdf:type owl:DatatypeProperty ;
               rdfs:range dcterms:MediaTypeOrExtent .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:DatatypeProperty ;
               rdfs:domain dcat:Resource ;
               rdfs:range xsd:dateTime ,
                          xsd:datetime .


###  http://purl.org/dc/terms/language
dcterms:language rdf:type owl:DatatypeProperty ;
                 rdfs:domain dcat:Resource ;
                 rdfs:range xsd:string .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:DatatypeProperty ;
                 rdfs:domain dcat:Resource ;
                 rdfs:range xsd:datetime .


###  http://purl.org/dc/terms/temporal
dcterms:temporal rdf:type owl:DatatypeProperty ;
                 rdfs:range dcterms:PeriodOfTime .


###  http://spdx.org/rdf/terms#checksumValue
<http://spdx.org/rdf/terms#checksumValue> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <http://spdx.org/rdf/terms#Checksum> ;
                                          rdfs:range xsd:hexBinary .


###  http://www.w3.org/ns/adms#identifier
<http://www.w3.org/ns/adms#identifier> rdf:type owl:DatatypeProperty ;
                                       rdfs:range <http://www.w3.org/ns/adms#Identifier> .


###  http://www.w3.org/ns/dcat#byteSize
dcat:byteSize rdf:type owl:DatatypeProperty ;
              rdfs:domain dcat:Distribution ;
              rdfs:range xsd:nonNegativeInteger .


###  http://www.w3.org/ns/dcat#downloadURL
dcat:downloadURL rdf:type owl:DatatypeProperty ;
                 rdfs:domain dcat:Distribution ;
                 rdfs:range xsd:anyURI .


###  http://www.w3.org/ns/dcat#endpointURL
dcat:endpointURL rdf:type owl:DatatypeProperty ;
                 rdfs:domain dcat:DataService ;
                 rdfs:range xsd:anyURI .


###  http://www.w3.org/ns/dcat#hasRole
dcat:hasRole rdf:type owl:DatatypeProperty ;
             rdfs:range dcat:Role .


###  http://www.w3.org/ns/dcat#spatialResolutionInMeters
dcat:spatialResolutionInMeters rdf:type owl:DatatypeProperty ;
                               rdfs:domain dcat:Dataset ;
                               rdfs:range xsd:decimal .


###  http://www.w3.org/ns/dcat#temporalResolution
dcat:temporalResolution rdf:type owl:DatatypeProperty ;
                        rdfs:domain dcat:Dataset ;
                        rdfs:range xsd:duration .


###  http://xmlns.com/foaf/0.1/name
foaf:name rdf:type owl:DatatypeProperty ;
          rdfs:domain foaf:Agent ;
          rdfs:range xsd:string .


###  https://w3id.org/emmo/application/datadoc#curationDate
ns1:curationDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain dcat:Resource ;
                 rdfs:range xsd:datetime .


###  https://w3id.org/emmo/domain/oteio#hasConfiguration
<https://w3id.org/emmo/domain/oteio#hasConfiguration> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <https://w3id.org/emmo/domain/oteio#Parser> ;
                                                      rdfs:range rdf:JSON .


###  https://w3id.org/emmo/domain/oteio#hasDatamodel
<https://w3id.org/emmo/domain/oteio#hasDatamodel> rdf:type owl:DatatypeProperty ;
                                                  rdfs:range <https://w3id.org/emmo/domain/oteio#Datamodel> .


###  https://w3id.org/emmo/domain/oteio#hasDatamodelStorage
<https://w3id.org/emmo/domain/oteio#hasDatamodelStorage> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain dcat:Dataset ;
                                                         rdfs:range xsd:anyURI .


###  https://w3id.org/emmo/domain/oteio#mapping
<https://w3id.org/emmo/domain/oteio#mapping> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain dcat:Dataset ;
                                             rdfs:range rdf:JSON .


###  https://w3id.org/emmo/domain/oteio#mappingURL
<https://w3id.org/emmo/domain/oteio#mappingURL> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain dcat:Dataset ;
                                                rdfs:range xsd:anyURI .


###  https://w3id.org/emmo/domain/oteio#statement
<https://w3id.org/emmo/domain/oteio#statement> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain dcat:Resource ;
                                               rdfs:range rdf:JSON .


###  https://w3id.org/pink#hasAPI
:hasAPI rdf:type owl:DatatypeProperty ;
        rdfs:domain :Software ;
        rdfs:range xsd:boolean ;
        rdfs:isDefinedBy : ;
        skos:definition "Whether the software has an API." ;
        skos:prefLabel "hasAPI"@en .


###  https://w3id.org/pink#ssbdSubDimension
:ssbdSubDimension rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  rdfs:isDefinedBy : ;
                  skos:definition "Note this class redefined in PR https://github.com/PINK-project/PINK-annotation-schema/pull/15"@en ;
                  skos:prefLabel "ssbdSubDimension"@en .


#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/eli/ontology#LegalResource
<http://data.europa.eu/eli/ontology#LegalResource> rdf:type owl:Class ;
                                                   rdfs:subClassOf foaf:Document ;
                                                   vann:usageNote "The definition and properties of the Legal Resource class are aligned with the ontology included in \"Council conclusions inviting the introduction of the European Legislation Identifier (ELI)\". For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the (ELI) ontology. In this data specification the use is restricted to instances of this class that follow the (ELI) URI guidelines." ;
                                                   rdfs:isDefinedBy ns1: ;
                                                   skos:definition "This class represents the legislation, policy or policies that lie behind the Rules that govern the service." .


###  http://purl.org/dc/terms/LicenseDocument
dcterms:LicenseDocument rdf:type owl:Class ;
                        rdfs:subClassOf dcterms:RightsStatement .


###  http://purl.org/dc/terms/Location
dcterms:Location rdf:type owl:Class ;
                 rdfs:subClassOf rdfs:Resource ;
                 vann:usageNote "It can be represented using a controlled vocabulary or with geographic coordinates. In the latter case, the use of the Core Location Vocabulary is recommended, following the approach described in the GeoDCAT-AP specification." ;
                 rdfs:isDefinedBy ns1: ;
                 skos:definition "A spatial region or named place." .


###  http://purl.org/dc/terms/MediaType
dcterms:MediaType rdf:type owl:Class ;
                  rdfs:subClassOf rdfs:Resource ;
                  vann:usageNote "Media type instances follow the [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) vocabulary using the <http://www.iana.org/assignments/media-types/> namespace. For example, the IRI of the media type `text/turtle` is <http://www.iana.org/assignments/media-types/text/turtle>." ;
                  rdfs:isDefinedBy ns1: ;
                  skos:definition "A media type, e.g. the format of a computer file." .


###  http://purl.org/dc/terms/RightsStatement
dcterms:RightsStatement rdf:type owl:Class ;
                        rdfs:subClassOf foaf:Document .


###  http://purl.org/dc/terms/Standard
dcterms:Standard rdf:type owl:Class ;
                 rdfs:subClassOf rdfs:Resource ;
                 rdfs:isDefinedBy ns1: ;
                 skos:definition "A standard or other specification to which a resource conforms." .


###  http://spdx.org/rdf/terms#Checksum
<http://spdx.org/rdf/terms#Checksum> rdf:type owl:Class ;
                                     rdfs:subClassOf rdfs:Resource ;
                                     rdfs:isDefinedBy ns1: ;
                                     skos:definition "A preferred label of the concept." .


###  http://spdx.org/rdf/terms#ChecksumAlgorithm
<http://spdx.org/rdf/terms#ChecksumAlgorithm> rdf:type owl:Class ;
                                              rdfs:subClassOf rdfs:Resource ;
                                              vann:usageNote "This specification does not impose any additional requirements to properties for this entity." ;
                                              rdfs:isDefinedBy ns1: ;
                                              skos:definition "Algorithm for Checksums." .


###  http://www.w3.org/2000/01/rdf-schema#Datatype
rdfs:Datatype rdf:type owl:Class ;
              rdfs:subClassOf rdfs:Resource .


###  http://www.w3.org/2000/01/rdf-schema#Resource
rdfs:Resource rdf:type owl:Class ;
              rdfs:isDefinedBy ns1: ;
              skos:definition "A generic resource defined by RDFS." .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             rdfs:subClassOf rdfs:Resource ;
             vann:usageNote "In DCAT-AP, a Concept is used to denote codes within a codelist. See [DCAT-AP](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#controlled-vocs) for expectations and more detail." ;
             rdfs:isDefinedBy ns1: ;
             skos:definition "An idea or notion; a unit of thought." .


###  http://www.w3.org/2006/vcard/ns#Kind
<http://www.w3.org/2006/vcard/ns#Kind> rdf:type owl:Class ;
                                       rdfs:subClassOf rdfs:Resource ;
                                       vann:usageNote "Note that the class Kind is the parent class for the four explicit types of vCard (Individual, Organization, Location, Group)." ;
                                       rdfs:isDefinedBy ns1: ;
                                       skos:definition "A description following the vCard specification, e.g. to provide telephone number and e-mail address for a contact point." .


###  http://www.w3.org/ns/dcat#DataService
dcat:DataService rdf:type owl:Class ;
                 rdfs:subClassOf dcat:Resource ;
                 rdfs:isDefinedBy ns1: ;
                 skos:definition "A collection of operations that provides access to one or more datasets or data processing functions." .


###  http://www.w3.org/ns/dcat#Dataset
dcat:Dataset rdf:type owl:Class ;
             rdfs:subClassOf dcat:Resource ;
             vann:usageNote "This class represents the actual dataset as published by the dataset provider. In cases where a distinction between the actual dataset and its entry in the catalog is necessary (because metadata such as modification date and maintainer might differ), the catalog record class can be used for the latter." ;
             rdfs:isDefinedBy ns1: ;
             skos:definition "A collection of data, published or curated by an agent, and available for access or download in one or more representations." .


###  http://www.w3.org/ns/dcat#DatasetSeries
dcat:DatasetSeries rdf:type owl:Class ;
                   rdfs:subClassOf dcat:Dataset ;
                   rdfs:isDefinedBy ns1: ;
                   skos:definition "A collection of datasets that are published separately, but share some characteristics that group them." .


###  http://www.w3.org/ns/dcat#Distribution
dcat:Distribution rdf:type owl:Class ;
                  rdfs:subClassOf dcat:Resource ;
                  vann:usageNote "This represents a general availability of a dataset. It implies no information about the actual access method of the data, i.e., whether by direct download, API, or through a Web page. The use of dcat:downloadURL property indicates directly downloadable distributions." ;
                  rdfs:isDefinedBy ns1: ;
                  skos:definition "A physical embodiment of the Dataset in a particular format." .


###  http://www.w3.org/ns/dcat#Relationship
dcat:Relationship rdf:type owl:Class ;
                  rdfs:subClassOf rdfs:Resource ;
                  rdfs:isDefinedBy ns1: ;
                  skos:definition "An association class for attaching additional information to a relationship between DCAT Resources." .


###  http://www.w3.org/ns/dcat#Resource
dcat:Resource rdf:type owl:Class ;
              rdfs:subClassOf prov:Entity ;
              rdfs:comment "Resource published or curated by a single agent."@en ;
              rdfs:isDefinedBy <https://w3id.org/pink/reused-terms#> ;
              rdfs:label "Resource"@en ;
              skos:definition "Resource published or curated by an agent." ;
              skos:scopeNote "The class of all catalogued resources, the Superclass of dcat:Dataset, dcat:DataService, dcat:Catalog and any other member of a dcat:Catalog. This class carries properties common to all catalogued resources, including datasets and data services. The instances of this class SHOULD be included in a catalog. The instances of this class SHOULD be included in a catalog. It is strongly recommended to use a more specific sub-class. When describing a resource which is not a dcat:Dataset or dcat:DataService, it is recommended to create a suitable sub-class of dcat:Resource, or use dcat:Resource with the dcterms:type property to indicate the specific type."@en .


###  http://www.w3.org/ns/locn#Geometry
locn:Geometry rdf:type owl:Class ;
              rdfs:subClassOf rdfs:Resource ;
              vann:usageNote "This specification does not impose any additional requirements to properties for this entity." ;
              rdfs:isDefinedBy ns1: ;
              skos:definition "The locn:Geometry class provides the means to identify a location as a point, line, polygon, etc. expressed using coordinates in some coordinate reference system." .


###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class ;
              rdfs:subClassOf rdfs:Resource ;
              owl:disjointWith prov:Entity ;
              rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                               : ;
              rdfs:label "Activity" ;
              prov:category "starting-point" ;
              prov:component "entities-activities" ;
              prov:constraints "http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#prov-dm-constraints-fig"^^xsd:anyURI ;
              prov:definition "An activity is something that occurs over a period of time and acts upon or with entities; it may include consuming, processing, transforming, modifying, relocating, using, or generating entities." ;
              prov:dm "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-Activity"^^xsd:anyURI ;
              prov:n "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-Activity"^^xsd:anyURI .


###  http://www.w3.org/ns/prov#Agent
prov:Agent rdf:type owl:Class ;
           rdfs:subClassOf foaf:Agent ;
           rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                            ns1: ;
           rdfs:label "Agent" ;
           prov:category "starting-point" ;
           prov:component "agents-responsibility" ;
           prov:definition "An agent is something that bears some form of responsibility for a activity taking place, for the existence of an entity, or for another agent's aprovctivity. "@en ;
           prov:dm "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-agent"^^xsd:anyURI ;
           prov:n "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-Agent"^^xsd:anyURI .


###  http://www.w3.org/ns/prov#Attribution
prov:Attribution rdf:type owl:Class ;
                 rdfs:subClassOf prov:Agent ;
                 vann:usageNote "See [explanations and examples in W3C/DCAT](https://www.w3.org/TR/vocab-dcat-3/#qualified-attribution)." ;
                 rdfs:isDefinedBy ns1: ;
                 skos:definition "An agent that has some form of responsibility for a resource, but which is not a publisher nor a creator of the resource." .


###  http://www.w3.org/ns/prov#Entity
prov:Entity rdf:type owl:Class ;
            rdfs:subClassOf rdfs:Resource ;
            owl:disjointWith prov:InstantaneousEvent ;
            rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ,
                             : ;
            rdfs:label "Entity" ;
            prov:category "starting-point" ;
            prov:component "entities-activities" ;
            prov:constraints "http://www.w3.org/TR/2013/REC-prov-constraints-20130430/#prov-dm-constraints-fig"^^xsd:anyURI ;
            prov:definition "An entity is a physical, digital, conceptual, or other kind of thing with some fixed aspects; entities may be real or imaginary. "@en ;
            prov:dm "http://www.w3.org/TR/2013/REC-prov-dm-20130430/#term-entity"^^xsd:anyURI ;
            prov:n "http://www.w3.org/TR/2013/REC-prov-n-20130430/#expression-Entity"^^xsd:anyURI .


###  http://www.w3.org/ns/prov#InstantaneousEvent
prov:InstantaneousEvent rdf:type owl:Class ;
                        rdfs:subClassOf rdfs:Resource .


###  http://xmlns.com/foaf/0.1/Agent
foaf:Agent rdf:type owl:Class ;
           rdfs:subClassOf rdfs:Resource ;
           vann:usageNote "A resource that acts or has the power to act." ;
           rdfs:isDefinedBy ns1: ;
           skos:definition "An agent (eg. person, group, software or physical artifact)." .


###  http://xmlns.com/foaf/0.1/Document
foaf:Document rdf:type owl:Class ;
              rdfs:subClassOf :Data ;
              owl:disjointWith foaf:Organization ,
                               foaf:Project ;
              vann:usageNote "The Document class represents those things which are, broadly conceived, 'documents'. E.g. images." ;
              rdfs:comment "A document." ;
              rdfs:isDefinedBy <http://xmlns.com/foaf/0.1> ,
                               <https://w3id.org/pink/reused-terms#> ;
              rdfs:label "Document" ;
              skos:definition "A document." .


###  http://xmlns.com/foaf/0.1/Organization
foaf:Organization rdf:type owl:Class ;
                  rdfs:subClassOf :Object .


###  http://xmlns.com/foaf/0.1/Person
foaf:Person rdf:type owl:Class ;
            rdfs:subClassOf :Object .


###  http://xmlns.com/foaf/0.1/Project
foaf:Project rdf:type owl:Class ;
             rdfs:subClassOf prov:Entity .


###  https://w3id.org/emmo/application/datadoc#ConformanceLevel
ns1:ConformanceLevel rdf:type owl:Class ;
                     owl:equivalentClass [ rdf:type owl:Class ;
                                           owl:oneOf ( ns1:mandatory
                                                       ns1:optional
                                                       ns1:recommended
                                                     )
                                         ] ;
                     rdfs:subClassOf foaf:Document ;
                     rdfs:isDefinedBy ns1: ;
                     skos:definition "The class of conformance levels. Includes the following individuals: `ddoc:mandatory`, `ddoc:recommended` and `ddoc:optional`."@en ;
                     skos:prefLabel "ConformanceLevel"@en .


###  https://w3id.org/emmo/domain/oteio#Generator
<https://w3id.org/emmo/domain/oteio#Generator> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/emmo/domain/oteio#Parser> ;
                                               rdfs:isDefinedBy ns1: ;
                                               skos:definition "A generator that can serialise an instance of a datamodel into a distribution." .


###  https://w3id.org/emmo/domain/oteio#Parser
<https://w3id.org/emmo/domain/oteio#Parser> rdf:type owl:Class ;
                                            rdfs:subClassOf rdfs:Resource ;
                                            rdfs:isDefinedBy ns1: ;
                                            skos:definition "A parser that can parse a distribution into an instance of a datamodel." .


###  https://w3id.org/emmo/hume#AIModel
<https://w3id.org/emmo/hume#AIModel> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/emmo/hume#DataBasedModel> ;
                                     rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                     skos:altLabel "ArtificialIntelligenceModel"@en ;
                                     skos:definition "An AI-based model."@en ;
                                     skos:prefLabel "AIModel"@en .


###  https://w3id.org/emmo/hume#AmorphousMaterial
<https://w3id.org/emmo/hume#AmorphousMaterial> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByStructure> ;
                                               rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                               skos:altLabel "NonCrystallineMaterial"@en ;
                                               skos:definition "A solid lacking a repeating, ordered atomic structure (long-range order)."@en ;
                                               skos:prefLabel "AmorphousMaterial"@en ;
                                               skos:scopeNote "A amorphous material resembles a frozen liquid with atoms arranged randomly, unlike crystalline solids with periodic patterns, leading to properties like no sharp melting point, irregular shapes, and isotropic characteristics (uniform properties in all directions)."@en .


###  https://w3id.org/emmo/hume#AnalogicalIcon
<https://w3id.org/emmo/hume#AnalogicalIcon> rdf:type owl:Class ;
                                            rdfs:subClassOf :Model ;
                                            rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                            skos:altLabel "AnalogicalIcon"@en ;
                                            skos:definition "A model that represents the internal logical structure of the object."@en ;
                                            skos:example "A physics equation is replicating the mechanisms internal to the object."@en ,
                                                         "Electrical diagram is diagrammatic and resemblance"@en ,
                                                         "MODA and CHADA are diagrammatic representation of a simulation or a characterisation workflow."@en ;
                                            skos:prefLabel "AnalogicalModel"@en ;
                                            skos:scopeNote "A model that focus on HOW the object works."@en ,
                                                           "The subclass of model inspired by Peirceian category (b) the diagram, whose internal relations, mainly dyadic or so taken, represent by analogy (with the same logic) the relations in something (e.g. math formula, geometric flowchart)."@en .


###  https://w3id.org/emmo/hume#ArtificialMaterial
<https://w3id.org/emmo/hume#ArtificialMaterial> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByOrigin> ;
                                                rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                                skos:definition "Any substance engineered or created by humans, often to mimic or improve upon natural materials."@en ;
                                                skos:prefLabel "ArtificialMaterial"@en ;
                                                skos:scopeNote "Artificial materials are typically engineered through chemical synthesis from natural raw materials like oil or coal, resulting in polymers such as plastics, nylon, or polyester, designed for specific, enhanced properties like strength, durability, or moldability not found in nature."@en .


###  https://w3id.org/emmo/hume#Atom
<https://w3id.org/emmo/hume#Atom> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://w3id.org/emmo/hume#MolecularEntity> ;
                                  rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                  skos:altLabel "ChemicalElement"@en ;
                                  skos:definition """A standalone atom has direct part one 'nucleus' and one 'electron_cloud'.

An O 'atom' within an O₂ 'molecule' is an 'e-bonded_atom'.

In this material branch, H atom is a particular case, with respect to higher atomic number atoms, since as soon as it shares its electron it has no nucleus entangled electron cloud.

We cannot say that H₂ molecule has direct part two H atoms, but has direct part two H nucleus."""@en ;
                                  skos:prefLabel "Atom"@en ;
                                  ns4:scopeNote "An 'atom' is a 'nucleus' surrounded by an 'electron_cloud', i.e. a quantum system made of one or more bounded electrons."@en .


###  https://w3id.org/emmo/hume#BondedAtom
<https://w3id.org/emmo/hume#BondedAtom> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/emmo/hume#Atom> ;
                                        rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                        skos:definition "A bonded atom that shares at least one electron to the atom-based entity of which is part of."@en ;
                                        skos:prefLabel "BondedAtom"@en ;
                                        skos:scopeNote """A real bond between atoms is always something hybrid between covalent, metallic and ionic.

In general, metallic and ionic bonds have atoms sharing electrons."""@en ,
                                                       "The bond types that are covered by this definition are the strong electronic bonds: covalent, metallic and ionic."@en ,
                                                       "This class can be used to represent molecules as simplified quantum systems, in which outer molecule shared electrons are un-entangled with the inner shells of the atoms composing the molecule."@en .


###  https://w3id.org/emmo/hume#CeramicMaterial
<https://w3id.org/emmo/hume#CeramicMaterial> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByType> ;
                                             rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                             skos:altLabel "Ceramic"@en ;
                                             skos:definition "An inorganic non-metallic solid made from elements (metals, non-metals, semi-metals like silicon) combined into compounds (oxides, carbides, nitrides) that are typically hard, strong, brittle, corrosion-resistant, and good insulators."@en ;
                                             skos:prefLabel "CeramicMaterial"@en ;
                                             skos:scopeNote "Ceramic materials are hardened by intense heat and typically used from pottery and tiles to advanced electronics and aerospace parts."@en .


###  https://w3id.org/emmo/hume#ChemicalCompound
<https://w3id.org/emmo/hume#ChemicalCompound> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/emmo/hume#ChemicalSubstance> ;
                                              rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                              rdfs:seeAlso "https://en.wikipedia.org/wiki/Chemical_compound" ;
                                              skos:definition "A chemical substance composed of many identical molecules (or molecular entities) composed of atoms from more than one element held together by chemical bonds." ;
                                              skos:prefLabel "ChemicalCompound"@en .


###  https://w3id.org/emmo/hume#ChemicalEntity
<https://w3id.org/emmo/hume#ChemicalEntity> rdf:type owl:Class ;
                                            rdfs:subClassOf :Matter ;
                                            rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                            skos:definition "The union of ChemicalSubstance and MolecularEntity."@en ;
                                            skos:prefLabel "ChemicalEntity"@en ;
                                            skos:scopeNote """A chemical entity comprises the two different ways to represents matter: as single recognizable particle entity (molecular entity) and as a composition of particle entities (substance).

This distinction is not well assessed in actual chemical nomenclature, in which an element name refers to both the pure elemental substance or the atom.

In the EMMO we force the adoption of a more strict categorization based on mereotopology.

The class Material hosts the subclasses for which a substance can be identified without necessarily considering its nature of molecule/atom or substance (e.g. hydrocarbon is the class of both hydrocarbon molecules or gases).""" .


###  https://w3id.org/emmo/hume#ChemicalSubstance
<https://w3id.org/emmo/hume#ChemicalSubstance> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/emmo/hume#ChemicalEntity> ,
                                                               <https://w3id.org/emmo/hume#Substance> ;
                                               owl:disjointWith <https://w3id.org/emmo/hume#MolecularEntity> ;
                                               rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                               rdfs:seeAlso "https://doi.org/10.1351/goldbook.C01039" ;
                                               skos:definition "Matter of constant composition best characterized by the entities (molecules, formula units, atoms) it is composed of." ;
                                               skos:prefLabel "ChemicalSubstance"@en ;
                                               skos:scopeNote "A substance is always composed of more than one molecular entity. It lays in the continuum or mesoscopic domain."@en .


###  https://w3id.org/emmo/hume#CompactMaterial
<https://w3id.org/emmo/hume#CompactMaterial> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByCompactness> ,
                                                             <https://w3id.org/emmo/hume#Solid> ;
                                             rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                             skos:definition "A solid material whose particles are closely and firmly packed together, resulting in a high density, solid structure without significant internal voids or cavities."@en ;
                                             skos:prefLabel "CompactMaterial"@en .


###  https://w3id.org/emmo/hume#CompositeMaterial
<https://w3id.org/emmo/hume#CompositeMaterial> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByType> ;
                                               rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                               skos:altLabel "Composite"@en ;
                                               skos:definition "A material that contains two or more constituent materials."@en ;
                                               skos:prefLabel "CompositeMaterial"@en .


###  https://w3id.org/emmo/hume#CondensedMatter
<https://w3id.org/emmo/hume#CondensedMatter> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/emmo/hume#StateOfMatter> ;
                                             rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                             skos:definition "Solid or liquid matter."@en ;
                                             skos:prefLabel "CondensedMatter"@en ;
                                             skos:scopeNote "The subject of condensed matter physics that deals with the macroscopic and microscopic physical properties of matter, especially the solid and liquid phases which arise from electromagnetic forces between atoms. More generally, the subject deals with \"condensed\" phases of matter: systems of many constituents with strong interactions between them."@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <https://w3id.org/emmo/hume#CondensedMatter> ;
   owl:annotatedProperty skos:scopeNote ;
   owl:annotatedTarget "The subject of condensed matter physics that deals with the macroscopic and microscopic physical properties of matter, especially the solid and liquid phases which arise from electromagnetic forces between atoms. More generally, the subject deals with \"condensed\" phases of matter: systems of many constituents with strong interactions between them."@en ;
   rdfs:seeAlso "https://en.wikipedia.org/wiki/Condensed_matter_physics"@en
 ] .


###  https://w3id.org/emmo/hume#ContinuumSubstance
<https://w3id.org/emmo/hume#ContinuumSubstance> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/emmo/hume#Substance> ;
                                                owl:disjointWith <https://w3id.org/emmo/hume#MesoscopicSubstance> ;
                                                rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                                skos:definition """A state that is a collection of sufficiently large number of other parts such that:
- it is the bearer of qualities that can exists only by the fact that it is a sum of parts
- the smallest partition dV of the state volume in which we are interested in, contains enough parts to be statistically consistent: n [#/m3] x dV [m3] >> 1"""@en ;
                                                skos:prefLabel "ContinuumSubstance"@en ;
                                                skos:scopeNote "A continuum is made of a sufficient number of parts that it continues to exists as continuum individual even after the loss of one of them i.e. a continuum is a redundant."@en ,
                                                               """A continuum is not necessarily small (i.e. composed by the minimum amount of sates to fulfill the definition).

A single continuum individual can be the whole fluid in a pipe."""@en ,
                                                               "A continuum is the bearer of properties that are generated by the interactions of parts such as viscosity and thermal or electrical conductivity."@en .


###  https://w3id.org/emmo/hume#CrystallineMaterial
<https://w3id.org/emmo/hume#CrystallineMaterial> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByStructure> ,
                                                                 <https://w3id.org/emmo/hume#Solid> ;
                                                 rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                                 skos:definition "A solid where atoms, ions, or molecules are arranged in a highly ordered, repeating, three-dimensional pattern, forming a crystal lattice that extends throughout the substance, giving it characteristic geometric shapes and distinct physical properties like sharp melting points, unlike amorphous solids with random structures."@en ;
                                                 skos:prefLabel "CrystallineMaterial"@en .


###  https://w3id.org/emmo/hume#DataBasedModel
<https://w3id.org/emmo/hume#DataBasedModel> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/emmo/hume#MathematicalModel> ;
                                            rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                            skos:definition "A mathematical model based on observed data, measurements, or experimental results."@en ;
                                            skos:prefLabel "DataBasedModel"@en .


###  https://w3id.org/emmo/hume#DataProcessing
<https://w3id.org/emmo/hume#DataProcessing> rdf:type owl:Class ;
                                            rdfs:subClassOf :Computation ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :hasModel ;
                                                              owl:someValuesFrom <https://w3id.org/emmo/hume#MathematicalModel>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :hasParticipant ;
                                                              owl:someValuesFrom <https://w3id.org/emmo/hume#DataProcessingSoftware>
                                                            ] ;
                                            rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                            skos:definition "A computation that provides a data output following the elaboration of some input data, using a data processing application."@en ;
                                            skos:prefLabel "DataProcessing"@en .


###  https://w3id.org/emmo/hume#DataProcessingSoftware
<https://w3id.org/emmo/hume#DataProcessingSoftware> rdf:type owl:Class ;
                                                    rdfs:subClassOf :Software ;
                                                    rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                                    skos:altLabel "DataProcessingApplication"@en ;
                                                    skos:definition "A software program aimed for data processing."@en ;
                                                    skos:prefLabel "DataProcessingSoftware"@en .


###  https://w3id.org/emmo/hume#ElementalSubstance
<https://w3id.org/emmo/hume#ElementalSubstance> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/emmo/hume#ChemicalSubstance> ;
                                                rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                                rdfs:seeAlso "https://doi.org/10.1351/goldbook.C01022" ;
                                                skos:altLabel "PureSubstance"@en ;
                                                skos:definition "A chemical substance composed of atoms with the same number of protons in the atomic nucleus."@en ;
                                                skos:prefLabel "ElementalSubstance"@en .


###  https://w3id.org/emmo/hume#Fluid
<https://w3id.org/emmo/hume#Fluid> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/emmo/hume#StateOfMatter> ;
                                   rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                   skos:definition "A continuum that has no fixed shape and yields easily to external pressure."@en ;
                                   skos:example "Gas, liquid, plasma,"@en ;
                                   skos:prefLabel "Fluid"@en .


###  https://w3id.org/emmo/hume#FunctionalIcon
<https://w3id.org/emmo/hume#FunctionalIcon> rdf:type owl:Class ;
                                            rdfs:subClassOf :Model ;
                                            rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                            skos:altLabel "FunctionalIcon"@en ;
                                            skos:definition "A model that imitates one representative character of the object. It share external similarities with the object, but not necessarily the same internal logical structure."@en ;
                                            skos:example "A data based model is only a functional model, since it provide the same relations between the properties of the object (e.g., it can predict some properties as function of others) but is not considering the internal mechanisms (i.e., it can ignore the physics)."@en ;
                                            skos:prefLabel "FunctionalModel"@en ;
                                            skos:scopeNote "A model that focusing WHAT the object does."@en ,
                                                           "This subclass of model inspired by Peirceian category (c) the metaphor, which represents the representative character of a sign by representing a parallelism in something else."@en .


###  https://w3id.org/emmo/hume#Gas
<https://w3id.org/emmo/hume#Gas> rdf:type owl:Class ;
                                 rdfs:subClassOf <https://w3id.org/emmo/hume#Fluid> ;
                                 rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                 skos:definition "Gas is a compressible fluid, a state of matter that has no fixed shape and no fixed volume."@en ;
                                 skos:prefLabel "Gas"@en .


###  https://w3id.org/emmo/hume#GenerativeAIModel
<https://w3id.org/emmo/hume#GenerativeAIModel> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/emmo/hume#AIModel> ;
                                               rdfs:isDefinedBy <https://w3id.org/pink/models#> ;
                                               skos:altLabel "GenerativeArtificialIntelligenceModel"@en ;
                                               skos:definition "An AI model that can generate new content, like text, images or code."@en ;
                                               skos:example "Chatbots"@en ;
                                               skos:prefLabel "GenerativeAIModel"@en .


###  https://w3id.org/emmo/hume#GranularMaterial
<https://w3id.org/emmo/hume#GranularMaterial> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/emmo/hume#MaterialByCompactness> ;
                                              rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
                                              skos:definition "A granular material is a conglomeration of discrete solid, macroscopic particles that are  large enough to avoid thermal motion fluctuations, and characterized by a loss of energy whenever the particles interact."@en ;
                                              skos:prefLabel "GranularMaterial"@en .


###  https://w3id.org/emmo/hume#IonAtom
<https://w3id.org/emmo/hume#IonAtom> rdf:type owl:Class ;
                                     rdfs:subClassOf <https://w3id.org/emmo/hume#StandaloneAtom> ;
