#################################################################

###  http://data.europa.eu/r5r/applicableLegislation
ns2:applicableLegislation rdf:type owl:ObjectProperty ;
                          rdfs:domain dcat:Resource ;
                          rdfs:range <http://data.europa.eu/eli/ontology#LegalResource> .


