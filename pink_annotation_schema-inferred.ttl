dcterms:license rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:Resource ;
                rdfs:range dcterms:LicenseDocument .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:ObjectProperty ;
                  rdfs:domain dcat:Resource ;
                  rdfs:range foaf:Agent .


###  http://purl.org/dc/terms/relation
dcterms:relation rdf:type owl:ObjectProperty ;
                 rdfs:domain dcat:Relationship ;
                 rdfs:range rdfs:Resource .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:ObjectProperty ;
               rdfs:domain dcat:Dataset ;
               rdfs:range dcat:Dataset .


###  http://purl.org/dc/terms/spatial
dcterms:spatial rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:Dataset ;
                rdfs:range dcterms:Location .


###  http://purl.org/dc/terms/temporal
dcterms:temporal rdf:type owl:ObjectProperty ;
                 rdfs:domain dcat:Dataset .


###  http://purl.org/dc/terms/type
dcterms:type rdf:type owl:ObjectProperty ;
             rdfs:range skos:Concept .


