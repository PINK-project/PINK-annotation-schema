<https://w3id.org/emmo/hume#MaterialByOrigin> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/emmo/hume#Material> ;
                                              rdfs:isDefinedBy <https://w3id.org/pink/matter#> ;
