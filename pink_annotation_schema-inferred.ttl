ns2:applicableLegislation rdfs:isDefinedBy ns1: ;
                          skos:definition "The legislation that mandates the creation or management of the resource." ;
                          skos:prefLabel "applicableLegislation" .


ns2:availability rdfs:isDefinedBy ns1: ;
                 skos:definition "An indication how long it is planned to keep the Distribution of the Dataset available." ;
                 skos:prefLabel "availability" .


ns2:status vann:usageNote "It MUST take one of the values: 'stat:Completed', 'stat:Deprecated', 'stat:UnderDevelopment', 'stat:Withdrawn'." ;
           rdfs:isDefinedBy ns1: ;
           skos:definition "The status of the distribution in the context of maturity lifecycle." ;
           skos:prefLabel "status" .


dcterms:LicenseDocument rdfs:comment "A legal document giving official permission to do something with a resource."@en ;
                        rdfs:isDefinedBy <http://purl.org/dc/terms> ,
                                         <https://w3id.org/pink/reused-terms#> ;
                        rdfs:label "License Document"@en ;
                        skos:definition "A legal document giving official permission to do something with a resource." .


dcterms:RightsStatement vann:usageNote "EU pre-defines the following individuals: accr:PUBLIC, accr:NON_PUBLIC, accr:CONFIDENTIAL, accr:RESTRICTED, accr:SENSITIVE." ;
                        rdfs:comment "A statement about the intellectual property rights (IPR) held in or over a resource, a legal document giving official permission to do something with a resource, or a statement about access rights."@en ;
                        rdfs:isDefinedBy <http://purl.org/dc/terms> ,
                                         <https://w3id.org/pink/reused-terms#> ;
                        rdfs:label "Rights Statement"@en ;
                        skos:definition "A statement about the intellectual property rights (IPR) held in or over a resource, a legal document giving official permission to do something with a resource, or a statement about access rights." .


dcterms:abstract rdfs:isDefinedBy ns1: ;
                 skos:definition "A summary of the resource." ;
                 skos:prefLabel "abstract" .


dcterms:accessRights vann:usageNote "Access Rights may include information regarding access or restrictions based on privacy, security, or other policies. The following preferred Rights Statement individuals are defined: `accr:PUBLIC`, `accr:NON_PUBLIC`, `accr:CONFIDENTIAL`, `accr:RESTRICTED`, `accr:SENSITIVE`" ;
                     rdfs:isDefinedBy ns1: ;
                     skos:definition "Information about who can access the resource or an indication of its security status." ;
                     skos:prefLabel "accessRights" .


dcterms:accrualPeriodicity rdfs:isDefinedBy ns1: ;
                           skos:definition "The frequency at which the Dataset is updated." ;
                           skos:prefLabel "frequency" .


dcterms:bibliographicCitation vann:usageNote "Recommended practice is to include sufficient bibliographic detail to identify the resource as unambiguously as possible." ;
                              rdfs:isDefinedBy ns1: ;
                              skos:definition "A bibliographic reference for the resource." ;
                              skos:prefLabel "bibliographicCitation" .


dcterms:conformsTo rdfs:isDefinedBy ns1: ;
                   skos:definition "An implementing rule or other specification." ;
                   skos:prefLabel "conformsTo" .


dcterms:contributor rdfs:isDefinedBy ns1: ;
                    skos:definition "An entity responsible for making contributions to the resource." ;
                    skos:prefLabel "contributor" .


dcterms:creator rdfs:isDefinedBy ns1: ;
                skos:definition "An entity responsible for producing the resource." ;
                skos:prefLabel "creator" .


dcterms:format vann:usageNote "dcat:mediaType SHOULD be used if the type of the distribution is defined by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types)." ;
               rdfs:isDefinedBy ns1: ;
               skos:definition "The file format of the Distribution." ;
               skos:prefLabel "format" .


dcterms:hasPart rdfs:isDefinedBy ns1: ;
                skos:definition "A related resource that is included either physically or logically in the described resource." ;
                skos:prefLabel "hasPart" .


dcterms:identifier vann:usageNote "Recommended practice is to identify the resource by means of a string conforming to an identification system. Examples include International Standard Book Number (ISBN), Digital Object Identifier (DOI), and Uniform Resource Name (URN).  Persistent identifiers should be provided as HTTP URIs." ;
                   rdfs:isDefinedBy ns1: ;
                   skos:definition "URI or other unique identifier of the resource being described." ;
                   skos:prefLabel "identifier" .


dcterms:isReferencedBy rdfs:isDefinedBy ns1: ;
                       skos:definition "A related resource, such as a publication, that references, cites, or otherwise points to the documented resource." ;
                       skos:prefLabel "isReferencedBy" .


dcterms:issued rdfs:comment "The date of formal issuance (e.g., publication) of the resource." ;
               rdfs:isDefinedBy <https://w3id.org/pink/reused-terms#> ;
               rdfs:label "releaseDate" ;
               skos:definition "The date of formal issuance (e.g., publication) of the resource." ;
               skos:prefLabel "releaseDate" .


dcterms:language vann:usageNote """Recommended practice is to use either a non-literal value
representing a language from a controlled vocabulary such as
ISO 639-2 or ISO 639-3, or a literal value consisting of an
IETF Best Current Practice 47
[[IETF-BCP47](https://tools.ietf.org/html/bcp47)] language
tag.

Example values: \"en\", \"it\", \"no\", \"da\"

This property can be repeated if the resource is expressed
with multiple languages.
""" ;
                 rdfs:isDefinedBy ns1: ;
                 skos:definition "A language of the resource." ;
                 skos:prefLabel "language" .


dcterms:license rdfs:isDefinedBy ns1: ;
                skos:definition "A licence under which the resource is made available." ;
                skos:prefLabel "license" .


dcterms:modified rdfs:isDefinedBy ns1: ;
                 skos:definition "The most recent date on which the resource was changed or modified." ;
                 skos:prefLabel "modificationDate" .


dcterms:publisher rdfs:isDefinedBy ns1: ;
                  skos:definition "Agent responsible for making the resource available." ;
                  skos:prefLabel "publisher" .


dcterms:relation rdfs:isDefinedBy ns1: ;
                 skos:definition "A resource with an unspecified relationship to the cataloged resource." ;
                 skos:prefLabel "relatedResource" .


dcterms:source rdfs:isDefinedBy ns1: ;
               skos:definition "A related Dataset from which the described Dataset is derived." ;
               skos:prefLabel "source" .


dcterms:spatial rdfs:isDefinedBy ns1: ;
                skos:definition "A geographic region that is covered by the dataset." ;
