            sh:path pink:priorRelease ],
        [ sh:or ( [ sh:class pink:Software ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:isSubmoduleOf ],
        [ sh:datatype xsd:boolean ;
            sh:path pink:hasAPI ],
        [ sh:or ( [ sh:class pink:Model ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:implementsModel ],
        [ sh:datatype xsd:boolean ;
            sh:path pink:hasGUI ] ;
    sh:targetClass pink:Software .

