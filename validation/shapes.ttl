pink:ActivityShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:used ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasInformedBy ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:wasAssociatedWith ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:used ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:hasOutput ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasAssociatedWith ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:hasInput ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:wasInformedBy ] ;
    sh:targetClass prov:Activity .

