    sh:property [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:endpointDescription ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Parser> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#parser> ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:endpointURL ],
        [ sh:or ( [ sh:class dcat:Dataset ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:servesDataset ] ;
    sh:targetClass dcat:DataService .

