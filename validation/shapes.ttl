pink:ResourceShape a sh:NodeShape ;
    sh:node pink:EntityShape ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:path <https://w3id.org/emmo/application/datadoc#curationDate> ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:issued ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:landingPage ],
        [ sh:path dcat:version ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/application/datadoc#curator> ],
        [ sh:or ( [ sh:class prov:Attribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:qualifiedAttribution ],
        [ sh:or ( [ sh:class rdf:JSON ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#statement> ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:publisher ],
        [ sh:or ( [ sh:class dcat:Relationship ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:qualifiedRelation ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:hasVersion ],
        [ sh:or ( [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://data.europa.eu/r5r/applicableLegislation> ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path foaf:page ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/application/datadoc#ConformanceLevel> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/application/datadoc#conformance> ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:abstract ],
        [ sh:or ( [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:contactPoint ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:modified ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:creator ],
        [ sh:or ( [ sh:class dcterms:RightsStatement ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:accessRights ],
        [ sh:or ( [ sh:class dcterms:Standard ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:conformsTo ],
        [ sh:path dcterms:bibliographicCitation ],
        [ sh:datatype xsd:string ;
            sh:path <https://w3id.org/emmo/application/datadoc#unitSymbol> ],
        [ sh:datatype rdf:langString ;
            sh:path skos:definition ],
        [ sh:or ( [ sh:class skos:Concept ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:theme ],
        [ sh:or ( [ sh:class dcterms:LicenseDocument ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:license ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:isReferencedBy ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:contributor ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:title ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:documentation ],
        [ sh:datatype xsd:string ;
            sh:path dcterms:language ] ;
    sh:targetClass dcat:Resource .

pink:SemiSupervicedLearningModelShape a sh:NodeShape ;
    sh:targetClass pink:SemiSupervicedLearningModel .

pink:AgentShape a sh:NodeShape ;
    sh:node pink:AgentShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:path foaf:name ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:attributed ],
        [ sh:path dcterms:identifier ] ;
    sh:targetClass prov:Agent,
        foaf:Agent .

pink:ComputerVisionShape a sh:NodeShape ;
    sh:node pink:PerceptionModelShape ;
    sh:targetClass pink:ComputerVision .

pink:DimensionalityReductionShape a sh:NodeShape ;
    sh:targetClass pink:DimensionalityReduction .

pink:NaturalLanguageUnderstandingShape a sh:NodeShape ;
    sh:targetClass pink:NaturalLanguageUnderstanding .

pink:PredictionLearningModelShape a sh:NodeShape ;
    sh:node pink:SupervisedLearningModelShape ;
    sh:targetClass pink:PredictionLearningModel .

pink:SignShape a sh:NodeShape ;
    sh:node pink:EntityShape ;
    sh:property [ sh:or ( [ sh:class pink:Interpreter ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:isInterpretedBy ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:standsFor ] ;
    sh:targetClass pink:Sign .

pink:SupervisedLearningModelShape a sh:NodeShape ;
    sh:targetClass pink:SupervisedLearningModel .

pink:ClassificationShape a sh:NodeShape ;
    sh:node pink:SupervisedLearningModelShape ;
    sh:targetClass pink:Classification .

pink:SsbdDimensionShape a sh:NodeShape ;
    sh:node pink:EntityShape ;
    sh:targetClass pink:SsbdDimension .

pink:SymbolicDataShape a sh:NodeShape ;
    sh:node pink:DataShape ;
    sh:targetClass pink:SymbolicData .

pink:CognitionAndLearningModelShape a sh:NodeShape ;
    sh:targetClass pink:CognitionAndLearningModel .

pink:DataShape a sh:NodeShape ;
    sh:node pink:EntityShape ;
    sh:property [ sh:path pink:hasDataValue ] ;
    sh:targetClass pink:Data .

pink:DeepLearningModelShape a sh:NodeShape ;
    sh:node pink:ArtificialNeuralNetworkShape ;
    sh:targetClass pink:DeepLearningModel .

pink:EntityShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:wasGeneratedBy ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:participatesTo ],
        [ sh:or ( [ sh:class pink:Matter ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:chemicalClass ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:wasDerivedBy ],
        [ sh:or ( [ sh:class pink:TierLevel ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:tierLevel ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasAttributedTo ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:wasAttributedTo ],
        [ sh:or ( [ sh:class pink:Sign ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path pink:isRepresentedBy ] ;
    sh:targetClass prov:Entity .

