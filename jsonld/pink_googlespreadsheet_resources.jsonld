    {
      "@id": "qsar:ProfilerOutput",
      "@type": "owl:Class",
      "label": "Profiler dataset type",
      "description": "Preliminary defined categories (functional groups/alerts) used in a profiler.",
      "scopeNote": "Profiler definition: The profilers identify the affiliation of the target chemical(s) to preliminary defined categories (functional groups/alerts). The outcome of the profiling determines the most appropriate way to search for analogues, but they are also useful for preliminary screening or prioritization of substances. \n\nThe profilers are not (Q)SAR models. Hence, the profiling results are not a predictions and should not be used as such. see https://qsartoolbox.org/features/profiling/\nhttps://www.sciencedirect.com/science/article/pii/S2468111325000167 \n\n\nQSAR profiler categories are from the QSARToolbox: https://qsartoolbox.org/resources/profilers/",
      "subClassOf": "https://w3id.org/ssbd/Dataset"
    },
    {
      "@id": "qsar:ProfilerOutputEndpointSpecific",
      "@type": "owl:Class",
      "label": "Endpoint specific QSAR profilers",
      "description": "Mechanistic categorization schemes consist of rules for identification of chemical characteristics associated with a specific endpoint based on published or expert knowledge (e.g. DNA alerts for AMES, CA and MNT by OASIS).",
      "subClassOf": "https://w3id.org/ssbd/Profiler"
