        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "ssbd:MicroMolecule"
        }
      ],
      "title": "MultiCASE CASE Ultra commercial model RC2_AF4 for Rodent carcinogenicity in female mouse in vivo,\nDanish QSAR Group at DTU Food",
      "description": "The training set consists of non\u2010proprietary studies and is composed of data harvested from FDA approval packages and the published literature (for more details see 6.5). The model algorithm is proprietary from commercial software. The model has been created by FDA and MultiCASE based on FDA data as part of a Research Cooperation Agreement (RCA).\nThe training set was constructed using the NTP (U.S. National Toxicology Program) Rodent carcinogenicity database, the Lois Gold Carcinogen Potency Database, FDA/CDER (U.S. Food and Drug Administration / Center for Drug Evaluation and Research) archives, and the scientific literature. The model including the training data set is commercially available from MultiCASE Inc.",
      "documentation": "https://drive.google.com/file/d/1UfVlkwcNl9NiI3T1g9D463njkqScE5Gr/view",
      "distribution": {
        "@type": [
          "dcat:Distribution",
          "dcat:Resource",
          "prov:Entity"
        ],
        "accessURL": "https://app.jaqpot.org/dashboard/models/1837/predict"
      },
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://qsartoolbox.org/license-agreement/",
      "version": "January 2015",
      "curator": "https://orcid.org/0000-0002-0628-8434"
    },
    {
      "@id": "pink:TOX21_GNRHR_HEK293_Agonist",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "emmo:PhysicsBasedModel"
        }
      ],
      "title": "Tox21 HEK293T Gonadotropin-releasing Hormone (GnRH) Receptor Agonism Assay",
      "description": "TOX21_GNRHR_HEK293 is a cell-based, single-readout assay that uses GnRHR-expressing stably transfected HEK293, a human kidney cell line, with measurements taken at 1.25 hours after chemical dosing in a 1536-well plate. TOX21_GNRHR_HEK293_Agonist is one of 2 assay components measured in the TOX21_GNRHR_HEK293 assay. It is designed to make measurements of intracellular calcium, a form of biochemical reporter, as detected with Fluorescence intensity signals by FDSS 7000EX kinetic plate reader technology. Data from the assay component TOX21_GNRHR_HEK293_Agonist was analyzed into 2 assay endpoints. This assay endpoint, TOX21_GNRHR_HEK293_Agonist was analyzed in the positive analysis fitting direction relative to DMSO as the negative control and baseline of activity. Using a type of inducible reporter, gain-of-signal activity can be used to understand changes in binding. To generalize the intended target to other relatable targets, this assay endpoint is annotated to the gpcr, where the subfamily is gonadotropin-releasing hormone receptor.",
      "documentation": "https://clowder.edap-cluster.com/files/68a37cece4b02565fc7b59e4?dataset=6894f2dae4b025654d12b716&space=687e388ce4b02565bc3e28e4",
      "distribution": {
        "@type": [
          "dcat:Distribution",
          "dcat:Resource",
          "prov:Entity"
        ],
        "accessURL": "https://clowder.edap-cluster.com/spaces/687e388ce4b02565bc3e28e4"
      },
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "http://www.usa.gov/publicdomain/label/1.0/",
      "version": "August 14 2025",
      "curator": "https://orcid.org/0000-0002-1849-5246"
    },
    {
      "@id": "pink:2256b12d-5ef8-49a2-af9a-b453b3f23d96",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "ssbd:DecisionTree"
        }
      ],
      "title": "Carcinogenicity (genotox and nongenotox) alerts by ISS",
      "description": "This profiler is an expanded and updated version of the correspondent module originally\nimplemented in the software Toxtree. It works as a decision tree for estimating\ncarcinogenicity, based on a list of 55 structural alerts (SAs). Out of them, 35 derive from the\nToxtree module and 20 are newly derived. Most of the new SAs are relative to nongenotoxic\ncarcinogenicity, whereas the SAs in the initial list mainly coded genotoxic carcinogenicity.\nThe SAs for carcinogenicity are molecular functional groups or substructures known to be\nlinked to the carcinogenic activity of chemicals. As one or more SAs embedded in a\nmolecular structure are recognised, the system flags the potential carcinogenicity of the\nchemical. The present list of alert is relevant for the investigation of chemicals genotoxic\nand nongenotoxic carcinogenicity. Applicable to Carcinogenicity (e.g. Carcinogenicity, Summary carcinogenicity, TD50).",
      "keyword": [
        "carcinogenicity",
        "profiler"
      ],
      "tierLevel": "https://w3id.org/ssbd/tierlevel1",
      "documentation": "https://drive.google.com/file/d/1A-PrNYn-XXgJyLs_c9xaiTGxbC5qHoBP/view?usp=share_link",
      "distribution": {
        "@type": [
          "dcat:Distribution",
          "dcat:Resource",
          "prov:Entity"
        ],
        "accessURL": "https://app.jaqpot.org/dashboard/models/1842/predict"
      },
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://qsartoolbox.org/license-agreement/",
      "creator": "https://ror.org/02hssy432",
      "version": "Version: 2.3\nDecember 2016",
      "curator": "https://orcid.org/0000-0002-0628-8434"
    },
