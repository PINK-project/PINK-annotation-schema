          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "ssbd:NanoParticle"
        }
      ],
      "title": "Zeta Predict Extended tool",
      "description": "This web GUI tool calculates the zeta potential of Nanoparticles using a) DLVO theory, b) liquid TEM images and c) the NOVAMFF derived to predict with high accuracy the Hamaker constant",
      "keyword": [
        "Aggregation",
        "DLVO",
        "NPs"
