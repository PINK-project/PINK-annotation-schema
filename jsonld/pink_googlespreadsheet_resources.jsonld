    {
      "@id": "qsar:ProfilerOutputGeneralMechanistic",
      "@type": "owl:Class",
      "label": "General mechanistic QSAR profilers",
      "description": "Mechanistic categorization schemes consist of rules for identification of important general chemical characteristics based on published or expert knowledge (e.g. DNA binding by OASIS)",
      "subClassOf": "https://w3id.org/ssbd/Profiler"
    },
    {
      "@id": "qsar:ProfilerOutputPredefined",
      "@type": "owl:Class",
      "label": "Predefined QSAR profilers",
      "description": "Predefined categories are set of rules for grouping chemicals developed by recognized institutions or organizations and they could be considered as \u201cstandard\u201d categorization schemes (e.g. US-EPA New Chemical categories)",
      "subClassOf": "https://w3id.org/ssbd/Profiler"
    },
    {
      "@id": "qsar:ProfilerOutputEmpriric",
      "@type": "owl:Class",
      "label": "Empiric QSAR profilers",
      "description": "Empiric categorization schemes include rules used to determine the chemical elements constituting the target chemical, its chemical functionality and structural similarity (e.g. Organic functional groups)",
      "subClassOf": "https://w3id.org/ssbd/Profiler"
    },
    {
      "@id": "qsar:ProfilerOutputToxicological",
      "@type": "owl:Class",
      "label": "Toxicological QSAR profilers",
      "description": "The toxicological category includes only one profiler. The profiler contains boundaries based on repeated dose toxicity test data extracted from database of Hazard Evaluation Support System (HESS).",
      "subClassOf": "https://w3id.org/ssbd/Profiler"
    },
    {
      "@id": "qsar:ProfilerOutputRepeatedDose",
      "@type": "owl:Class",
      "label": "missing",
      "subClassOf": "qsar:ProfilerToxicological"
    },
    {
      "@id": "qsar:ProfilerOutputCustom",
      "@type": "owl:Class",
      "label": "Custom QSAR profilers",
      "description": "schemes based on the user`s knowledge. Example Prioritization Scheme (PBT) identifying the persistence, bioaccumulation and toxicity of the target chemical(s) based on their experimental and/or predicted data is included as a custom profiler.",
      "subClassOf": "https://w3id.org/ssbd/Profiler"
    },
