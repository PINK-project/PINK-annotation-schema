    {
      "@id": "datasettype:ChemicalStructureDataset",
      "@type": "owl:Class",
      "label": "Chemical Structure Dataset",
      "description": "Dataset describing the chemical identity and three-dimensional structure of molecules, oligomers, polymers, or condensed-phase systems. It may include SMILES strings, atomistic coordinates, bonding topology, periodic boundary conditions, and molecular connectivity. The dataset is used as input for structure generation, force-field assignment, molecular dynamics simulations, and construction of bulk models.",
      "keyword": [
        "SMILES",
        "atomistic",
        "chain",
        "chemical",
        "coordinates",
        "model",
        "molecular",
        "periodic",
        "polymer",
        "structure",
        "system",
        "topology"
      ],
      "format": "SMILES, MOL, SDF, PDB, XYZ, GRO, CIF",
      "subClassOf": [
        "https://w3id.org/ssbd/Dataset",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ddoc:curator",
          "owl:hasValue": "https://ror.org/04zaypm56"
        }
      ]
    },
    {
      "@id": "datasettype:ChemicalStructureCoordinateDataset",
      "@type": "owl:Class",
      "label": "missing",
      "description": "Dataset describing a three-dimensional coordinates of a structure.",
      "format": "MOL, SDF, PDB, XYZ, GRO, CIF",
      "subClassOf": "datasettype:ChemicalStructureDataset"
    },
    {
      "@id": "datasettype:MechanicalPropertiesDataset",
      "@type": "owl:Class",
      "label": "Mechanical Properties Dataset",
      "description": "Dataset reporting mechanical properties derived from experiments or simulations, such as Young\u2019s modulus, bulk modulus, Poisson\u2019s ratio, stress-strain curves, elastic constants, and derived statistical indicators. The dataset supports quantitative assessment of material stiffness, elasticity, and macroscopic mechanical behavior.",
      "keyword": [
        "Poisson",
        "Young\u2019s",
        "bulk",
        "characterization",
        "constants",
        "elastic",
        "material",
        "mechanical",
        "modulus",
        "properties",
        "ratio",
        "stress-strain"
      ],
      "format": "CSV, XLSX, JSON",
      "subClassOf": [
        "https://w3id.org/ssbd/Dataset",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ddoc:curator",
          "owl:hasValue": "https://ror.org/04zaypm56"
        }
      ]
    },
    {
      "@id": "datasettype:InteractionPotentialParameters",
      "@type": "owl:Class",
      "label": "Interaction Potential Parameters Dataset",
      "description": "Dataset containing the parameters required to define the interaction potential for molecular simulations. This includes atom types, bonded parameters (bonds, angles, dihedrals), non-bonded parameters (Lennard-Jones, electrostatics), partial charges, and force-field topology information. The dataset enables reproducible molecular mechanics and molecular dynamics simulations.",
      "keyword": [
        "GAFF",
        "OPLS",
        "atom",
        "bonded",
        "charges",
        "field",
        "force",
        "interaction",
        "non-bonded",
        "parameters",
        "partial",
        "potential",
        "topology",
        "types"
      ],
      "format": "TOP, ITP, PRM, XML, JSON, TXT",
      "subClassOf": [
        "https://w3id.org/ssbd/Dataset",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ddoc:curator",
          "owl:hasValue": "https://ror.org/04zaypm56"
        }
      ]
    },
    {
      "@id": "pink:ChemPharosDB-ds3",
      "@type": "owl:Class",
      "label": "Vapor Pressure (logVP) of small molecules",
      "description": "A curated and enriched dataset for log-transormed vapor pressure at 24\u02daC of small molecules, intended for in silico model development. The dataset originates from the US EPA EPI Suite, filtered according to Zang et al. (2017). https://doi.org/10.1021/acs.jcim.6b00625. The curated logVP dataset comprises 2713 compounds enriched with 777 molecular descriptors extracted from their 2D structure using EnalosMold2 KNIME node.",
      "format": ".csv",
      "subClassOf": "https://w3id.org/ssbd/Dataset"
    },
    {
      "@id": "pink:ChemPharosDB-ds4",
      "@type": "owl:Class",
      "label": "Octanol/water partition coefficient (logP) of small molecules",
      "description": "A curated and enriched dataset for log-transormed octanol/water partition coefficient of small molecules, intended for in silico model development. The dataset originates from the US EPA EPI Suite, filtered according to Zang et al. (2017). https://doi.org/10.1021/acs.jcim.6b00625. The curated logP dataset comprises 14207 compounds enriched with 777 molecular descriptors extracted from their 2D structure using EnalosMold2 KNIME node.",
      "format": ".csv",
      "subClassOf": "https://w3id.org/ssbd/Dataset"
    },
    {
      "@id": "pink:ChemPharosDB-ds5",
      "@type": "owl:Class",
      "label": "Cytotoxicity of small molecules",
      "description": "A curated and enriched dataset for the cytotoxicity of small molecules to NIH/3T3 cells (mouse embryonic fibroblast cell line; ATCC CRL-1658). The dataset originates from the PubChem database: https://pubchem.ncbi.nlm.nih.gov/bioassay/651744. The curated dataset comprises 5416 compounds enriched with 777 molecular descriptors extracted from their 2D structure using EnalosMold2 KNIME node. Compounds are classified as either \u201cActive\u201d\u2014indicating cytotoxicity to NIH/3T3 cells\u2014or \u201cInactive\u201d, signifying non-cytotoxicity to these cells.",
      "format": ".csv",
      "subClassOf": "https://w3id.org/ssbd/Dataset"
    },
    {
      "@id": "pink:ChemPharosDB-ds10",
      "@type": "owl:Class",
      "label": "Boiling point of small molecules",
      "description": "A curated and enriched dataset for the boiling point (BP) in \u00b0C of small molecules, intended for in silico model development. The dataset originates from the US EPA EPI Suite, filtered according to Zang et al. (2017). https://doi.org/10.1021/acs.jcim.6b00625. The curated BP dataset comprises 5432 compounds enriched with 777 molecular descriptors extracted from their 2D structure using EnalosMold2 KNIME node.",
      "format": ".csv",
      "subClassOf": "https://w3id.org/ssbd/Dataset"
    },
    {
      "@id": "pink:ChemPharosDB-ds11",
      "@type": "owl:Class",
      "label": "Ames mutagenicity of small molecule",
      "description": "A curated and enriched dataset for the Ames mutagenicity of small molecules, intended for in silico model development. The dataset originates from the study of Hansen et al. (2009) https://doi.org/10.1021/ci900161g, and is further refined by the US EPA EPI Suite (removing salts, mixtures, ambiguous compounds, and compounds without CAS numbers). The curated lmutagenicity dataset comprises 5738 compounds enriched with 777 molecular descriptors extracted from their 2D structure using EnalosMold2 KNIME node. Compounds are classified as either \u201cpositive\u201d -indicating mutagenic compounds- or \u201cnegative\u201d -indicating non-mutagenic substances.",
      "format": ".csv",
      "subClassOf": "https://w3id.org/ssbd/Dataset"
    },
    {
      "@id": "datasettype:OccurrenceData",
      "@type": "owl:Class",
      "label": "Quantification of PFAS in surface and groundwater sites in UK",
      "description": "A curated dataset of environmental monitoring from UK 2022-2024 for surface and groundwaters assessing total PFAS and individual PFAS congeners.",
