    {
      "@id": "pink:Jaqpot_2081",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "ssbd:RandomForest"
        }
      ],
      "title": "Animal Carcinogenicity prediction according to OECD Test No. 451",
      "description": "The endpoint predicted by this model is Animal Carcinogenicity. The dataset used for modeling was obtained from the Carcinogenic Potency Database (CPDB), which contains long-term study results for over 1,500 chemical substances on rodent (mouse and rat) species. Carcinogenicity is defined through the OECD Test No. 451. Each author in the literature evaluated the tissue-tumor combination of the chemical substance and gave their opinion on carcinogenicity, which was assessed from NCI/NTP. In the dataset:\nCarcinogenic chemicals are labeled as 1.\nNon-carcinogenic chemicals are labeled as 0.",
      "documentation": "https://docs.google.com/document/d/1yBrGi-dJkPBCYkpQ6qhCtzQswdLcKN5x/edit?usp=drive_link&ouid=103056225293934767525&rtpof=true&sd=true",
      "distribution": {
        "@type": [
          "dcat:Distribution",
          "dcat:Resource",
          "prov:Entity"
        ],
        "accessURL": "https://app.jaqpot.org/dashboard/models/2081/description"
      },
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "creator": "https://ror.org/03cx6bg69",
      "curator": "https://orcid.org/0000-0002-0628-8434"
    },
    {
      "@id": "pink:Jaqpot_2082",
      "@type": [
        "ssbd:Software",
        "ssbd:Data"
      ],
      "title": "Skin Reaction TDCommons",
      "description": "Binary Classification of Skin Reaction for small Drugs with Extra Trees Classifier and MACCS fingerprints with python and jaqpot software. An Extra Trees classifier was developed to classify whether a drug causes skin reaction or not. The dataset used in this study was retrieved from the ICCVAM (Interagency Coordinating Committee on the Validation of Alternative Methods) report on the rLLNA. The test used to obtain the endpoint is called reduced LLNA (rLLNA) which identifies skin sensitizers by quantifying lymphocyte proliferation.. The train and testing splits were conducted randomly stratified with a 0.7-0.3 ratio. MACCS fingerprints were generated from SMILES and feature selection through correlation, variance threshold and mutual information was implemented. The final model is cross-validated and evaluated on the unseen test set to ensure robustness.",
      "documentation": "https://docs.google.com/document/d/1F0iwM70_BLwXiBPRN9J5PDtuV8UJLdoC/edit",
      "distribution": {
        "@type": [
          "dcat:Distribution",
          "dcat:Resource",
          "prov:Entity"
        ],
        "accessURL": "https://app.jaqpot.org/dashboard/models/2082/description"
      },
      "implementsModel": "pink:ExtraTreeClassifier",
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "creator": "https://ror.org/03cx6bg69",
      "curator": "https://orcid.org/0000-0002-0628-8434"
    },
    {
      "@id": "mw:bulk_polymer_mechanical_molecular",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:PolymericMaterial"
        }
      ],
      "title": "CNR SMILES to mechanical properties workflow - molecular scale",
      "description": "(Integrated workflow) - An integrated workflow based on atomistic molecular dynamics simulations that uses the SMILES representation of a monomer as input to automatically generate a polymer chain, construct a periodic bulk model, and perform fully atomistic simulations of mechanical properties. From the stress-strain response obtained under controlled deformation, the tool computes the key mechanical properties of the polymer, including Young\u2019s modulus, bulk modulus, and Poisson\u2019s ratio.",
      "keyword": [
        "Molecular",
        "SMILES",
        "bulk",
        "dynamics",
        "polymer"
      ],
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://opensource.org/license/mit",
      "creator": "https://ror.org/04zaypm56",
      "curator": [
        "https://orcid.org/0000-0002-3369-4438",
        "https://orcid.org/0000-0002-4860-153X"
      ]
    },
    {
      "@id": "mw:polymer_builder_molecular",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "emmo:StructureManipulationModel"
        },
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:PolymericMaterial"
        }
      ],
      "title": "CNR polymer builder module - molecular scale",
      "description": "(Computational module) - This module takes the SMILES representation of a monomer as input and automatically generates a polymer chain structure (atomistic level) suitable for atomistic molecular dynamics simulations. The tool interprets the SMILES string to reconstruct the 3D molecular structure of the monomer, identifies the reactive termini, and performs automated polymerization to build a chain of user-defined length.",
      "keyword": [
        "SMILES",
        "polymer"
      ],
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://opensource.org/license/mit",
      "creator": "https://ror.org/04zaypm56",
      "curator": [
        "https://orcid.org/0000-0002-3369-4438",
        "https://orcid.org/0000-0002-4860-153X"
      ]
    },
    {
      "@id": "mw:ff_builder_molecular",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "emmo:AtomicInteractionModel"
        },
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:PolymericMaterial"
        }
      ],
      "title": "CNR force field builder module - molecular scale",
      "description": "(Computational module) - This module takes the polymer structure as an input and generates a molecular mechanics force field, with OPLS used as the default option and GAFF available as an alternative. The tool generates the complete molecular topology, including atom types, bonded and non-bonded parameters, partial charges, and connectivity, providing a fully parameterized polymer structure ready for subsequent MD calculations.",
      "keyword": [
        "Molecular",
        "dynamics",
        "field",
        "force",
        "polymer",
        "topology"
      ],
      "tierLevel": "https://w3id.org/ssbd/tierlevel1",
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://opensource.org/license/mit",
      "creator": "https://ror.org/04zaypm56",
      "curator": [
        "https://orcid.org/0000-0002-3369-4438",
        "https://orcid.org/0000-0002-4860-153X"
      ]
    },
    {
      "@id": "mw:polymer_bulk_builder_molecular",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "emmo:AtomisticMolecularDynamics"
        },
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:OrganicCompound"
        },
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:PolymericMaterial"
        }
      ],
      "title": "CNR bulk builder module - molecular scale",
      "description": "(Computational module) - This module takes a single polymer chain structure (atomistic level) as an input and constructs a three-dimensional bulk model (atomistic level) by replicating it within a cubic simulation box. The system is then subjected to a multi-stage molecular dynamics protocol in the NPT ensemble, comprising heating under compression, cooling under compression, and final equilibration at ambient pressure. This procedure enables the chains to pack realistically and relax toward a stable glassy configuration. The module outputs the equilibrated bulk structure along with key bulk properties extracted from the simulation, providing a physically meaningful starting point for mechanical characterization.",
      "keyword": [
        "bulk",
        "density",
        "dynamics",
        "molecular",
        "polymer"
      ],
      "tierLevel": "https://w3id.org/ssbd/tierlevel1",
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://opensource.org/license/mit",
      "creator": "https://ror.org/04zaypm56",
      "curator": [
        "https://orcid.org/0000-0002-3369-4438",
        "https://orcid.org/0000-0002-4860-153X"
      ]
    },
    {
      "@id": "mw:youngs_modulus_evaluator_molecular",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "emmo:AtomisticMolecularDynamics"
        },
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:PolymericMaterial"
        }
      ],
      "title": "CNR Young's modulus calculator module - molecular scale",
      "description": "(Computational module) -This module computes the Young\u2019s modulus of a bulk polymer system using molecular simulations. It takes as input an equilibrated polymer configuration along with the corresponding interaction parameters. The simulation cell is replicated to minimize finite-size effects and subjected to controlled uniaxial deformation within an NPT ensemble. During deformation, the stress-strain response of the system is recorded. The Young\u2019s modulus is then determined by fitting the linear elastic region of the stress-strain curve, providing a quantitative measure of the polymer\u2019s mechanical stiffness.",
      "keyword": [
        "dynamics",
        "mechanical",
        "modulus",
        "molecular",
        "polymer",
        "properties",
        "young's"
      ],
      "tierLevel": "https://w3id.org/ssbd/tierlevel1",
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://opensource.org/license/mit",
      "creator": "https://ror.org/04zaypm56",
      "curator": [
        "https://orcid.org/0000-0002-3369-4438",
        "https://orcid.org/0000-0002-4860-153X"
      ]
    },
    {
      "@id": "mw:mechanical_properties_evaluator_molecular",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:implementsModel",
          "owl:someValuesFrom": "emmo:AtomisticMolecularDynamics"
        },
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "emmo:PolymericMaterial"
        }
      ],
      "title": "CNR mechanical properties calculator module - molecular scale",
      "description": "(Computational module) - This module takes the equilibrated bulk polymer model as input and prepares it for mechanical testing by replicating the simulation cell and applying a series of molecular dynamics simulations. Controlled deformations are introduced under NPT conditions to obtain stress-strain responses for different loading modes. From these trajectories, the module computes key mechanical indicators of the polymer, including Young\u2019s modulus, bulk modulus, and Poisson\u2019s ratio, providing a quantitative assessment of the material\u2019s macroscopic mechanical behavior directly from atomistic simulation.",
      "keyword": [
        "bulk",
        "dynamics",
        "modulus",
        "molecular",
        "poisson",
        "polymer",
        "ratio",
        "young's"
      ],
      "tierLevel": "https://w3id.org/ssbd/tierlevel1",
      "hasAPI": true,
      "hasGUI": true,
      "accessRights": "http://publications.europa.eu/resource/authority/access-right/PUBLIC",
      "license": "https://opensource.org/license/mit",
      "creator": "https://ror.org/04zaypm56",
      "curator": [
        "https://orcid.org/0000-0002-3369-4438",
        "https://orcid.org/0000-0002-4860-153X"
      ]
    },
    {
      "@id": "pink:AOP_451",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
          "owl:someValuesFrom": "ssbd:NanoParticle"
        }
      ],
      "title": "AOP 451: Interaction with lung resident cell membrane components leads to lung cancer",
