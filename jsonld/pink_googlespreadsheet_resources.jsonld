    {
      "@id": "pink:EnalosCloud_NanoBioConstruct",
      "@type": [
        "ssbd:Data",
        "ssbd:Software",
        {
          "@type": "owl:Restriction",
          "owl:onProperty": "ssbd:chemicalClass",
