cheminf:CHEMINF_000430 a owl:Class ;
    rdfs:label "structural alert count"@en ;
    ns1:IAO_0000115 """The number of structural alerts, that is, unwanted features as defined according to the procedure followed in Brenk et al., 2008.
Brenk R, et al. Lessons learnt from assembling screening libraries for drug discovery for neglected diseases. Chem Med Chem. 2008;3:435–444. """ ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000209 ;
    skos:prefLabel "StructuralAlertCount"@en .

cheminf:CHEMINF_000431 a owl:Class ;
    rdfs:label "weighted quantitative estimate of drug-likeness"@en ;
    ns1:IAO_0000115 """A descriptor which gives a quantitative estimate of drug likeness according to the procedure outlined in Bickerton et al., 2012.

http://www.ncbi.nlm.nih.gov/pubmed/22270643
Nat Chem. 2012 Jan 24;4(2):90-8. doi: 10.1038/nchem.1243.
Quantifying the chemical beauty of drugs.
Bickerton GR, Paolini GV, Besnard J, Muresan S, Hopkins AL.""" ;
    ns1:IAO_0000118 "QED weighted" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000025 ;
    skos:prefLabel "WeightedQuantitativeEstimateOfDrugMinuslikeness"@en .

cheminf:CHEMINF_000432 a owl:Class ;
    rdfs:label "freezing point descriptor"@en ;
    dc:description "A descriptor that indicates the temperature at which a chemical substance undergoes a state transition from gas or liquid to solid, under standard conditions." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "FreezingPointDescriptor"@en .

cheminf:CHEMINF_000433 a owl:Class ;
    rdfs:label "Henry's Law constant"@en ;
    dc:description """Henry's law, formulated by William Henry in 1803, states "At a constant temperature, the amount of a given gas that dissolves in a given type and volume of liquid is directly proportional to the partial pressure of that gas in equilibrium with that liquid." Henry's law can be put into mathematical terms (at constant temperature) as
    p = kHc
where p is the partial pressure of the solute in the gas above the solution, c is the concentration of the solute and kH is a constant with the dimensions of pressure divided by concentration. The constant, known as the Henry's law constant, depends on the solute, the solvent and the temperature.""" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "Henry'sLawConstant"@en .

cheminf:CHEMINF_000434 a owl:Class ;
    rdfs:label "atmospheric OH rate constant"@en ;
    dc:description "A physical descriptor for the rate constant of a reaction of a chemical entity with OH. This is used to describe the atmospheric behaviour (i.e. stability) of the entity. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "AtmosphericOHRateConstant"@en .

cheminf:CHEMINF_000435 a owl:Class ;
    rdfs:label "upper explosive limit descriptor"@en ;
    dc:description "A physical descriptor for the upper explosive limit of the entity in air as a percentage by volume at room temperature. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "UpperExplosiveLimitDescriptor"@en .

cheminf:CHEMINF_000436 a owl:Class ;
    rdfs:label "lower explosive limit descriptor"@en ;
    dc:description "A physical descriptor for the lower explosive limit in air as a percentage by volume at room temperature" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "LowerExplosiveLimitDescriptor"@en .

cheminf:CHEMINF_000437 a owl:Class ;
    rdfs:label "minimum explosive concentration descriptor"@en ;
    dc:description "A physical descriptor for the minimum explosive concentration. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "MinimumExplosiveConcentrationDescriptor"@en .

cheminf:CHEMINF_000438 a owl:Class ;
    rdfs:label "specific gravity descriptor"@en ;
    dc:description "A physical descriptor of the ratio of the density of chemical substance to the density of a reference substance. The reference substance is usually water for liquids or air for gases. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "SpecificGravityDescriptor"@en .

cheminf:CHEMINF_000439 a owl:Class ;
    rdfs:label "relative density descriptor"@en ;
    dc:description "A descriptor of the relative density of gases referenced to air as 1, which indicates how many times a gas is heavier than air at the same temperature. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "RelativeDensityDescriptor"@en .

cheminf:CHEMINF_000440 a owl:Class ;
    rdfs:label "vapor density descriptor"@en ;
    dc:description "A descriptor of the density of a vapour in relation in that of hydrogen, defined as the mass of a certain volume of the given substance divided by the mass of the same volume of hydrogen. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "VaporDensityDescriptor"@en .

cheminf:CHEMINF_000441 a owl:Class ;
    rdfs:label "odor detection threshold descriptor"@en ;
    dc:description "A physical descriptor for the lowest concentration of an odorant chemical entity that is perceivable by the human sense of smell. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "OdorDetectionThresholdDescriptor"@en .

cheminf:CHEMINF_000442 a owl:Class ;
    rdfs:label "pH descriptor"@en ;
    dc:description "A physical descriptor which gives a measure of the acidity or basicity of an aqueous solution, defined as the decimal logarithm of the reciprocal of the hydrogen ion activity in a solution. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "PHDescriptor"@en .

cheminf:CHEMINF_000443 a owl:Class ;
    rdfs:label "evaporation rate descriptor"@en ;
    dc:description "A physical descriptor of the rate of evaporation of a liquid under standard conditions. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "EvaporationRateDescriptor"@en .

cheminf:CHEMINF_000444 a owl:Class ;
    rdfs:label "autoignition temperature descriptor"@en ;
    ns1:IAO_0000118 "kindling point" ;
    dc:description "A physical descriptor of the lowest temperature at a substance will spontaneously ignite in a normal atmosphere without an external source of ignition. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "AutoignitionTemperatureDescriptor"@en .

cheminf:CHEMINF_000445 a owl:Class ;
    rdfs:label "soil half-life descriptor"@en ;
    dc:description "A physical descriptor for the time it takes for half of a portion of substance of a given type to decompose in soil under standard conditions. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025 ;
    skos:prefLabel "SoilHalfMinuslifeDescriptor"@en .

cheminf:CHEMINF_000446 a owl:Class ;
    rdfs:label "CAS registry number" ;
    dc:description "Identifier used by the Chemical Abstracts Service database." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000464 ;
    skos:prefLabel "CASRegistryNumber"@en .

cheminf:CHEMINF_000447 a owl:Class ;
