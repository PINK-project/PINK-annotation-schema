    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_36357 ],
        cheminf:CHEMINF_000061,
        cheminf:CHEMINF_000085 ;
    skos:prefLabel "TUCANDescriptor"@en .

cheminf:CHEMINF_000523 a owl:Class ;
    rdfs:label "ACD/Labs index name"@en ;
    ns1:IAO_0000118 "index name" ;
    dc:creator <http://orcid.org/0000-0002-4378-6061> ;
    dc:date "2022-07-11T08:20:10+00:00"^^xsd:dateTime ;
    dc:description "A molecular entity name that represents the name of a molecular structure determined by the naming algorithms developed by ACD/Labs." ;
    dc:source "https://www.acdlabs.com/products/name/"^^xsd:anyURI ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
