cheminf:CHEMINF_000487 a owl:Class ;
    rdfs:label "energy band gap"@en ;
    ns1:IAO_0000115 "A descriptor that describes the energy range in a solid where no electron states can exist. In graphs of the electron band structure of solids, the band gap generally refers to the energy difference (in electron volts) between the top of the valence band and the bottom of the conduction band in insulators and semiconductors. [http://en.wikipedia.org/wiki/Band_gap]" ;
    ns1:IAO_0000118 "band gap",
        "energy gap" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
