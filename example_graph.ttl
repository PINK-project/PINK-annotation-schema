    skos:prefLabel "TotalPolarSurfaceAreaCalculatedByRDKitSoftwareLibraryVersion2015092"@en .

cheminf:CHEMINF_001100 a owl:Class ;
    rdfs:label "Bond Polarizabilities" ;
    dc:description "Descriptor that calculates the sum of the absolute value of the difference between atomic polarizabilities of all bonded atoms in the molecule (including implicit hydrogens)." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000087 ;
    skos:prefLabel "BondPolarizabilities"@en .

cheminf:CHEMINF_001101 a owl:Class ;
    rdfs:label "oxidation state" ;
    dc:description "Oxidation state is an atomic descriptor that gives the degree of oxidation of an atom in terms of counting electrons. The higher the oxidation state (OS) of a given atom, the greater is its degree of oxidation. [source: IUPAC Gold Book - https://doi.org/10.1351/goldbook.O04365]" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000087,
        <http://www.blueobelisk.org/ontologies/chemoinformatics-algorithms/#AtomicDescriptor> ;
    skos:prefLabel "OxidationState"@en ;
    ns5:source "https://doi.org/10.1351/goldbook.O04365" .

cheminf:CHEMINF_001104 a owl:Class ;
    rdfs:label "connectivity SMILES descriptor" ;
    dc:description "A connectivity SMILES descriptor is a SMILES descriptor that does not include any stereochemical or isotopic information." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000018 ;
    skos:prefLabel "ConnectivitySMILESDescriptor"@en .

cheminf:CHEMINF_001500 a owl:Class ;
    rdfs:label "BCUT"@en ;
    dc:description "Eigenvalue based descriptor noted for its utility in chemical diversity." ;
    bibo:doi " http://dx.doi.org/10.1021/ci980137x" ;
    ns3:short_name "BCUT" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "BCUT"@en .

cheminf:CHEMINF_001501 a owl:Class ;
    rdfs:label "bond partial pi charge"@en ;
    dc:description "Descriptor that calculates bond-pi Partial charge of a bond by determining the difference the Partial Pi Charge on atoms A and B of a bond (based in Gasteiger Charge)." ;
    ns3:short_name "bondPartialPiCharge" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "BondPartialPiCharge"@en .

cheminf:CHEMINF_001502 a owl:Class ;
    rdfs:label "bond partial sigma charge"@en ;
    dc:description "Descriptor that calculates bond-sigma Partial charge of a bond." ;
    ns3:short_name "bondPartialSigmaCharge" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "BondPartialSigmaCharge"@en .

cheminf:CHEMINF_001503 a owl:Class ;
    rdfs:label "bond partial total charge"@en ;
    dc:description "Descriptor that calculates bond-total Partial charge of a bond." ;
    ns3:short_name "bondPartialTCharge" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "BondPartialTotalCharge"@en .

cheminf:CHEMINF_001504 a owl:Class ;
    rdfs:label "bond sigma electronegativity"@en ;
    dc:description "Descriptor that calculates of bond-Polarizability of a bond by determining the difference the Sigma electronegativity on atoms A and B of a bond." ;
    ns3:short_name "bondSigmaElectronegativity" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "BondSigmaElectronegativity"@en .

cheminf:CHEMINF_001505 a owl:Class ;
    rdfs:label "bonds to Atom"@en ;
    dc:description "Descriptor based on the number of bonds on the shortest path between two atoms (topological distance)." ;
    ns3:short_name "bondsToAtom" ;
    rdfs:comment "This is the shortest distance between a pair of atoms in a graph, defined as the number of edges in the shortest path between the atom pair in the molecular graph." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "BondsToAtom"@en .

cheminf:CHEMINF_001506 a owl:Class ;
    rdfs:label "chi chain indices"@en ;
    dc:description "Evluates the simple and valence chi chain descriptors (Kier and Hall) of orders 3, 4, 5, 6 and 7. " ;
    ns3:short_name "chiChain" ;
    rdfs:comment "It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ChiChainIndices"@en .

cheminf:CHEMINF_001507 a owl:Class ;
    rdfs:label "chi cluster indices"@en ;
    dc:description "Evluates the simple and valence chi cluster descriptors (Kier and Hall) of orders 3, 4,5 and 6." ;
    ns3:short_name "chiCluster" ;
    rdfs:comment " It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ChiClusterIndices"@en .

cheminf:CHEMINF_001508 a owl:Class ;
    rdfs:label "chi path indices"@en ;
    dc:description "Evaluates the Kier and Hall Chi path indices of orders 0,1,2,3,4,5,6 and 7.  " ;
    ns3:short_name "chiPath" ;
    rdfs:comment "It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ChiPathIndices"@en .

cheminf:CHEMINF_001509 a owl:Class ;
    rdfs:label "chi path-cluster indices"@en ;
    dc:description "Evaluates the Kier and Hall Chi path cluster indices of orders 4,5 and 6." ;
    ns3:short_name "chiPathCluster" ;
    rdfs:comment "It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ChiPathMinusclusterIndices"@en .

cheminf:CHEMINF_001511 a owl:Class ;
    rdfs:label "gravitational index (square and cube roots)"@en ;
    dc:description "Descriptor characterizing the mass distribution of the molecule as the square or cube root of the gravitational index." ;
    bibo:doi "http://dx.doi.org/10.1021/ci980029a" ;
    ns3:short_name "gravitationalIndex_SquareAndCubeRoots" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_001510 ;
    skos:prefLabel "GravitationalIndex(squareAndCubeRoots)"@en .

cheminf:CHEMINF_001512 a owl:Class ;
    rdfs:label "acceptor field atoms (Boehm,Klebe)"@en ;
    dc:description "Counts the number of acceptor field atoms for a carbonyl oxygen probe using force field based definition." ;
    bibo:doi "http://dx.doi.org/10.1021/jm011039x" ;
    ns3:short_name "hBondAcceptorsBoehmKlebe" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "AcceptorFieldAtoms(Boehm,Klebe)"@en .

cheminf:CHEMINF_001513 a owl:Class ;
    rdfs:label "hydrogen bond acceptors (Daylight)"@en ;
    dc:description "Descriptor that calculates the number of hydrogen bond acceptors (by Daylight)." ;
    ns3:short_name "hBondacceptorsDaylight" ;
    rdfs:comment "SMILES on-line tutorial, http://www.daylight.com/dayhtml_tutorials/languages/smarts/smarts_examples.html)" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "HydrogenBondAcceptors(Daylight)"@en .

cheminf:CHEMINF_001514 a owl:Class ;
    rdfs:label "acceptors or donors field atoms (Boehm,Klebe)"@en ;
    dc:description "Counts the number of acceptor/donor field atoms for a carbonyl oxygen or amino hydrogen probe. " ;
    bibo:doi "http://dx.doi.org/10.1021/jm011039x" ;
    ns3:short_name "hBondAcceptorsDonorsBoehmKlebe" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "AcceptorsOrDonorsFieldAtoms(Boehm,Klebe)"@en .

cheminf:CHEMINF_001515 a owl:Class ;
    rdfs:label "donor field atoms (Boehm,Klebe)"@en ;
    dc:description "Counts the number of donor field atoms for an amino hydrogen probe." ;
    bibo:doi "http://dx.doi.org/10.1021/jm011039x" ;
    ns3:short_name "hBondDonorsBoehmKlebe" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "DonorFieldAtoms(Boehm,Klebe)"@en .

cheminf:CHEMINF_001516 a owl:Class ;
    rdfs:label "hydrogen bond donors (Daylight)"@en ;
    dc:description "Descriptor that calculates the number of hydrogen bond donors (by Daylight)." ;
    ns3:short_name "hBondDonorsDaylight" ;
    rdfs:comment "SMILES on-line tutorial, http://www.daylight.com/dayhtml_tutorials/languages/smarts/smarts_examples.html)" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "HydrogenBondDonors(Daylight)"@en .

cheminf:CHEMINF_001517 a owl:Class ;
    rdfs:label "proton belonging to an aromatic system"@en ;
    dc:description "Descriptor returns 1 if the protons is directly bonded to an aromatic system, it returns 2 if the distance between aromatic system and proton is 2 bonds, and it return 0 for other positions." ;
    ns3:short_name "isProtonInAromaticSystem" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000136 ;
    skos:prefLabel "ProtonBelongingToAnAromaticSystem"@en .

cheminf:CHEMINF_001518 a owl:Class ;
    rdfs:label "proton belonging to a pi-system"@en ;
    dc:description "Descriptor returns true if the protons is directly bonded to a pi system." ;
    ns3:short_name "isProtonInConjugatedPiSystem" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000136 ;
    skos:prefLabel "ProtonBelongingToAPiMinussystem"@en .

cheminf:CHEMINF_001519 a owl:Class ;
    rdfs:label "Kier Hall SMARTS"@en ;
    dc:description "Counts the number of occurrences of the E-state fragments." ;
    bibo:doi "http://dx.doi.org/10.3390/91201004" ;
    ns3:short_name "kierHallSmarts" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "KierHallSMARTS"@en .

cheminf:CHEMINF_001520 a owl:Class ;
    rdfs:label "molecular distance edge"@en ;
    dc:description "Evaluate molecular distance edge descriptors for C, N and O." ;
    bibo:doi "http://dx.doi.org/10.1021/ci970109z" ;
    ns3:short_name "mde" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "MolecularDistanceEdge"@en .

cheminf:CHEMINF_001521 a owl:Class ;
    rdfs:label "moments of inertia"@en ;
    dc:description "Descriptor that calculates the principal moments of inertia and ratios of the principal moments. Als calculates the radius of gyration." ;
    ns3:short_name "momentOfInertia" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000093 ;
    skos:prefLabel "MomentsOfInertia"@en .

cheminf:CHEMINF_001522 a owl:Class ;
    rdfs:label "partial total charge (MMFF94)"@en ;
    dc:description "Descriptor that calculates total partial charges of an heavy atom." ;
    ns3:short_name "partialTChargeMMFF94" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "PartialTotalCharge(MMFF94)"@en .

cheminf:CHEMINF_001523 a owl:Class ;
    rdfs:label "period of an atom"@en ;
    dc:description "Descriptor that returns the period in the periodic table of an atom belonging to an atom container." ;
    ns3:short_name "period" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000136 ;
    skos:prefLabel "PeriodOfAnAtom"@en .

cheminf:CHEMINF_001524 a owl:Class ;
    rdfs:label "pi-contact of two atoms"@en ;
    dc:description "Descriptor that check if two atoms have pi-contact (this is true when there is one and the same conjugated pi-system which contains both atoms, or directly linked neighboors of the atoms)." ;
    ns3:short_name "piContact" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000136 ;
    skos:prefLabel "PiMinuscontactOfTwoAtoms"@en .

cheminf:CHEMINF_001525 a owl:Class ;
    rdfs:label "proton total partial charge"@en ;
    dc:description "Descriptor that calculates partial charges of an heavy atom and its protons based on Gasteiger Marsili (PEOE)." ;
    ns3:short_name "protonPartialCharge" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "ProtonTotalPartialCharge"@en .

cheminf:CHEMINF_001526 a owl:Class ;
    rdfs:label "RDF proton descriptor"@en ;
    dc:description "Calculation of RDF proton descriptor." ;
    bibo:doi "http://dx.doi.org/10.1021/ac010737m" ;
    ns3:short_name "rdfProtonCalculatedValues" ;
    rdfs:comment "This is a mixed descriptor: topological, geometrical and electronic descriptor." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "RDFProtonDescriptor"@en .

cheminf:CHEMINF_001527 a owl:Class ;
    rdfs:label "TAE RECON descriptors for amino acid sequences"@en ;
    dc:description "Descriptors are derived from pre-calculated quantum mechanical parameters by using the paramaters for amino acids and evaluating a set of 147 descriptors for peptide sequences." ;
    bibo:doi "http://dx.doi.org/10.1016/0097-8485(94)00052-G" ;
    ns3:short_name "taeAminoAcid" ;
    rdfs:comment "{@cdk.cite BREN1995} {@cdk.cite BREN1997} {@cdk.cite WHITE2003}" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "TAERECONDescriptorsForAminoAcidSequences"@en .

cheminf:CHEMINF_001528 a owl:Class ;
    rdfs:label "weighted path"@en ;
    dc:description "The weighted path (molecular ID) descriptors were described by Randic and they characterize molecular branching." ;
    ns3:short_name "weightedPath" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "WeightedPath"@en .

cheminf:CHEMINF_001529 a owl:Class ;
    rdfs:label "WHIM"@en ;
    dc:description "Holistic descriptors described by Todeschini et al." ;
    ns3:short_name "WHIM" ;
    rdfs:comment "Todeschini, R. and Gramatica, P.. New 3D Molecular Descriptors: The WHIM theory and QAR Applications, Persepectives in Drug Discovery and Design. 1998, pp. 355-380. Mixed descriptors: molecular size, shape, symmetry, and atom distribution and density. Uses 3D coordinates, PCA and it calculates 10 descriptors." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "WHIM"@en .

cheminf:CHEMINF_001530 a owl:Class ;
    rdfs:label "Moreau-Broto Autocorrelation (charge) descriptors"@en ;
    dc:description "The Moreau-Broto autocorrelation descriptors using partial charges." ;
    ns3:short_name "autoCorrelationCharge" ;
    rdfs:comment "ATSc1 - ATSc5" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "MoreauMinusBrotoAutocorrelation(charge)Descriptors"@en .

cheminf:CHEMINF_001531 a owl:Class ;
    rdfs:label "Moreau-Broto autocorrelation (mass) descriptors"@en ;
    dc:description "The Moreau-Broto autocorrelation descriptors using atomic weight." ;
    ns3:short_name "autoCorrelationMass" ;
    rdfs:comment "ATSm1 - ATSm5" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "MoreauMinusBrotoAutocorrelation(mass)Descriptors"@en .

cheminf:CHEMINF_001532 a owl:Class ;
    rdfs:label "Moreau-Broto autocorrelation (polarizability) descriptors"@en ;
    dc:description "The Moreau-Broto autocorrelation descriptors using polarizability." ;
    ns3:short_name "autoCorrelationPolarizability" ;
    rdfs:comment "ATSp1 - ATSp5" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "MoreauMinusBrotoAutocorrelation(polarizability)Descriptors"@en .

cheminf:CHEMINF_001533 a owl:Class ;
    rdfs:label "carbon types"@en ;
    dc:description "Characterizes the carbon connectivity in terms of hybridization" ;
    ns3:short_name "carbonTypes" ;
    rdfs:comment "C1SP1, C2SP1, C1SP2, C2SP2, C3SP2, C1SP3, C2SP3, C3SP3, C4SP3" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "CarbonTypes"@en .

cheminf:CHEMINF_001534 a owl:Class ;
    rdfs:label "carbon connectivity index (order 0)"@en ;
    dc:description "Descriptor that calculates the carbon connectivity index (order 0). " ;
    ns3:short_name "chi0C" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "CarbonConnectivityIndex(order0)"@en .

cheminf:CHEMINF_001535 a owl:Class ;
    rdfs:label "valence connectivity index (order 0)"@en ;
    dc:description "Descriptor that calculates atomic valence connectivity index (order 0). " ;
    ns3:short_name "chi0v" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ValenceConnectivityIndex(order0)"@en .

cheminf:CHEMINF_001536 a owl:Class ;
    rdfs:label "valence carbon connectivity index (order 0)"@en ;
    dc:description "Descriptor that calculates carbon valence connectivity index (order 0)." ;
    ns3:short_name "chi0vC" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ValenceCarbonConnectivityIndex(order0)"@en .

cheminf:CHEMINF_001537 a owl:Class ;
    rdfs:label "carbon connectivity index (order 1)"@en ;
    dc:description "Descriptor that calculates carbon connectivity index (order 1). " ;
    ns3:short_name "chi1C" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "CarbonConnectivityIndex(order1)"@en .

cheminf:CHEMINF_001538 a owl:Class ;
    rdfs:label "valence connectivity index (order 1)"@en ;
    dc:description "Descriptor that calculates atomic valence connectivity index (order 1). " ;
    ns3:short_name "chi1v" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ValenceConnectivityIndex(order1)"@en .

cheminf:CHEMINF_001539 a owl:Class ;
    rdfs:label "valence carbon connectivity index (order 1)"@en ;
    dc:description "Descriptor that calculates carbon valence connectivity index (order 1). " ;
    ns3:short_name "chi1vC" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "ValenceCarbonConnectivityIndex(order1)"@en .

cheminf:CHEMINF_001540 a owl:Class ;
    rdfs:label "distance to atom"@en ;
    dc:description "Descriptor that calculates the 3D distance between two atoms." ;
    ns3:short_name "distanceToAtom" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000093 ;
    skos:prefLabel "DistanceToAtom"@en .

cheminf:CHEMINF_001541 a owl:Class ;
    rdfs:label "effective polarizability"@en ;
    dc:description "Descriptor that calculates the effective polarizability of a given heavy atom." ;
    ns3:short_name "effectivePolarizability" ;
    rdfs:comment "EffectiveAtomPolarizabilityDescriptor, effAtomPol" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "EffectivePolarizability"@en .

cheminf:CHEMINF_001542 a owl:Class ;
    rdfs:label "hybridization ratio"@en ;
    dc:description "Characterizes molecular complexity in terms of carbon hybridization states." ;
    ns3:short_name "hybratio" ;
    rdfs:comment "It reports the fraction of sp3 carbons to sp2 carbons as Nsp3/ (Nsp3 + Nsp2). The original form of the descriptor (i.e., simple ratio) has been used to characterize molecular complexity, especially in the are of natural products , which usually have a high value of the sp3 to sp2 ratio. Other short names: HybridizationRatio, HybRatio." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "HybridizationRatio"@en .

cheminf:CHEMINF_001543 a owl:Class ;
    rdfs:label "Kier and Hall kappa molecular shape indices"@en ;
    dc:description "Descriptor that calculates Kier and Hall kappa molecular shape indices." ;
    ns3:short_name "kierValues" ;
    rdfs:comment "Kier and Hall kappa molecular shape indices compare the molecular graph with minimal and maximal molecular graphs. First kappa shape index is given by n ( n - 1 ) 2 m 2 , second kappa shape index is given by ( n - 1 ) ( n - 2 ) 2 p 2 2 and third kappa shape index is given by ( n - 1 ) ( n - 3 ) 2 p 3 2 for odd n and ( n - 3 ) ( n - 2 ) 2 p 3 2 for enev n, where n denotes the number of atoms in the hydrogen suppressed graph, m is the number of bonds in the hydrogen suppressed graph. Also, let p2 denote the number of paths of length 2 and let p3 denote the number of paths of length 3. Other short names: KappaShapeIndices, Kier1, Kier2, Kier3." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "KierAndHallKappaMolecularShapeIndices"@en .

cheminf:CHEMINF_001544 a owl:Class ;
    rdfs:label "partial pi charge"@en ;
    dc:description "Descriptor that calculates pi partial charges in pi-bonded systems of an heavy atom based on based on Gasteiger H.Saller (PEPE)." ;
    bibo:doi "http://dx.doi.org/10.1002/ange.19850970818" ;
    ns3:short_name "partialPiCharge" ;
    rdfs:comment "Other short_name: pepe." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "PartialPiCharge"@en .

cheminf:CHEMINF_001545 a owl:Class ;
    rdfs:label "partial sigma charge"@en ;
    dc:description "Descriptor that calculates sigma partial charges in sigma-bonded systems (PEOE) of an heavy atom based on Gasteiger Marsili." ;
    bibo:doi "http://dx.doi.org/10.1016/0040-4020(80)80168-2" ;
    ns3:short_name "partialSigmaCharge" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "PartialSigmaCharge"@en .

cheminf:CHEMINF_001546 a owl:Class ;
    rdfs:label "pi electronegativity"@en ;
    dc:description "Descriptor that returns the pi electronegativity for a given atom." ;
    ns3:short_name "piElectronegativity" ;
    rdfs:comment "Pi electronegativity is given by X = a + b q + c ( q 2 ) , where a, b and c are Gasteiger Marsili parameters, and q is the sigma charge. Other short_name: elecPiA." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "PiElectronegativity"@en .

