cheminf:CHEMINF_000169 a owl:Class ;
    rdfs:label "relative positive charge" ;
    dc:description "most positive charge / total positive charge" ;
    ns2:short_name "RPCG" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "RelativePositiveCharge"@en .

cheminf:CHEMINF_000170 a owl:Class ;
    rdfs:label "relative negative charge" ;
    dc:description "most negative charge / total negative charge" ;
    ns2:short_name "RNCG" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "RelativeNegativeCharge"@en .

cheminf:CHEMINF_000171 a owl:Class ;
    rdfs:label "relative positive charge surface area" ;
    dc:description "most positive surface area * RPCG" ;
    ns2:short_name "RPCS" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "RelativePositiveChargeSurfaceArea"@en .

cheminf:CHEMINF_000172 a owl:Class ;
    rdfs:label "relative negative charge surface area" ;
    dc:description "most negative surface area * RNCG" ;
    ns2:short_name "RNCS" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "RelativeNegativeChargeSurfaceArea"@en .

cheminf:CHEMINF_000173 a owl:Class ;
    rdfs:label "THSA" ;
    dc:description "sum of solvent accessible surface areas of atoms with absolute value of partial charges less than 0.2" ;
    ns2:short_name "THSA" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "THSA"@en .

cheminf:CHEMINF_000175 a owl:Class ;
    rdfs:label "RHSA" ;
    dc:description "THSA / total molecular surface area" ;
    ns2:short_name "RHSA" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "RHSA"@en .

cheminf:CHEMINF_000176 a owl:Class ;
    rdfs:label "RPSA" ;
    dc:description "TPSA / total molecular surface area" ;
    ns2:short_name "RPSA" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "RPSA"@en .

cheminf:CHEMINF_000178 a owl:Class ;
    rdfs:label "collection of 3D atomic coordinates" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000177 ;
    skos:prefLabel "CollectionOf3DAtomicCoordinates"@en .

cheminf:CHEMINF_000179 a owl:Class ;
    rdfs:label "molecular polarizability"@en ;
    dc:description "Sum of the absolute value of the difference between atomic polarizabilities of all bonded atoms in the molecule (including implicit hydrogens)" ;
    ns2:short_name "BPol" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000094 ;
    skos:prefLabel "MolecularPolarizability"@en .

cheminf:CHEMINF_000180 a owl:Class ;
    rdfs:label "fragment complexity descriptor"@en ;
    dc:description "defined as @cdk.cite{Nilakantan06}" ;
    ns2:short_name "FragmentComplexity" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000219 ;
    skos:prefLabel "FragmentComplexityDescriptor"@en .

cheminf:CHEMINF_000181 a owl:Class ;
    rdfs:label "vertex adjacency matrix descriptor"@en ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000093 ;
    skos:prefLabel "VertexAdjacencyMatrixDescriptor"@en .

cheminf:CHEMINF_000182 a owl:Class ;
    rdfs:label "Petitjean Topological Shape Index"@en ;
    dc:description "A measure of the anisotropy in a molecule (as per Petitjean et al)" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000185 ;
    skos:prefLabel "PetitjeanTopologicalShapeIndex"@en .

cheminf:CHEMINF_000183 a owl:Class ;
    rdfs:label "Petitjean Geometric Shape Index"@en ;
    dc:description "A measure of the anisotropy in a molecule (as per Bath et al)" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000185 ;
    skos:prefLabel "PetitjeanGeometricShapeIndex"@en .

cheminf:CHEMINF_000184 a owl:Class ;
    rdfs:label "Petitjean number"@en ;
    dc:description "the eccentricity of a vertex corresponds to the distance from that vertex to the most remote vertex in the graph. The distance is obtained from the distance matrix as the count of edges between the two vertices. If r i is the largest matrix entry in row i of the distance matrix D, then the radius is defined as the smallest of the r i . The graph diameter D is defined as the largest vertex eccentricity in the graph. Petitjean Number is the value of ( diameter - radius ) diameter ." ;
    ns2:short_name "petitjeanNumber" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "PetitjeanNumber"@en .

cheminf:CHEMINF_000187 a owl:Class ;
    rdfs:label "MLogP descriptor"@en ;
    dc:description "A LogP descriptor based on a simple equation using the number of carbons and hetero atoms." ;
    ns2:short_name "MannholdLogP" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000251 ;
    skos:prefLabel "MLogPDescriptor"@en .

cheminf:CHEMINF_000188 a owl:Class ;
    rdfs:label "maximal ratio of length to breadth descriptor"@en ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000189 ;
    skos:prefLabel "MaximalRatioOfLengthToBreadthDescriptor"@en .

cheminf:CHEMINF_000190 a owl:Class ;
    rdfs:label "minimal ratio of length to breadth descriptor"@en ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000189 ;
    skos:prefLabel "MinimalRatioOfLengthToBreadthDescriptor"@en .

cheminf:CHEMINF_000191 a owl:Class ;
    rdfs:label "ionization energy descriptor"@en ;
    ns1:IAO_0000115 """An ionization energy descriptor is a descriptor that describes the minimum amount of energy required to remove an electron (to an infinite distance) from an atom or molecule in a gaseous state.

X + energy → X+ + e-

The term 'ionization potential' has historically been used but is now no longer recommended. """ ;
    ns1:IAO_0000118 "ionization energy",
        "ionization enthalpy",
        "ionization potential" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000094 ;
    skos:prefLabel "IonizationEnergyDescriptor"@en .

cheminf:CHEMINF_000192 a owl:Class ;
    rdfs:label "eccentric connectivity index descriptor"@en ;
    ns2:short_name "EccentricConnectivityIndex" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "EccentricConnectivityIndexDescriptor"@en .

cheminf:CHEMINF_000194 a owl:Class ;
    rdfs:label "acid dissociation constant"@en ;
    dc:description "the acid dissociation constant, Ka, is quantitative measure of the strength of an acid in solution. It is the equilibrium constant for a chemical reaction known as dissociation in the context of acid-base reactions." ;
    ns2:short_name "Ka" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000193 ;
    skos:prefLabel "AcidDissociationConstant"@en .

cheminf:CHEMINF_000198 a owl:Class ;
    rdfs:label "molecular weight calculated by pipeline pilot" ;
    ns1:IAO_0000115 "A molecular weight descriptor calculated by a relevant module of the Pipeline Pilot software tool. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000216 ;
    skos:prefLabel "MolecularWeightCalculatedByPipelinePilot"@en .

cheminf:CHEMINF_000199 a owl:Class ;
    rdfs:label "absolute SMILES descriptor"@en ;
    dc:description "An absolute SMILES descriptor is an isomeric SMILES descriptor that is produced using a canonicalization algorithm. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000032 ;
    skos:prefLabel "AbsoluteSMILESDescriptor"@en .

cheminf:CHEMINF_000223 a owl:Class ;
    rdfs:label "pi-system size" ;
    dc:description "The integer number of atoms in a pi-orbital system." ;
    ns2:short_name "LargestPiSystem" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        [ a owl:Restriction ;
            owl:onProperty cheminf:CHEMINF_000012 ;
            owl:someValuesFrom xsd:int ],
        cheminf:CHEMINF_000209,
        pink:Data ;
    skos:prefLabel "PiMinussystemSize"@en .

cheminf:CHEMINF_000224 a owl:Class ;
    rdfs:label "bond dissociation Gibbs energy descriptor" ;
    dc:description "Bond dissociation Gibbs energy descriptor captures the Gibbs energy associated with the process of breaking the bond in question. This could be measured or calculated in vacuo or in a specific Solvent, at a given temperature and pressure. Depends on molecular conformation." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000210 ;
    skos:prefLabel "BondDissociationGibbsEnergyDescriptor"@en .

cheminf:CHEMINF_000225 a owl:Class ;
    rdfs:label "solvation Gibbs energy descriptor" ;
    dc:description "The molecular entity solvation Gibbs energy descriptor reflects the Gibbs energy associated with the solvation of the molecular entity in question. This could be measured or calculated in vacuo or in a specific solvent, at a particular temperature and pressure. Depends on molecular conformation when computed." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000208 ;
    skos:prefLabel "SolvationGibbsEnergyDescriptor"@en .

cheminf:CHEMINF_000226 a owl:Class ;
    rdfs:label "bond charge density descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000231 ;
    skos:prefLabel "BondChargeDensityDescriptor"@en .

cheminf:CHEMINF_000232 a owl:Class ;
    rdfs:label "aromatic atom count" ;
    dc:description "A descriptor that provides the integer count of aromatic atoms in a given molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        [ a owl:Restriction ;
            owl:onProperty cheminf:CHEMINF_000012 ;
            owl:someValuesFrom xsd:int ],
        cheminf:CHEMINF_000263 ;
    skos:prefLabel "AromaticAtomCount"@en .

cheminf:CHEMINF_000234 a owl:Class ;
    rdfs:label "PubChem conformer identifier"@en ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000140 ;
    skos:prefLabel "PubChemConformerIdentifier"@en .

cheminf:CHEMINF_000237 a owl:Class ;
    rdfs:label "bond aromaticity descriptor" ;
    dc:description "A bond aromaticity descriptor is an aromaticity descriptor associated with a bond within a chemical entity which indicates whether that  bond belongs to an aromatic system." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cheminf:CHEMINF_000012 ;
            owl:someValuesFrom xsd:boolean ],
        cheminf:CHEMINF_000056,
        pink:Data ;
    skos:prefLabel "BondAromaticityDescriptor"@en .

cheminf:CHEMINF_000239 a owl:Class ;
    rdfs:label "formation Gibbs energy descriptor" ;
    dc:description "The formation Gibbs energy descriptor captures the Gibbs energy associated with the formation of a molecular entity, relative to the standard state of constituent atoms. This can be measured, calculated in vacuo, or calculated with respect to a specific solvent, at a particular temperature and pressure. When calculated, the formation Gibbs energy value depends on the molecular conformation." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000207 ;
    skos:prefLabel "FormationGibbsEnergyDescriptor"@en .

cheminf:CHEMINF_000240 a owl:Class ;
    rdfs:label "size of largest aliphatic chain" ;
    dc:description "The largest aliphatic chain size descriptor is a count descriptor that gives the integer length (number of atoms) in the largest unbranched chain of atoms that does not contain aromatic atoms, within a given molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        [ a owl:Restriction ;
            owl:onProperty cheminf:CHEMINF_000012 ;
            owl:someValuesFrom xsd:int ],
        cheminf:CHEMINF_000246 ;
    skos:prefLabel "SizeOfLargestAliphaticChain"@en .

cheminf:CHEMINF_000241 a owl:Class ;
    rdfs:label "formation enthalpy descriptor" ;
    ns1:IAO_0000118 "enthalpy of formation",
        "heat of formation" ;
    dc:description "Molecular entity formation enthaply descriptor captures the enthalpy associated with the formation of the molecular entity in question, relative to the standard state of constituent atoms. This could be measured or calculated in vacuo or in a specific Solvent, at a particular temperature and pressure. Depends on molecular conformation when computed." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000207 ;
    skos:prefLabel "FormationEnthalpyDescriptor"@en .

cheminf:CHEMINF_000243 a owl:Class ;
    rdfs:label "aromatic bond count" ;
    dc:description "A descriptor that provides the integer count of aromatic bonds in a given molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        [ a owl:Restriction ;
            owl:onProperty cheminf:CHEMINF_000012 ;
            owl:someValuesFrom xsd:int ],
        cheminf:CHEMINF_000233 ;
    skos:prefLabel "AromaticBondCount"@en .

cheminf:CHEMINF_000249 a owl:Class ;
    rdfs:label "solvation entropy descriptor" ;
    dc:description "The molecular entity solvation entropy descriptor reflects the entropy associated with the solvation of the molecular entity in question. This could be measured or calculated in vacuo or in a specific solvent, at a particular temperature and pressure. Depends on molecular conformation when computed." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000208 ;
    skos:prefLabel "SolvationEntropyDescriptor"@en .

cheminf:CHEMINF_000250 a owl:Class ;
    rdfs:label "solvation enthalpy descriptor" ;
    dc:description "The molecular entity solvation enthalpy descriptor reflects the enthalpy associated with the solvation of the molecular entity in question. This could be measured or calculated in vacuo or in a specific solvent, at a particular temperature and pressure. Depends on molecular conformation when computed." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000208 ;
    skos:prefLabel "SolvationEnthalpyDescriptor"@en .

cheminf:CHEMINF_000252 a owl:Class ;
    rdfs:label "bond dissociation enthalpy descriptor" ;
    dc:description "Bond dissociation enthalpy descriptor captures the enthalpy associated with the process of breaking the bond in question. This could be measured or calculated in vacuo or in a specific Solvent, at a given temperature and pressure. Depends on molecular conformation." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000210 ;
    skos:prefLabel "BondDissociationEnthalpyDescriptor"@en .

cheminf:CHEMINF_000256 a owl:Class ;
    rdfs:label "melting point descriptor" ;
    rdfs:comment "Melting point descriptor specifies the temperature at which a chemical substance undergoes the transition from solid to liquid state under standard conditions." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom cheminf:CHEMINF_000266 ],
        cheminf:CHEMINF_000025,
        <https://w3id.org/emmo/domain/microstructure#MeltingPointTemperature> ;
    skos:prefLabel "MeltingPointDescriptor"@en .

cheminf:CHEMINF_000260 a owl:Class ;
    rdfs:label "formation entropy descriptor" ;
    dc:description "Molecular entity formaiton entropy descriptor captures the entropy associated with the formation of the molecular entity in question, relative to the standard state of constituent atoms. This could be measured or calculated in vacuo or in a specific Solvent, at a particular temperature and pressure. Depends on molecular conformation when computed." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
