@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix cheminf: <http://semanticscience.org/resource/> .
@prefix datasettype: <https://w3id.org/pink/datasettype/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcatap: <http://data.europa.eu/r5r/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ddoc: <https://w3id.org/emmo/application/datadoc#> .
@prefix emmo: <https://w3id.org/emmo/hume#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <http://semanticscience.org/ontology/cheminf-core.owl#> .
@prefix ns3: <http://www.semanticweb.org/ontologies/cheminf.owl#> .
@prefix ns4: <http://www.geneontology.org/formats/oboInOwl#> .
@prefix ns5: <https://www.dublincore.org/specifications/dublin-core/dcmi-terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pink: <https://w3id.org/pink#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rights: <http://publications.europa.eu/resource/authority/access-right/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix vidoco: <https://w3id.org/widoco/vocab#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcatap:status a owl:AnnotationProperty .

ns1:IAO_0000111 a owl:AnnotationProperty .

ns1:IAO_0000112 a owl:AnnotationProperty .

ns1:IAO_0000114 a owl:AnnotationProperty .

ns1:IAO_0000115 a owl:AnnotationProperty .

ns1:IAO_0000116 a owl:AnnotationProperty .

ns1:IAO_0000117 a owl:AnnotationProperty .

ns1:IAO_0000118 a owl:AnnotationProperty .

ns1:IAO_0000119 a owl:AnnotationProperty .

ns1:RO_0000056 a owl:ObjectProperty ;
    rdfs:label "participates in"@en,
        "participates_in"@en ;
    ns1:IAO_0000111 "participates in"@en ;
    ns1:IAO_0000112 "this blood clot participates in this blood coagulation"@en,
        "this input material (or this output material) participates in this process"@en,
        "this investigator participates in this investigation"@en ;
    ns1:IAO_0000115 "a relation between a continuant and a process, in which the continuant is somehow involved in the process"@en ;
    ns1:IAO_0000118 "participates_in"@en ;
    ns4:hasAlternativeId "OBO_REL:0000020" ;
    ns4:hasOBONamespace "relationship" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subPropertyOf pink:participatesTo ;
    skos:prefLabel "participatesIn"@en .

dc:creator a owl:AnnotationProperty .

dc:date a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:source a owl:AnnotationProperty .

dcterms:LicenseDocument a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "License Document"@en ;
    dcterms:issued "2008-01-14T00:00:00"^^xsd:dateTime ;
    rdfs:comment "A legal document giving official permission to do something with a resource."@en ;
    rdfs:isDefinedBy <http://purl.org/dc/terms>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:subClassOf dcterms:RightsStatement .

dcterms:abstract a owl:AnnotationProperty ;
    rdfs:isDefinedBy <https://w3id.org/pink/matter#> .

dcterms:bibliographicCitation a owl:AnnotationProperty .

dcterms:contributor a owl:AnnotationProperty .

dcterms:created a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:description a owl:AnnotationProperty,
        owl:NamedIndividual ;
    rdfs:label "Description"@en ;
    dcterms:description "Description may include but is not limited to: an abstract, a table of contents, a graphical representation, or a free-text account of the resource."@en ;
    dcterms:issued "2008-01-14"^^xsd:date ;
    rdfs:comment "An account of the resource."@en ;
    rdfs:isDefinedBy <http://purl.org/dc/terms>,
        <https://w3id.org/pink/reused-terms#> .

dcterms:hasFormat a owl:AnnotationProperty .

dcterms:issued a owl:DatatypeProperty ;
    rdfs:label "releaseDate" ;
    rdfs:comment "The date of formal issuance (e.g., publication) of the resource." ;
    rdfs:isDefinedBy <https://w3id.org/pink/reused-terms#> ;
    rdfs:range xsd:dateTime .

dcterms:license a owl:AnnotationProperty .

dcterms:publisher a owl:AnnotationProperty .

dcterms:rightsHolder a owl:NamedIndividual,
        owl:ObjectProperty ;
    rdfs:label "rightsHolder"@en ;
    dcterms:description "A person or organization owning or managing rights over the resource."@en ;
    dcterms:issued "2004-06-14"^^xsd:date ;
    rdfs:isDefinedBy <http://purl.org/dc/terms>,
        <https://w3id.org/pink/reused-terms#> ;
    rdfs:range foaf:Agent ;
    rdfs:subPropertyOf pink:isRepresentedBy .

dcterms:title a owl:AnnotationProperty ;
    rdfs:isDefinedBy <https://w3id.org/pink/matter#> .

bibo:doi a owl:AnnotationProperty ;
    rdfs:isDefinedBy pink: .

bibo:status a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty ;
    rdfs:isDefinedBy pink: .

vann:preferredNamespaceUri a owl:AnnotationProperty ;
    rdfs:isDefinedBy pink: .

vann:usageNote a owl:AnnotationProperty ;
    rdfs:isDefinedBy pink: .

ns2:short_name a owl:AnnotationProperty .

cheminf:CHEMINF_000002 a owl:Class ;
    rdfs:label "atomic polarizability sum" ;
    dc:description "atomic polarizability sum is the sum of the atomic polarizabilities (including implicit hydrogens)." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000094 ;
    skos:prefLabel "AtomicPolarizabilitySum"@en .

cheminf:CHEMINF_000003 a owl:Class ;
    rdfs:label "partial positive surface area" ;
    dc:description "sum of surface area on positive parts of molecule" ;
    ns2:short_name "PPSA-1" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "PartialPositiveSurfaceArea"@en .

cheminf:CHEMINF_000004 a owl:Class ;
    rdfs:label "PPSA-2" ;
    dc:description "partial positive surface area * total positive charge on the molecule" ;
    ns2:short_name "PPSA-2" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "PPSAMinus2"@en .

cheminf:CHEMINF_000006 a owl:Class ;
    rdfs:label "R stereochemical descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000005 ;
    owl:disjointWith cheminf:CHEMINF_000034 ;
    skos:prefLabel "RStereochemicalDescriptor"@en .

cheminf:CHEMINF_000008 a owl:Class ;
    rdfs:label "charge weighted partial positive surface area" ;
    dc:description "charge weighted partial positive surface area" ;
    ns2:short_name "PPSA-3" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "ChargeWeightedPartialPositiveSurfaceArea"@en .

cheminf:CHEMINF_000010 a owl:Class ;
    rdfs:label "atomic order" ;
    dc:description "Atomic order is an atomic descriptor that specifies the ordinal position of an atom." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        [ a owl:Restriction ;
            owl:onProperty cheminf:CHEMINF_000012 ;
            owl:someValuesFrom xsd:int ],
        cheminf:CHEMINF_000041,
        pink:Data ;
    skos:prefLabel "AtomicOrder"@en .

cheminf:CHEMINF_000011 a owl:Class ;
    rdfs:label "partial negative surface area" ;
    dc:description "sum of surface area on negative parts of molecule" ;
    ns2:short_name "PNSA-1" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "PartialNegativeSurfaceArea"@en .

cheminf:CHEMINF_000015 a owl:Class ;
    rdfs:label "PNSA-2" ;
    dc:description "partial negative surface area * total negative charge on the molecule" ;
    ns2:short_name "PNSA-2" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000229 ;
    skos:prefLabel "PNSAMinus2"@en .

cheminf:CHEMINF_000019 a owl:Class ;
    rdfs:label "SMARTS descriptor" ;
    dc:description "A SMARTS descriptor is a molecular structure descriptor that conforms to the SMARTS specification." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000085 ;
    skos:prefLabel "SMARTSDescriptor"@en .

cheminf:CHEMINF_000046 a owl:Class ;
    rdfs:label "zagreb index" ;
    dc:description "The sum of the squared atom degrees of all heavy atoms." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000209 ;
    skos:prefLabel "ZagrebIndex"@en .

cheminf:CHEMINF_000049 a owl:Class ;
    rdfs:label "+ stereochemical descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000048 ;
    owl:disjointWith cheminf:CHEMINF_000050 ;
    skos:prefLabel "PlusStereochemicalDescriptor"@en .

cheminf:CHEMINF_000052 a owl:Class ;
    rdfs:label "D stereochemical descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000051 ;
    owl:disjointWith cheminf:CHEMINF_000053 ;
    skos:prefLabel "DStereochemicalDescriptor"@en .

cheminf:CHEMINF_000055 a owl:Class ;
    rdfs:label "chemical connectivity table" ;
    dc:description "A chemical connectivity table is a structure descriptor which consists of a connection table representing bonds between atoms in a molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000085 ;
    skos:prefLabel "ChemicalConnectivityTable"@en .

cheminf:CHEMINF_000058 a owl:Class ;
    rdfs:label "MOLfile" ;
    dc:description "A MOLfile is a file which contains a MOLfile encoding of a chemical structure representation. It is the concretization of a MOLfile descriptor." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000057 ;
    skos:prefLabel "MOLfile"@en .

cheminf:CHEMINF_000062 a owl:Class ;
    rdfs:label "bond order descriptor" ;
    dc:description "A bond order descriptor is a descriptor associated with a bond in a chemical entity which indicates the order of the bond (single, double or triple)." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000093 ;
    skos:prefLabel "BondOrderDescriptor"@en .

cheminf:CHEMINF_000068 a owl:Class ;
    rdfs:label "functional group descriptor" ;
    dc:description "A functional group descriptor is a structural descriptor which describes specific groups of atoms within molecules that are responsible for the characteristic chemical reactions of those molecules." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000085 ;
    skos:prefLabel "FunctionalGroupDescriptor"@en .

cheminf:CHEMINF_000078 a owl:Class ;
    rdfs:label "neutron count" ;
    dc:description "The (integer) number of neutrons in the atoms nucleus." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000209 ;
    skos:prefLabel "NeutronCount"@en .

cheminf:CHEMINF_000079 a owl:Class ;
    rdfs:label "proton count" ;
    dc:description "The (integer) number of protons in the atoms nucleus." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000209 ;
    skos:prefLabel "ProtonCount"@en .

cheminf:CHEMINF_000081 a owl:Class ;
    rdfs:label "cis stereochemical descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000080 ;
    skos:prefLabel "CisStereochemicalDescriptor"@en .

cheminf:CHEMINF_000082 a owl:Class ;
    rdfs:label "trans stereochemical descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000080 ;
    skos:prefLabel "TransStereochemicalDescriptor"@en .

cheminf:CHEMINF_000084 a owl:Class ;
    rdfs:label "atomic mass descriptor" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000083 ;
    skos:prefLabel "AtomicMassDescriptor"@en .

cheminf:CHEMINF_000090 a owl:Class ;
    rdfs:label "atomic degree" ;
    dc:description "The integer number of non-H substituents of an atom." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000209 ;
    skos:prefLabel "AtomicDegree"@en .

cheminf:CHEMINF_000096 a owl:Class ;
    rdfs:label "atomic valence" ;
    dc:description "Atomic valence is an atomic descriptor that specifies the maximum number of univalent atoms (originally hydrogen or chlorine atoms) which may combine with an atom of the element under consideration, or with a fragment, or for which an atom of this element can be substituted [source: IUPAC Gold Book - http://goldbook.iupac.org/V06588.html]" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000087 ;
    skos:prefLabel "AtomicValence"@en .

cheminf:CHEMINF_000097 a owl:Class ;
    rdfs:label "atomic hardness descriptor" ;
    dc:description "An atomic hardness descriptor is an atomic descriptor that estimates the difference between the ionization potential and the electron affinity of a given atom." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000094 ;
    skos:prefLabel "AtomicHardnessDescriptor"@en .

cheminf:CHEMINF_000099 a owl:Class ;
    rdfs:label "atomic softness descriptor" ;
    dc:description "An atomic softness descriptor is an atomic descriptor which is about the charge delocalizing ability of a given atom." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000094 ;
    skos:prefLabel "AtomicSoftnessDescriptor"@en .

cheminf:CHEMINF_000104 a owl:Class ;
    rdfs:label "molecular QSAR descriptor" ;
    dc:description "A molecular QSAR descriptor is a OSAR descriptor which gives a quantitative value to some aspect of a molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000064 ;
    skos:prefLabel "MolecularQSARDescriptor"@en .

cheminf:CHEMINF_000105 a owl:Class ;
    rdfs:label "cycle basis" ;
    dc:description "The cycle basis of a molecular structure is the smallest set of cycles (closed paths) formed in the graph representation of the structure, from which all other cycles can be computed." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000085 ;
    skos:prefLabel "CycleBasis"@en .

cheminf:CHEMINF_000109 a owl:Class ;
    rdfs:label "trivial name" ;
    dc:description "A trivial name is a molecular entity name that is in common public use and may not be related to the structure of the molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000043 ;
    skos:prefLabel "TrivialName"@en .

cheminf:CHEMINF_000110 a owl:Class ;
    rdfs:label "fused cycles" ;
    dc:description "The fused cycles in a molecular structure are those cycles from the cycle basis which share at least one bond." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000085 ;
    skos:prefLabel "FusedCycles"@en .

cheminf:CHEMINF_000112 a owl:Class ;
    rdfs:label "atomic QSAR descriptor" ;
    dc:description "An atomic QSAR descriptor is a QSAR descriptor which gives a quantitative value to some aspect of an atom which is part of a molecular entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000064 ;
    skos:prefLabel "AtomicQSARDescriptor"@en .

cheminf:CHEMINF_000114 a owl:Class ;
    rdfs:label "MOLfile descriptor" ;
    dc:description "A MOLfile descriptor is a structure descriptor which conforms to the MOLfile format specification." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_23367 ],
        cheminf:CHEMINF_000085 ;
    skos:prefLabel "MOLfileDescriptor"@en .

cheminf:CHEMINF_000116 a owl:Class ;
    rdfs:label "atomic connectivity index" ;
    dc:description "An atomic connectivity index is an atomic descriptor that is a measure of atomic connectivity, which can take various forms (e.g. zero-order, or first-order)." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000093 ;
    skos:prefLabel "AtomicConnectivityIndex"@en .

cheminf:CHEMINF_000117 a owl:Class ;
    rdfs:label "Wiener path number" ;
    dc:description "Half the sum of all the distance matrix entries, topological index of atom-atom distances." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "WienerPathNumber"@en .

cheminf:CHEMINF_000118 a owl:Class ;
    rdfs:label "formal charge descriptor" ;
    dc:description """The formal charge gives the charge assigned to an atom in a molecule, assuming that electrons in a chemical bond are shared equally between atoms, regardless of relative electronegativity.
The formal charge of any atom in a molecule can be calculated by the following equation: FC = number of valence electrons of the atom in isolation (atom in ground state) - number of non-bonding electrons on this atom in the molecule - half the total number of electrons shared in covalent bonds with other atoms in the molecule. [source:wikipedia]""" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000131 ;
    skos:prefLabel "FormalChargeDescriptor"@en .

cheminf:CHEMINF_000119 a owl:Class ;
    rdfs:label "partial charge descriptor" ;
    dc:description "A partial charge descriptor gives the charge with an absolute value of less than one elementary charge unit (that is, smaller than the charge of the electron). [source:wikipedia]" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000131 ;
    skos:prefLabel "PartialChargeDescriptor"@en .

cheminf:CHEMINF_000122 a owl:Class ;
    rdfs:label "electronegativity descriptor" ;
    dc:description "An electronegativity descriptor is a chemical descriptor that is about the electronegativity quality of an atom." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns1:IAO_0000136 ;
            owl:someValuesFrom ns1:CHEBI_33250 ],
        cheminf:CHEMINF_000087 ;
    skos:prefLabel "ElectronegativityDescriptor"@en .

cheminf:CHEMINF_000130 a owl:Class ;
    rdfs:label "bond multiplicity descriptor" ;
    dc:description "A bond multiplicity descriptor is a chemical descriptor that in primitive cases is defined as half of the difference between the number of bonding and antibonding electrons in a particular system, but may also be defined with relation to the strength of a single bond." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000087 ;
    skos:prefLabel "BondMultiplicityDescriptor"@en .

cheminf:CHEMINF_000132 a owl:Class ;
    rdfs:label "bond length descriptor" ;
    dc:description "A bond length descriptor is a dimensional extent descriptor which gives the measured or predicted (idealised) length of an atom to atom bond within a chemical entity." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000060 ;
    skos:prefLabel "BondLengthDescriptor"@en .

cheminf:CHEMINF_000137 a owl:Class ;
    rdfs:label "Wiener polarity number descriptor" ;
    dc:description "Half the sum of all the distance matrix entries with a value of 3" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000092 ;
    skos:prefLabel "WienerPolarityNumberDescriptor"@en .

cheminf:CHEMINF_000141 a owl:Class ;
    rdfs:label "PubChem substance identifier (SID)" ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000302 ;
    skos:prefLabel "PubChemSubstanceIdentifier(SID)"@en .

cheminf:CHEMINF_000149 a owl:Class ;
    rdfs:label "generic SMILES descriptor"@en ;
    dc:description "a generic SMILES descriptor is a SMILES descriptor that denotes only the labeled molecular graph (i.e. atoms and bonds, but no chiral or isotopic information)." ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
    rdfs:subClassOf cheminf:CHEMINF_000018 ;
    skos:prefLabel "GenericSMILESDescriptor"@en .

cheminf:CHEMINF_000153 a owl:Class ;
