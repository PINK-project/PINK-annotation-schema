    skos:prefLabel "ECNumber"@en,
        "EINECSNo"@en,
        "EuropeanCommunityNumber"@en .

cheminf:CHEMINF_000448 a owl:Class ;
    rdfs:label "metal atom count"@en ;
    ns1:IAO_0000115 "A descriptor that specifies the integer count of metal atoms in a given chemical entity. " ;
    rdfs:isDefinedBy <https://w3id.org/pink/cheminf#> ;
