<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/pink/ddoc#"
     xml:base="https://w3id.org/pink/ddoc"
     xmlns:ns="http://www.w3.org/2006/vcard/ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:adms="http://www.w3.org/ns/adms#"
     xmlns:dcat="http://www.w3.org/ns/dcat#"
     xmlns:emmo="https://w3id.org/emmo#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:oteio="https://w3id.org/emmo/domain/oteio#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:datadoc="https://w3id.org/emmo/application/datadoc#">
    <owl:Ontology rdf:about="https://w3id.org/pink/ddoc">
        <owl:versionIRI rdf:resource="https://w3id.org/pink/0.0.1/ddoc"/>
        <terms:title xml:lang="en">Concepts defined in the ddoc vocabulary.</terms:title>
        <terms:title>Data documentation ontology</terms:title>
        <vann:preferredNamespacePrefix>ddoc</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/emmo/application/datadoc#</vann:preferredNamespaceUri>
        <owl:priorVersion>0.0.0</owl:priorVersion>
        <owl:versionInfo>0.0.1</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/abstract -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract">
        <terms:description>A summary of the resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>abstract</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/bibliographicCitation -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation">
        <terms:description>A bibliographic reference for the resource.</terms:description>
        <vann:usageNote>Recommended practice is to include sufficient bibliographic detail to identify the resource as unambiguously as possible.</vann:usageNote>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>bibliographicCitation</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description">
        <terms:description>A free-text account of the resource.</terms:description>
        <vann:usageNote>This property can be repeated for parallel language versions of the description.</vann:usageNote>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>description</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:mandatory</datadoc:conformance>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/identifier">
        <terms:description>URI or other unique identifier of the resource being described.</terms:description>
        <vann:usageNote>Recommended practice is to identify the resource by means of a string conforming to an identification system. Examples include International Standard Book Number (ISBN), Digital Object Identifier (DOI), and Uniform Resource Name (URN).  Persistent identifiers should be provided as HTTP URIs.</vann:usageNote>
        <rdfs:domain>foaf:Agent</rdfs:domain>
        <rdfs:label>identifier</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://purl.org/vocab/vann/usageNote -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/usageNote">
        <terms:description>A reference that provides information on how this resource is to be used.</terms:description>
        <rdfs:domain>rdfs:Resource</rdfs:domain>
        <rdfs:label>usageNote</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#comment -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#comment">
        <terms:description>A description of the subject resource. Use `description` instead.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>comment</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#label -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#label">
        <terms:description>Provides a human-readable version of a resource&apos;s name.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>label</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel">
        <terms:description>An alternative lexical label for a resource.</terms:description>
        <rdfs:domain>rdfs:Class</rdfs:domain>
        <rdfs:label>altLabel</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#hiddenLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#hiddenLabel">
        <terms:description>A lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations.</terms:description>
        <rdfs:domain>rdfs:Class</rdfs:domain>
        <rdfs:label>hiddenLabel</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#notation -->


