    <!-- http://data.europa.eu/eli/ontology#LegalResource -->


    <owl:Class rdf:about="http://data.europa.eu/eli/ontology#LegalResource">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>This class represents the legislation, policy or policies that lie behind the Rules that govern the service.</terms:description>
        <vann:usageNote>The definition and properties of the Legal Resource class are aligned with the ontology included in &quot;Council conclusions inviting the introduction of the European Legislation Identifier (ELI)&quot;. For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the (ELI) ontology. In this data specification the use is restricted to instances of this class that follow the (ELI) URI guidelines.</vann:usageNote>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/LicenseDocument -->


    <owl:Class rdf:about="http://purl.org/dc/terms/LicenseDocument">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A legal document giving official permission to do something with a resource.</terms:description>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/Location -->


    <owl:Class rdf:about="http://purl.org/dc/terms/Location">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A spatial region or named place.</terms:description>
        <vann:usageNote>It can be represented using a controlled vocabulary or with geographic coordinates. In the latter case, the use of the Core Location Vocabulary is recommended, following the approach described in the GeoDCAT-AP specification.</vann:usageNote>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/MediaType -->


    <owl:Class rdf:about="http://purl.org/dc/terms/MediaType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A media type, e.g. the format of a computer file.</terms:description>
        <vann:usageNote>Media type instances follow the [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) vocabulary using the &lt;http://www.iana.org/assignments/media-types/&gt; namespace. For example, the IRI of the media type `text/turtle` is &lt;http://www.iana.org/assignments/media-types/text/turtle&gt;.</vann:usageNote>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/RightsStatement -->


    <owl:Class rdf:about="http://purl.org/dc/terms/RightsStatement">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A statement about the intellectual property rights (IPR) held in or over a resource, a legal document giving official permission to do something with a resource, or a statement about access rights.</terms:description>
        <vann:usageNote>EU pre-defines the following individuals: accr:PUBLIC, accr:NON_PUBLIC, accr:CONFIDENTIAL, accr:RESTRICTED, accr:SENSITIVE.</vann:usageNote>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/Standard -->


    <owl:Class rdf:about="http://purl.org/dc/terms/Standard">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A standard or other specification to which a resource conforms.</terms:description>
    </owl:Class>
    


    <!-- http://spdx.org/rdf/terms#Checksum -->


    <owl:Class rdf:about="http://spdx.org/rdf/terms#Checksum">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A preferred label of the concept.</terms:description>
    </owl:Class>
    


    <!-- http://spdx.org/rdf/terms#ChecksumAlgorithm -->


    <owl:Class rdf:about="http://spdx.org/rdf/terms#ChecksumAlgorithm">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>Algorithm for Checksums.</terms:description>
        <vann:usageNote>This specification does not impose any additional requirements to properties for this entity.</vann:usageNote>
    </owl:Class>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#Class -->


    <owl:Class rdf:about="http://www.w3.org/2000/01/rdf-schema#Class">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>The class of classes.</terms:description>
    </owl:Class>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#Datatype -->


    <owl:Class rdf:about="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#Resource -->


    <owl:Class rdf:about="http://www.w3.org/2000/01/rdf-schema#Resource">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A generic resource defined by RDFS.</terms:description>
    </owl:Class>
    


    <!-- http://www.w3.org/2002/07/owl#Class -->


    <owl:Class rdf:about="http://www.w3.org/2002/07/owl#Class">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>The class of OWL classes.</terms:description>
        <rdfs:subClassOf>rdfs:Class</rdfs:subClassOf>
    </owl:Class>
    


