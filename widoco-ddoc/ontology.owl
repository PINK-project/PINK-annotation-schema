        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/dc/terms/type -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/type">
        <terms:description>A type of the resource.</terms:description>
        <vann:usageNote>A recommended controlled vocabulary data-type is foreseen. For agents, the value should be chosen from [ADMS publisher type](https://raw.githubusercontent.com/SEMICeu/ADMS-AP/master/purl.org/ADMS_SKOS_v1.00.rdf).</vann:usageNote>
        <rdfs:domain>dcterms:LicenseDocument</rdfs:domain>
        <rdfs:label>type</rdfs:label>
        <rdfs:range>skos:Concept</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://spdx.org/rdf/terms#algorithm -->


    <owl:ObjectProperty rdf:about="http://spdx.org/rdf/terms#algorithm">
        <terms:description>The algorithm used to produce the subject Checksum.</terms:description>
        <rdfs:domain>spdx:Checksum</rdfs:domain>
        <rdfs:label>algorithm</rdfs:label>
        <rdfs:range>spdx:ChecksumAlgorithm</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:ObjectProperty>
    


    <!-- http://spdx.org/rdf/terms#checksum -->


    <owl:ObjectProperty rdf:about="http://spdx.org/rdf/terms#checksum">
        <terms:description>A mechanism that can be used to verify that the contents of a distribution have not changed.</terms:description>
        <vann:usageNote>The checksum is related to the downloadURL.</vann:usageNote>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>checksum</rdfs:label>
        <rdfs:range>spdx:Checksum</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#domain -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#domain"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#isDefinedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#isDefinedBy">
        <terms:description>Indicate a resource defining the subject resource. This property may be used to indicate an RDF vocabulary in which a resource is described.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>isDefinedBy</rdfs:label>
        <rdfs:range>skos:Concept</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#range -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#range"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#seeAlso -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#seeAlso">
        <terms:description>Indicates a resource that might provide additional information about the subject resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>seeAlso</rdfs:label>
        <rdfs:range>skos:Concept</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#subClassOf -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
    


    <!-- http://www.w3.org/ns/adms#identifier -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/adms#identifier">
