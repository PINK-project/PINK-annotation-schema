        <terms:description>A keyword or tag describing the resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>keyword</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/ns/dcat#version -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/ns/dcat#version">
        <terms:description>Version indicator (name or identifier) of a resource.</terms:description>
        <vann:usageNote>DCAT does not prescribe how a version name / identifier should be specified, and refers for guidance to [DWBP]&apos;s Best Practice 7: Provide a version indicator.</vann:usageNote>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>version</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:AnnotationProperty>
    


    <!-- https://w3id.org/emmo#EMMO_31252f35_c767_4b97_a877_1235076c3e13 -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/emmo#EMMO_31252f35_c767_4b97_a877_1235076c3e13">
        <terms:description>A comment that helps the reader to understand how the world has been conceptualised by the ontology authors.</terms:description>
        <rdfs:domain>rdfs:Class</rdfs:domain>
        <rdfs:label>conceptualisation</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- https://w3id.org/emmo#EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/emmo#EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9">
        <terms:description>Short enlightening explanation aimed to facilitate the user in drawing the connection (interpretation) between a OWL entity and the real world object(s) for which it stands.  It should address the real world entities using the concepts introduced by the conceptualisation.</terms:description>
        <rdfs:domain>rdfs:Class</rdfs:domain>
        <rdfs:label>elucidation</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- https://w3id.org/emmo/application/datadoc#unitSymbol -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/emmo/application/datadoc#unitSymbol">
        <terms:description xml:lang="en">A SI unit associated to a property.</terms:description>
        <vann:usageNote xml:lang="en">The unit should be written with standard SI unit symbols.  Examples: As, μm, J, m/s²</vann:usageNote>
        <rdfs:label xml:lang="en">unitSymbol</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
    </owl:AnnotationProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#generatorType -->


