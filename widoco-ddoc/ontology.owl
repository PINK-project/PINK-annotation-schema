        <rdfs:label>checksumValue</rdfs:label>
        <rdfs:range>xsd:hexBinary</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2002/07/owl#deprecated -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/07/owl#deprecated">
        <terms:description>The annotation property that indicates that a given entity has been deprecated. It should equal to `&quot;true&quot;^^xsd:boolean`.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>deprecated</rdfs:label>
        <rdfs:range>xsd:boolean</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2002/07/owl#maxQualifiedCardinality -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/07/owl#maxQualifiedCardinality">
        <terms:description>The property that determines the cardinality of a maximum qualified cardinality restriction.</terms:description>
        <rdfs:domain>owl:Restriction</rdfs:domain>
        <rdfs:label>maxQualifiedCardinality</rdfs:label>
        <rdfs:range>xsd:nonNegativeInteger</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2002/07/owl#minQualifiedCardinality -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/07/owl#minQualifiedCardinality">
        <terms:description>The property that determines the cardinality of a minimum qualified cardinality restriction.</terms:description>
        <rdfs:domain>owl:Restriction</rdfs:domain>
        <rdfs:label>minQualifiedCardinality</rdfs:label>
        <rdfs:range>xsd:nonNegativeInteger</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2002/07/owl#qualifiedCardinality -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2002/07/owl#qualifiedCardinality">
        <terms:description>The property that determines the cardinality of an exact qualified cardinality restriction.</terms:description>
        <rdfs:domain>owl:Restriction</rdfs:domain>
        <rdfs:label>qualifiedCardinality</rdfs:label>
        <rdfs:range>xsd:nonNegativeInteger</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#byteSize -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#byteSize">
        <terms:description>The size of a Distribution in bytes.</terms:description>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>byteSize</rdfs:label>
        <rdfs:range>xsd:nonNegativeInteger</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#downloadURL -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#downloadURL">
        <terms:description>A URL that is a direct link to a downloadable file in a given format. The format is indicated by the distribution&apos;s &apos;dterms:format&apos; and/or &apos;dcat:mediaType&apos;.</terms:description>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>downloadURL</rdfs:label>
        <rdfs:range>xsd:anyURI</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#endpointURL -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#endpointURL">
        <terms:description>The root location or primary endpoint of the service (an IRI).</terms:description>
        <rdfs:domain>dcat:DataService</rdfs:domain>
        <rdfs:label>endpointURL</rdfs:label>
        <rdfs:range>xsd:anyURI</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:mandatory</datadoc:conformance>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#spatialResolutionInMeters -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#spatialResolutionInMeters">
        <terms:description>The minimum spatial separation resolvable in a dataset, measured in meters.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>spatialResolution</rdfs:label>
        <rdfs:range>xsd:decimal</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#temporalResolution -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#temporalResolution">
        <terms:description>The minimum time period resolvable in the dataset.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>temporalResolution</rdfs:label>
        <rdfs:range>xsd:duration</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name">
        <terms:description>A name of the agent.</terms:description>
        <rdfs:domain>foaf:Agent</rdfs:domain>
        <rdfs:label>name</rdfs:label>
        <rdfs:range>xsd:string</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:mandatory</datadoc:conformance>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#hasConfiguration -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/emmo/domain/oteio#hasConfiguration">
        <terms:description>A JSON string with configurations specific to the parser or generator.</terms:description>
        <rdfs:domain>oteio:Parser</rdfs:domain>
        <rdfs:label>configuration</rdfs:label>
        <rdfs:range>rdf:JSON</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#hasDatamodelStorage -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/emmo/domain/oteio#hasDatamodelStorage">
        <terms:description>URL to DLite storage plugin where the datamodel is stored.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>datamodelStorage</rdfs:label>
        <rdfs:range>xsd:anyURI</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#mapping -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/emmo/domain/oteio#mapping">
        <terms:description>A list of subject-predicate-object triples mapping the datamodel to ontological concepts.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>mappings</rdfs:label>
        <rdfs:range>rdf:JSON</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#mappingURL -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/emmo/domain/oteio#mappingURL">
        <terms:description>URL to a document defining the mappings of the datamodel. The file format is given by `mappingFormat`. Defaults to turtle.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>mappingURL</rdfs:label>
        <rdfs:range>xsd:anyURI</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#statement -->


