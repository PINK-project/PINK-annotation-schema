    <!-- http://www.w3.org/2006/vcard/ns#Kind -->


    <owl:Class rdf:about="http://www.w3.org/2006/vcard/ns#Kind">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A description following the vCard specification, e.g. to provide telephone number and e-mail address for a contact point.</terms:description>
