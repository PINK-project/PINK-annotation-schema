        <rdfs:label>bbox</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/ns/dcat#centroid -->


