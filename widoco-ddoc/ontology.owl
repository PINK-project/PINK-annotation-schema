        <rdfs:domain>oteio:Generator</rdfs:domain>
        <rdfs:label>generatorType</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#mappingFormat -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/emmo/domain/oteio#mappingFormat">
        <terms:description>File format for `mappingURL`. Defaults to &quot;turtle&quot;.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>mappingFormat</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


    <!-- https://w3id.org/emmo/domain/oteio#parserType -->


