        <rdfs:range>dcterms:LicenseDocument</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/dc/terms/publisher -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/publisher">
        <terms:description>Agent responsible for making the resource available.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
