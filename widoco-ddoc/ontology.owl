        <rdfs:domain>rdfs:Class</rdfs:domain>
        <rdfs:label>prefLabel</rdfs:label>
        <rdfs:range>rdf:langString</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:AnnotationProperty>
    


