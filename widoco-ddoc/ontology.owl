        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <terms:description>A collection of data, published or curated by an agent, and available for access or download in one or more representations.</terms:description>
        <vann:usageNote>This class represents the actual dataset as published by the dataset provider. In cases where a distinction between the actual dataset and its entry in the catalog is necessary (because metadata such as modification date and maintainer might differ), the catalog record class can be used for the latter.</vann:usageNote>
        <rdfs:subClassOf>dcat:Resource</rdfs:subClassOf>
