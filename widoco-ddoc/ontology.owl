    <!-- http://www.w3.org/ns/adms#versionNotes -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/ns/adms#versionNotes">
        <terms:description>A description of the differences between this version and a previous version of the resource.</terms:description>
        <vann:usageNote>This property can be repeated for parallel language versions of the version notes.</vann:usageNote>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>versionNotes</rdfs:label>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/ns/dcat#bbox -->


