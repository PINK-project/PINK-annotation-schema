    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/adms#sample -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/adms#sample">
        <terms:description>A sample distribution of the dataset.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>sample</rdfs:label>
        <rdfs:range>dcat:Distribution</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#accessService -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#accessService">
        <terms:description>A data service that gives access to the distribution of the dataset.</terms:description>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>accessService</rdfs:label>
        <rdfs:range>dcat:DataService</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#accessURL -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#accessURL">
        <terms:description>A URL that gives access to a Distribution of the Dataset. E.g. landing page, feed, SPARQL endpoint. Use for all cases except a simple download link, in which case downloadURL is preferred.</terms:description>
        <vann:usageNote>The resource at the access URL may contain information about how to get the Dataset.</vann:usageNote>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>accessURL</rdfs:label>
        <rdfs:range>rdfs:Resource</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:mandatory</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#compressFormat -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#compressFormat">
        <terms:description>The format of the file in which the data is contained in a compressed form, e.g. to reduce the size of the downloadable file.</terms:description>
        <vann:usageNote>It SHOULD be expressed using a media type as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types).</vann:usageNote>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>compressFormat</rdfs:label>
        <rdfs:range>dcterms:MediaType</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#contactPoint -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#contactPoint">
        <terms:description>Contact information that can be used for sending comments about the resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>contactPoint</rdfs:label>
        <rdfs:range>vcard:Kind</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#distribution -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#distribution">
        <terms:description>An available distribution for the dataset.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>distribution</rdfs:label>
        <rdfs:range>dcat:Distribution</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#endpointDescription -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#endpointDescription">
        <terms:description>A description of the services available via the end-points, including their operations, parameters etc.</terms:description>
        <rdfs:domain>dcat:DataService</rdfs:domain>
        <rdfs:label>endpointDescription</rdfs:label>
        <rdfs:range>rdfs:Resource</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#hasRole -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#hasRole">
        <terms:description>A function of an entity or agent with respect to another entity or resource.</terms:description>
        <rdfs:domain>dcat:Relationship</rdfs:domain>
        <rdfs:label>hasRole</rdfs:label>
        <rdfs:range>dcat:Role</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#hasVersion -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#hasVersion">
        <terms:description>A related resource that is a version, edition, or adaptation of the described resource.</terms:description>
        <vann:usageNote>This property is intended for relating a non-versioned or abstract resource to several versioned resources, e.g., snapshots.</vann:usageNote>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>hasVersion</rdfs:label>
        <rdfs:range>rdfs:Resource</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#inSeries -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#inSeries">
        <terms:description>A dataset series of which the dataset is part.</terms:description>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>inSeries</rdfs:label>
        <rdfs:range>dcat:DatasetSeries</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#landingPage -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#landingPage">
        <terms:description>A web page that provides access to the resource and/or additional information (e.g. the distribution for a dataset).</terms:description>
        <vann:usageNote>It is intended to point to a landing page at the original
data provider, not to a page on a site of a third party,
such as an aggregator.

For distributions, if they are accessible only through a
landing page (i.e. direct download URLs are not known), then
the landing page link should be duplicated as accessURL on a
distribution.
</vann:usageNote>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>landingPage</rdfs:label>
        <rdfs:range>foaf:Document</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#mediaType -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#mediaType">
        <terms:description>The media type of the Distribution as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types).</terms:description>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>mediaType</rdfs:label>
        <rdfs:range>dcterms:MediaType</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#packageFormat -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#packageFormat">
        <terms:description>The format of the file in which one or more data files are grouped together, e.g. to enable a set of related files to be downloaded together.</terms:description>
        <vann:usageNote>It SHOULD be expressed using a media type as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) and prefixed with `https://www.iana.org/assignments/media-types/`.</vann:usageNote>
        <rdfs:domain>dcat:Distribution</rdfs:domain>
        <rdfs:label>packageFormat</rdfs:label>
        <rdfs:range>dcterms:MediaType</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#qualifiedRelation -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#qualifiedRelation">
        <terms:description>A description of a relationship with another resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>qualifiedRelation</rdfs:label>
        <rdfs:range>dcat:Relationship</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#servesDataset -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#servesDataset">
        <terms:description>This property refers to a collection of data that this data service can distribute.</terms:description>
        <rdfs:domain>dcat:DataService</rdfs:domain>
        <rdfs:label>servesDataset</rdfs:label>
        <rdfs:range>dcat:Dataset</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:recommended</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#theme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#theme"/>
    


    <!-- http://www.w3.org/ns/locn#geometry -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/locn#geometry">
        <terms:description>The geographic center (centroid) of a resource.</terms:description>
        <rdfs:domain>dcterms:Location</rdfs:domain>
        <rdfs:label>geometry</rdfs:label>
        <rdfs:range>locn:Geometry</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#qualifiedAttribution -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#qualifiedAttribution">
        <terms:description>An Agent having some form of responsibility for the resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
        <rdfs:label>qualifiedAttribution</rdfs:label>
        <rdfs:range>prov:Attribution</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasDerivedFrom -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom">
        <terms:description>A derivation is a transformation of an entity into another, an update of an entity resulting in a new one, or the construction of a new entity based on a pre-existing entity.</terms:description>
        <vann:usageNote>Relates a resource to another resource it was derived from.</vann:usageNote>
        <rdfs:domain>dcat:Dataset</rdfs:domain>
        <rdfs:label>wasDerivedFrom</rdfs:label>
        <rdfs:range>dcat:Resource</rdfs:range>
        <dcat:theme>ddoc:datadoc</dcat:theme>
        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


