        <datadoc:conformance>ddoc:optional</datadoc:conformance>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/contributor">
        <terms:description>An entity responsible for making contributions to the resource.</terms:description>
        <rdfs:domain>dcat:Resource</rdfs:domain>
