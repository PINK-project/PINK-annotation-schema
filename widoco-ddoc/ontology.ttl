                         rdfs:domain "owl:Restriction" ;
                         rdfs:label "qualifiedCardinality" ;
                         rdfs:range "xsd:nonNegativeInteger" ;
                         <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


