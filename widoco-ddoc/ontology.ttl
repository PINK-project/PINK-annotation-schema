                                          <http://purl.org/vocab/vann/usageNote> "It SHOULD be expressed using a media type as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) and prefixed with `https://www.iana.org/assignments/media-types/`." ;
                                          rdfs:domain "dcat:Distribution" ;
                                          rdfs:label "packageFormat" ;
                                          rdfs:range "dcterms:MediaType" ;
                                          <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                          <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


