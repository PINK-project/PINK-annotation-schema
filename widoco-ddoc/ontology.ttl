                                               rdfs:range "rdf:JSON" ;
                                               <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/eli/ontology#LegalResource
<http://data.europa.eu/eli/ontology#LegalResource> rdf:type owl:Class ;
                                                   rdfs:subClassOf rdfs:Class ;
                                                   <http://purl.org/dc/terms/description> "This class represents the legislation, policy or policies that lie behind the Rules that govern the service." ;
                                                   <http://purl.org/vocab/vann/usageNote> "The definition and properties of the Legal Resource class are aligned with the ontology included in \"Council conclusions inviting the introduction of the European Legislation Identifier (ELI)\". For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the (ELI) ontology. In this data specification the use is restricted to instances of this class that follow the (ELI) URI guidelines." .


###  http://purl.org/dc/terms/LicenseDocument
<http://purl.org/dc/terms/LicenseDocument> rdf:type owl:Class ;
                                           rdfs:subClassOf rdfs:Class ;
                                           <http://purl.org/dc/terms/description> "A legal document giving official permission to do something with a resource." .


###  http://purl.org/dc/terms/Location
<http://purl.org/dc/terms/Location> rdf:type owl:Class ;
                                    rdfs:subClassOf rdfs:Class ;
                                    <http://purl.org/dc/terms/description> "A spatial region or named place." ;
                                    <http://purl.org/vocab/vann/usageNote> "It can be represented using a controlled vocabulary or with geographic coordinates. In the latter case, the use of the Core Location Vocabulary is recommended, following the approach described in the GeoDCAT-AP specification." .


###  http://purl.org/dc/terms/MediaType
<http://purl.org/dc/terms/MediaType> rdf:type owl:Class ;
                                     rdfs:subClassOf rdfs:Class ;
                                     <http://purl.org/dc/terms/description> "A media type, e.g. the format of a computer file." ;
                                     <http://purl.org/vocab/vann/usageNote> "Media type instances follow the [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types) vocabulary using the <http://www.iana.org/assignments/media-types/> namespace. For example, the IRI of the media type `text/turtle` is <http://www.iana.org/assignments/media-types/text/turtle>." .


###  http://purl.org/dc/terms/RightsStatement
<http://purl.org/dc/terms/RightsStatement> rdf:type owl:Class ;
                                           rdfs:subClassOf rdfs:Class ;
                                           <http://purl.org/dc/terms/description> "A statement about the intellectual property rights (IPR) held in or over a resource, a legal document giving official permission to do something with a resource, or a statement about access rights." ;
                                           <http://purl.org/vocab/vann/usageNote> "EU pre-defines the following individuals: accr:PUBLIC, accr:NON_PUBLIC, accr:CONFIDENTIAL, accr:RESTRICTED, accr:SENSITIVE." .


###  http://purl.org/dc/terms/Standard
<http://purl.org/dc/terms/Standard> rdf:type owl:Class ;
                                    rdfs:subClassOf rdfs:Class ;
                                    <http://purl.org/dc/terms/description> "A standard or other specification to which a resource conforms." .


###  http://spdx.org/rdf/terms#Checksum
<http://spdx.org/rdf/terms#Checksum> rdf:type owl:Class ;
                                     rdfs:subClassOf rdfs:Class ;
                                     <http://purl.org/dc/terms/description> "A preferred label of the concept." .


###  http://spdx.org/rdf/terms#ChecksumAlgorithm
<http://spdx.org/rdf/terms#ChecksumAlgorithm> rdf:type owl:Class ;
                                              rdfs:subClassOf rdfs:Class ;
                                              <http://purl.org/dc/terms/description> "Algorithm for Checksums." ;
                                              <http://purl.org/vocab/vann/usageNote> "This specification does not impose any additional requirements to properties for this entity." .


###  http://www.w3.org/2000/01/rdf-schema#Class
rdfs:Class rdf:type owl:Class ;
           rdfs:subClassOf rdfs:Class ;
           <http://purl.org/dc/terms/description> "The class of classes." .


###  http://www.w3.org/2000/01/rdf-schema#Datatype
rdfs:Datatype rdf:type owl:Class .


###  http://www.w3.org/2000/01/rdf-schema#Resource
rdfs:Resource rdf:type owl:Class ;
              rdfs:subClassOf rdfs:Class ;
              <http://purl.org/dc/terms/description> "A generic resource defined by RDFS." .


###  http://www.w3.org/2002/07/owl#Class
owl:Class rdf:type owl:Class ;
          rdfs:subClassOf rdfs:Class ;
          <http://purl.org/dc/terms/description> "The class of OWL classes." ;
          rdfs:subClassOf "rdfs:Class" .


###  http://www.w3.org/2002/07/owl#Restriction
owl:Restriction rdf:type owl:Class ;
                rdfs:subClassOf rdfs:Class ;
                <http://purl.org/dc/terms/description> "The class of property restrictions." .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class ;
                                              rdfs:subClassOf rdfs:Class ;
                                              <http://purl.org/dc/terms/description> "An idea or notion; a unit of thought." ;
                                              <http://purl.org/vocab/vann/usageNote> "In DCAT-AP, a Concept is used to denote codes within a codelist. See [DCAT-AP](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#controlled-vocs) for expectations and more detail." .


###  http://www.w3.org/2006/vcard/ns#Kind
<http://www.w3.org/2006/vcard/ns#Kind> rdf:type owl:Class ;
                                       rdfs:subClassOf rdfs:Class ;
                                       <http://purl.org/dc/terms/description> "A description following the vCard specification, e.g. to provide telephone number and e-mail address for a contact point." ;
                                       <http://purl.org/vocab/vann/usageNote> "Note that the class Kind is the parent class for the four explicit types of vCard (Individual, Organization, Location, Group)." .


###  http://www.w3.org/ns/dcat#DataService
<http://www.w3.org/ns/dcat#DataService> rdf:type owl:Class ;
                                        rdfs:subClassOf rdfs:Class ;
                                        <http://purl.org/dc/terms/description> "A collection of operations that provides access to one or more datasets or data processing functions." ;
                                        rdfs:subClassOf "rdfs:Resource" .


###  http://www.w3.org/ns/dcat#Dataset
<http://www.w3.org/ns/dcat#Dataset> rdf:type owl:Class ;
                                    rdfs:subClassOf rdfs:Class ;
                                    <http://purl.org/dc/terms/description> "A collection of data, published or curated by an agent, and available for access or download in one or more representations." ;
                                    <http://purl.org/vocab/vann/usageNote> "This class represents the actual dataset as published by the dataset provider. In cases where a distinction between the actual dataset and its entry in the catalog is necessary (because metadata such as modification date and maintainer might differ), the catalog record class can be used for the latter." ;
                                    rdfs:subClassOf "dcat:Resource" ,
                                                    "emmo:EMMO_194e367c_9783_4bf5_96d0_9ad597d48d9a" .


###  http://www.w3.org/ns/dcat#DatasetSeries
<http://www.w3.org/ns/dcat#DatasetSeries> rdf:type owl:Class ;
                                          rdfs:subClassOf rdfs:Class ;
                                          <http://purl.org/dc/terms/description> "A collection of datasets that are published separately, but share some characteristics that group them." ;
                                          rdfs:subClassOf "dcat:Dataset" .


###  http://www.w3.org/ns/dcat#Distribution
<http://www.w3.org/ns/dcat#Distribution> rdf:type owl:Class ;
                                         rdfs:subClassOf rdfs:Class ;
                                         <http://purl.org/dc/terms/description> "A physical embodiment of the Dataset in a particular format." ;
                                         <http://purl.org/vocab/vann/usageNote> "This represents a general availability of a dataset. It implies no information about the actual access method of the data, i.e., whether by direct download, API, or through a Web page. The use of dcat:downloadURL property indicates directly downloadable distributions." ;
                                         rdfs:subClassOf "dcat:Resource" .


###  http://www.w3.org/ns/dcat#Relationship
<http://www.w3.org/ns/dcat#Relationship> rdf:type owl:Class ;
                                         rdfs:subClassOf rdfs:Class ;
