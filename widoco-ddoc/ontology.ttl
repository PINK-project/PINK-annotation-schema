owl:deprecated rdf:type owl:DatatypeProperty ;
               <http://purl.org/dc/terms/description> "The annotation property that indicates that a given entity has been deprecated. It should equal to `\"true\"^^xsd:boolean`." ;
               rdfs:domain "dcat:Resource" ;
               rdfs:label "deprecated" ;
               rdfs:range "xsd:boolean" ;
               <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


