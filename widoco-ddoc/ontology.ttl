                                       <http://purl.org/dc/terms/description> "A related resource that is a version, edition, or adaptation of the described resource." ;
                                       <http://purl.org/vocab/vann/usageNote> "This property is intended for relating a non-versioned or abstract resource to several versioned resources, e.g., snapshots." ;
                                       rdfs:domain "dcat:Resource" ;
                                       rdfs:label "hasVersion" ;
                                       rdfs:range "rdfs:Resource" ;
