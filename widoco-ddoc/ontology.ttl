                                          rdfs:domain "spdx:Checksum" ;
                                          rdfs:label "checksumValue" ;
                                          rdfs:range "xsd:hexBinary" ;
                                          <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


