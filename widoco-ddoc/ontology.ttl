                                  rdfs:range "xsd:date" ;
                                  <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                  <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://purl.org/dc/terms/language
<http://purl.org/dc/terms/language> rdf:type owl:DatatypeProperty ;
                                    <http://purl.org/dc/terms/description> "A language of the resource." ;
                                    <http://purl.org/vocab/vann/usageNote> """Recommended practice is to use either a non-literal value
representing a language from a controlled vocabulary such as
ISO 639-2 or ISO 639-3, or a literal value consisting of an
IETF Best Current Practice 47
[[IETF-BCP47](https://tools.ietf.org/html/bcp47)] language
tag.

Example values: \"en\", \"it\", \"no\", \"da\"

This property can be repeated if the resource is expressed
with multiple languages.
""" ;
                                    rdfs:domain "dcat:Resource" ;
                                    rdfs:label "language" ;
                                    rdfs:range "xsd:string" ;
                                    <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                    <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:DatatypeProperty ;
                                    <http://purl.org/dc/terms/description> "The most recent date on which the resource was changed or modified." ;
                                    rdfs:domain "dcat:Resource" ;
                                    rdfs:label "modificationDate" ;
                                    rdfs:range "xsd:date" ;
                                    <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                    <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://spdx.org/rdf/terms#checksumValue
<http://spdx.org/rdf/terms#checksumValue> rdf:type owl:DatatypeProperty ;
