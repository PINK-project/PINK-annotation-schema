###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:DatatypeProperty ;
                                  <http://purl.org/dc/terms/description> "The date of formal issuance (e.g., publication) of the resource." ;
                                  rdfs:domain "dcat:Resource" ;
