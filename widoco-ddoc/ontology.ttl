###  http://www.w3.org/ns/adms#versionNotes
<http://www.w3.org/ns/adms#versionNotes> rdf:type owl:AnnotationProperty ;
                                         <http://purl.org/dc/terms/description> "A description of the differences between this version and a previous version of the resource." ;
                                         <http://purl.org/vocab/vann/usageNote> "This property can be repeated for parallel language versions of the version notes." ;
                                         rdfs:domain "dcat:Resource" ;
                                         rdfs:label "versionNotes" ;
                                         <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                         <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://www.w3.org/ns/dcat#bbox
<http://www.w3.org/ns/dcat#bbox> rdf:type owl:AnnotationProperty ;
                                 <http://purl.org/dc/terms/description> "The geographic bounding box of a resource." ;
                                 rdfs:domain "dcterms:Location" ;
                                 rdfs:label "bbox" ;
                                 <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                 <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:recommended" .


###  http://www.w3.org/ns/dcat#centroid
<http://www.w3.org/ns/dcat#centroid> rdf:type owl:AnnotationProperty ;
                                     <http://purl.org/dc/terms/description> "The geographic center (centroid) of a resource." ;
                                     rdfs:domain "dcterms:Location" ;
                                     rdfs:label "centroid" ;
                                     <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                     <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:recommended" .


###  http://www.w3.org/ns/dcat#keyword
<http://www.w3.org/ns/dcat#keyword> rdf:type owl:AnnotationProperty ;
                                    <http://purl.org/dc/terms/description> "A keyword or tag describing the resource." ;
                                    rdfs:domain "dcat:Resource" ;
                                    rdfs:label "keyword" ;
                                    rdfs:range "rdf:langString" ;
                                    <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                    <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:recommended" .


###  http://www.w3.org/ns/dcat#version
<http://www.w3.org/ns/dcat#version> rdf:type owl:AnnotationProperty ;
                                    <http://purl.org/dc/terms/description> "Version indicator (name or identifier) of a resource." ;
                                    <http://purl.org/vocab/vann/usageNote> "DCAT does not prescribe how a version name / identifier should be specified, and refers for guidance to [DWBP]'s Best Practice 7: Provide a version indicator." ;
                                    rdfs:domain "dcat:Resource" ;
                                    rdfs:label "version" ;
                                    <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                    <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  https://w3id.org/emmo#EMMO_31252f35_c767_4b97_a877_1235076c3e13
<https://w3id.org/emmo#EMMO_31252f35_c767_4b97_a877_1235076c3e13> rdf:type owl:AnnotationProperty ;
                                                                  <http://purl.org/dc/terms/description> "A comment that helps the reader to understand how the world has been conceptualised by the ontology authors." ;
                                                                  rdfs:domain "rdfs:Class" ;
                                                                  rdfs:label "conceptualisation" ;
                                                                  rdfs:range "rdf:langString" ;
                                                                  <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  https://w3id.org/emmo#EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9
<https://w3id.org/emmo#EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9> rdf:type owl:AnnotationProperty ;
                                                                  <http://purl.org/dc/terms/description> "Short enlightening explanation aimed to facilitate the user in drawing the connection (interpretation) between a OWL entity and the real world object(s) for which it stands.  It should address the real world entities using the concepts introduced by the conceptualisation." ;
                                                                  rdfs:domain "rdfs:Class" ;
                                                                  rdfs:label "elucidation" ;
                                                                  rdfs:range "rdf:langString" ;
                                                                  <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  https://w3id.org/emmo/application/datadoc#unitSymbol
<https://w3id.org/emmo/application/datadoc#unitSymbol> rdf:type owl:AnnotationProperty ;
                                                       <http://purl.org/dc/terms/description> "A SI unit associated to a property."@en ;
                                                       <http://purl.org/vocab/vann/usageNote> "The unit should be written with standard SI unit symbols.  Examples: As, μm, J, m/s²"@en ;
                                                       rdfs:label "unitSymbol"@en ;
                                                       rdfs:range xsd:string ;
                                                       rdfs:domain <http://www.w3.org/ns/dcat#Resource> .


###  https://w3id.org/emmo/domain/oteio#generatorType
<https://w3id.org/emmo/domain/oteio#generatorType> rdf:type owl:AnnotationProperty ;
                                                   <http://purl.org/dc/terms/description> "Generator type. Ex: `application/vnd.dlite-generate`." ;
                                                   rdfs:domain "oteio:Generator" ;
                                                   rdfs:label "generatorType" ;
                                                   <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  https://w3id.org/emmo/domain/oteio#mappingFormat
<https://w3id.org/emmo/domain/oteio#mappingFormat> rdf:type owl:AnnotationProperty ;
                                                   <http://purl.org/dc/terms/description> "File format for `mappingURL`. Defaults to \"turtle\"." ;
                                                   rdfs:domain "dcat:Dataset" ;
                                                   rdfs:label "mappingFormat" ;
                                                   <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  https://w3id.org/emmo/domain/oteio#parserType
<https://w3id.org/emmo/domain/oteio#parserType> rdf:type owl:AnnotationProperty ;
                                                <http://purl.org/dc/terms/description> "Parser type. Ex: `application/vnd.dlite-parse`." ;
                                                rdfs:domain "oteio:Parser" ;
                                                rdfs:label "parserType" ;
                                                <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


#################################################################
#    Object Properties
#################################################################

###  http://data.europa.eu/r5r/applicableLegislation
<http://data.europa.eu/r5r/applicableLegislation> rdf:type owl:ObjectProperty ;
                                                  <http://purl.org/dc/terms/description> "The legislation that mandates the creation or management of the resource." ;
                                                  rdfs:domain "dcat:Resource" ;
                                                  rdfs:label "applicableLegislation" ;
                                                  rdfs:range "eli:LegalResource" ;
                                                  <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                                  <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://data.europa.eu/r5r/status
<http://data.europa.eu/r5r/status> rdf:type owl:ObjectProperty ;
                                   <http://purl.org/dc/terms/description> "The status of the distribution in the context of maturity lifecycle." ;
                                   <http://purl.org/vocab/vann/usageNote> "It MUST take one of the values: 'stat:Completed', 'stat:Deprecated', 'stat:UnderDevelopment', 'stat:Withdrawn'." ;
                                   rdfs:domain "dcat:Distribution" ;
                                   rdfs:label "status" ;
                                   rdfs:range "skos:Concept" ;
                                   <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                   <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://purl.org/dc/terms/accessRights
<http://purl.org/dc/terms/accessRights> rdf:type owl:ObjectProperty ;
                                        <http://purl.org/dc/terms/description> "Information about who can access the resource or an indication of its security status." ;
                                        <http://purl.org/vocab/vann/usageNote> "Access Rights may include information regarding access or restrictions based on privacy, security, or other policies. The following preferred Rights Statement individuals are defined: `accr:PUBLIC`, `accr:NON_PUBLIC`, `accr:CONFIDENTIAL`, `accr:RESTRICTED`, `accr:SENSITIVE`" ;
                                        rdfs:domain "dcat:Resource" ;
                                        rdfs:label "accessRights" ;
                                        rdfs:range "dcterms:RightsStatement" ;
                                        <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                        <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://purl.org/dc/terms/accrualPeriodicity
