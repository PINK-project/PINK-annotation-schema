                                             rdfs:domain "dcat:Dataset" ;
                                             rdfs:label "mappings" ;
                                             rdfs:range "rdf:JSON" ;
                                             <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  https://w3id.org/emmo/domain/oteio#mappingURL
<https://w3id.org/emmo/domain/oteio#mappingURL> rdf:type owl:DatatypeProperty ;
