<http://www.w3.org/ns/dcat#mediaType> rdf:type owl:ObjectProperty ;
                                      <http://purl.org/dc/terms/description> "The media type of the Distribution as defined in the official register of media types managed by [IANA](https://www.w3.org/TR/vocab-dcat-3/#bib-iana-media-types)." ;
                                      rdfs:domain "dcat:Distribution" ;
                                      rdfs:label "mediaType" ;
                                      rdfs:range "dcterms:MediaType" ;
                                      <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                      <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:recommended" .


