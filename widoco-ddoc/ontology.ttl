@prefix : <https://w3id.org/pink/ddoc#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/pink/ddoc#> .

<https://w3id.org/pink/ddoc> rdf:type owl:Ontology ;
                              owl:versionIRI <https://w3id.org/pink/0.0.1/ddoc> ;
                              <http://purl.org/dc/terms/title> "Concepts defined in the ddoc vocabulary."@en ,
                                                               "Data documentation ontology" ;
                              <http://purl.org/vocab/vann/preferredNamespacePrefix> "ddoc" ;
                              <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/emmo/application/datadoc#" ;
                              owl:priorVersion "0.0.0" ;
                              owl:versionInfo "0.0.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty ;
                                    <http://purl.org/dc/terms/description> "A summary of the resource." ;
                                    rdfs:domain "dcat:Resource" ;
                                    rdfs:label "abstract" ;
                                    rdfs:range "rdf:langString" ;
                                    <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://purl.org/dc/terms/bibliographicCitation
<http://purl.org/dc/terms/bibliographicCitation> rdf:type owl:AnnotationProperty ;
                                                 <http://purl.org/dc/terms/description> "A bibliographic reference for the resource." ;
                                                 <http://purl.org/vocab/vann/usageNote> "Recommended practice is to include sufficient bibliographic detail to identify the resource as unambiguously as possible." ;
                                                 rdfs:domain "dcat:Resource" ;
                                                 rdfs:label "bibliographicCitation" ;
                                                 <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty ;
                                       <http://purl.org/dc/terms/description> "A free-text account of the resource." ;
                                       <http://purl.org/vocab/vann/usageNote> "This property can be repeated for parallel language versions of the description." ;
                                       rdfs:domain "dcat:Resource" ;
                                       rdfs:label "description" ;
                                       rdfs:range "rdf:langString" ;
                                       <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                       <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:mandatory" .


###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:AnnotationProperty ;
                                      <http://purl.org/dc/terms/description> "URI or other unique identifier of the resource being described." ;
                                      <http://purl.org/vocab/vann/usageNote> "Recommended practice is to identify the resource by means of a string conforming to an identification system. Examples include International Standard Book Number (ISBN), Digital Object Identifier (DOI), and Uniform Resource Name (URN).  Persistent identifiers should be provided as HTTP URIs." ;
                                      rdfs:domain "foaf:Agent" ;
                                      rdfs:label "identifier" ;
                                      <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" ;
                                      <https://w3id.org/emmo/application/datadoc#conformance> "ddoc:optional" .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/usageNote
<http://purl.org/vocab/vann/usageNote> rdf:type owl:AnnotationProperty ;
                                       <http://purl.org/dc/terms/description> "A reference that provides information on how this resource is to be used." ;
                                       rdfs:domain "rdfs:Resource" ;
                                       rdfs:label "usageNote" ;
                                       rdfs:range "rdf:langString" ;
                                       <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty ;
             <http://purl.org/dc/terms/description> "A description of the subject resource. Use `description` instead." ;
             rdfs:domain "dcat:Resource" ;
             rdfs:label "comment" ;
             <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty ;
           <http://purl.org/dc/terms/description> "Provides a human-readable version of a resource's name." ;
           rdfs:domain "dcat:Resource" ;
           rdfs:label "label" ;
           <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty ;
                                               <http://purl.org/dc/terms/description> "An alternative lexical label for a resource." ;
                                               rdfs:domain "rdfs:Class" ;
                                               rdfs:label "altLabel" ;
                                               rdfs:range "rdf:langString" ;
                                               <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#hiddenLabel
<http://www.w3.org/2004/02/skos/core#hiddenLabel> rdf:type owl:AnnotationProperty ;
                                                  <http://purl.org/dc/terms/description> "A lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations." ;
                                                  rdfs:domain "rdfs:Class" ;
                                                  rdfs:label "hiddenLabel" ;
                                                  rdfs:range "rdf:langString" ;
                                                  <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#notation
<http://www.w3.org/2004/02/skos/core#notation> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty ;
                                                <http://purl.org/dc/terms/description> "A preferred label of the concept." ;
                                                rdfs:domain "rdfs:Class" ;
                                                rdfs:label "prefLabel" ;
                                                rdfs:range "rdf:langString" ;
                                                <http://www.w3.org/ns/dcat#theme> "ddoc:datadoc" .


