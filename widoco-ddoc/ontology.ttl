###  http://www.w3.org/ns/dcat#downloadURL
<http://www.w3.org/ns/dcat#downloadURL> rdf:type owl:DatatypeProperty ;
                                        <http://purl.org/dc/terms/description> "A URL that is a direct link to a downloadable file in a given format. The format is indicated by the distribution's 'dterms:format' and/or 'dcat:mediaType'." ;
                                        rdfs:domain "dcat:Distribution" ;
                                        rdfs:label "downloadURL" ;
